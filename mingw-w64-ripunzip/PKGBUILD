

_realname=ripunzip
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=2.0.4
pkgrel=2
pkgdesc="Extract zip files in parallel (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://github.com/GoogleChrome/${_realname}"
msys2_repository_url="${url}"
msys2_references=(
)
license=('spdx:MIT')
depends=("${MINGW_PACKAGE_PREFIX}-bzip2"
         "${MINGW_PACKAGE_PREFIX}-xz"
         "${MINGW_PACKAGE_PREFIX}-zstd")
makedepends=("${MINGW_PACKAGE_PREFIX}-rust"
             "${MINGW_PACKAGE_PREFIX}-pkgconf")
source=("${url}/archive/refs/tags/v${pkgver}/${_realname}-${pkgver}.tar.gz"
        "bzip2-sys.tar.gz::https://static.crates.io/crates/bzip2-sys/0.1.13+1.0.8/download"
        "zstd-sys.tar.gz::https://static.crates.io/crates/zstd-sys/2.0.15+zstd.1.5.7/download"
        "bzip2-use-pkgconfig.patch")
sha256sums=('b485dc58777fb8637ff0509c72dc6b50235f6a01fecbf382365437be704a8468'
            '225bff33b2141874fe80d71e07d6eec4f85c5c216453dd96388240f96e1acc14'
            'eb81183ddd97d0c74cedf1d50d85c8d08c1b8b68ee863bdee9e706eedba1a237'
            'f73309fb98b89b2085bccee6ffb66820082628d096bc989922b25d33a1f5f378')

prepare() {
  cd "${_realname}-${pkgver}"

  patch -d "../bzip2-sys-0.1.13+1.0.8" -i "../bzip2-use-pkgconfig.patch"
  sed -i "s/statik(true)/statik(false)/" "../zstd-sys-2.0.15+zstd.1.5.7/build.rs"
  cat >> Cargo.toml <<END

[patch.crates-io]
bzip2-sys.path = "../bzip2-sys-0.1.13+1.0.8"
zstd-sys.path = "../zstd-sys-2.0.15+zstd.1.5.7"
END

  cargo update -p bzip2-sys -p zstd-sys
  cargo fetch --locked --target "${RUST_CHOST}"
}

build(){
  cd "${_realname}-$pkgver"
  export ZSTD_SYS_USE_PKG_CONFIG=1
  cargo build --release --frozen
}

package() {
  cd "${_realname}-$pkgver"
  install -Dm755 "target/release/${_realname}" -t "${pkgdir}${MINGW_PREFIX}/bin"
  install -Dm644 LICENSE -t "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}"
}
