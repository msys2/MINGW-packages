--- ITK-5.4.6/Modules/Bridge/VtkGlue/itk-module-init.cmake
+++ ITK-5.4.6/Modules/Bridge/VtkGlue/itk-module-init.cmake
@@ -6,7 +6,7 @@
 set(VERSION_MIN "8.1.0")
 
 # Look for VTK
-find_package(VTK NO_MODULE REQUIRED)
+find_package(VTK ${VERSION_MIN} NO_MODULE REQUIRED COMPONENTS vtkIOImage vtkImagingSources)
 
 if(NOT COMMAND vtk_module_config)
   macro(vtk_module_config ns)
@@ -42,19 +42,29 @@
     set(VTK_RENDERING_BACKEND OpenGL)
   endif()
 endif()
+set(_component_prefix "vtk")
 set(_target_prefix "vtk")
 if(VTK_VERSION VERSION_GREATER_EQUAL 8.90.0)
+  set(_component_prefix "")
   set(_target_prefix "VTK::")
 endif()
-set(_target_freetypeopengl)
-if(TARGET ${_target_prefix}RenderingFreeType${VTK_RENDERING_BACKEND})
-  set(_target_freetypeopengl ${_target_prefix}RenderingFreeType${VTK_RENDERING_BACKEND})
-endif()
 
+set(_required_vtk_components ${_component_prefix}IOImage ${_component_prefix}ImagingSources)
+if(TARGET VTK::jsoncpp)
+  list(APPEND _required_vtk_components jsoncpp)
+endif()
+set(_optional_vtk_components)
 set(_required_vtk_libraries ${_target_prefix}IOImage ${_target_prefix}ImagingSources)
 if(ITK_WRAP_PYTHON)
   list(
     APPEND
+    _required_vtk_components
+    ${_component_prefix}WrappingPythonCore
+    ${_component_prefix}CommonCore
+    ${_component_prefix}CommonDataModel
+    ${_component_prefix}CommonExecutionModel)
+  list(
+    APPEND
     _required_vtk_libraries
     ${_target_prefix}WrappingPythonCore
     ${_target_prefix}CommonCore
@@ -67,12 +77,33 @@
    "None")
   list(
     APPEND
+    _required_vtk_components
+    ${_component_prefix}Rendering${VTK_RENDERING_BACKEND}
+    ${_component_prefix}RenderingFreeType
+    ${_component_prefix}InteractionStyle
+    ${_component_prefix}InteractionWidgets)
+  list(
+    APPEND
     _required_vtk_libraries
     ${_target_prefix}Rendering${VTK_RENDERING_BACKEND}
     ${_target_prefix}RenderingFreeType
-    ${_target_freetypeopengl}
     ${_target_prefix}InteractionStyle
     ${_target_prefix}InteractionWidgets)
+  if(VTK_VERSION VERSION_LESS 8.90.0)
+    list(APPEND _optional_vtk_components ${_component_prefix}RenderingFreeType${VTK_RENDERING_BACKEND})
+  endif()
+endif()
+find_package(
+  VTK
+  ${VERSION_MIN}
+  NO_MODULE
+  REQUIRED
+  COMPONENTS ${_required_vtk_components}
+  OPTIONAL_COMPONENTS ${_optional_vtk_components})
+set(_target_freetypeopengl)
+if(TARGET ${_target_prefix}RenderingFreeType${VTK_RENDERING_BACKEND})
+  set(_target_freetypeopengl ${_target_prefix}RenderingFreeType${VTK_RENDERING_BACKEND})
+  list(APPEND _required_vtk_libraries ${_target_freetypeopengl})
 endif()
 if(${VTK_VERSION} VERSION_LESS ${VERSION_MIN})
   message(ERROR " VtkGlue requires VTK version ${VERSION_MIN} or newer but the current version is ${VTK_VERSION}")
