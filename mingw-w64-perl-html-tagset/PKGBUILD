# Maintainer: @naveen521kk on Github, Naveen M K <naveen521kk@gmail.com>

_perlname=HTML-Tagset
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=3.24
pkgrel=6
pkgdesc="data tables useful in parsing HTML (mingw-w64)"
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/HTML-Tagset"
msys2_repository_url='https://github.com/petdance/html-tagset'
msys2_references=(
  'purl: pkg:cpan/PETDANCE/HTML-Tagset'
)
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=(
  "${MINGW_PACKAGE_PREFIX}-perl"
)
options=('!emptydirs')
makedepends=(
  "${MINGW_PACKAGE_PREFIX}-make"
  "${MINGW_PACKAGE_PREFIX}-python"
)
license=(unknown)
source=(
  "https://cpan.metacpan.org/authors/id/P/PE/PETDANCE/${_perlname}-${pkgver}.tar.gz"
)
sha256sums=('eb89e145a608ed1f8f141a57472ee5f69e67592a432dcd2e8b1dbb445f2b230b')

build() {
  cd "$srcdir/${_perlname}-${pkgver}"
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd "$srcdir/${_perlname}-${pkgver}"
  mingw32-make DESTDIR="${pkgdir}/" install
}
