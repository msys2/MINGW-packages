# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=HTML-Parser
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=3.85
pkgrel=3
pkgdesc="HTML parser class. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/HTML-Parser"
msys2_repository_url="https://github.com/libwww-perl/HTML-Parser"
msys2_references=(
  'purl: pkg:cpan/OALDERS/HTML-Parser'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-html-tagset"
         "${MINGW_PACKAGE_PREFIX}-perl-http-message"
         "${MINGW_PACKAGE_PREFIX}-perl-uri")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/O/OA/OALDERS/${_perlname}-${pkgver}.tar.gz")
sha256sums=('fd42ba6abe07241cf0ad57be246c3980065f683e4465e59b46af9efebc8e0c71')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make CC=${CC} CXX=${CXX} LD=${CXX}
}

package() {
  cd build-${MSYSTEM}
  mingw32-make DESTDIR="${pkgdir}/" install
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
