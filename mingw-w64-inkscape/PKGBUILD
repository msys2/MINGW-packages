        '007-no-console-clang.patch'
        '0001-poppler-2605.patch'
        '0002-poppler-2606.patch'
        '0003-poppler-2607.patch')
sha256sums=('bbce5753a1e08b871a5cf16c665eb060700aaab9a6a379dc63f4c4d9b3b8856e'
            '92387251c1740f1a57cde9e587cc673ef1600813617bd2c9db65598c324a24d4'
