 .../internal/pdfinput/pdf-parser.cpp          | 54 +++++++++----------
 .../pdfinput/poppler-transition-api.h         |  6 +++
 .../internal/pdfinput/poppler-utils.cpp       | 29 +++++-----
 .../internal/pdfinput/poppler-utils.h         |  1 +
 5 files changed, 54 insertions(+), 41 deletions(-)

