# Maintainer: Felix Xing <felixaszx@outlook.com>

_realname=VulkanMemoryAllocator
pkgbase=mingw-w64-vulkan-memory-allocator
pkgname="${MINGW_PACKAGE_PREFIX}-vulkan-memory-allocator"
pkgver="3.0.1"
pkgrel=1
pkgdesc="The industry-leading, open source, memory allocation library for the Vulkan API"
arch=("any")
mingw_arch=('mingw32' 'mingw64' 'ucrt64' 'clang64' 'clang32' 'clangarm64')
url="https://gpuopen.com/vulkan-memory-allocator/"
license=('spdx:MIT')
depends=("${MINGW_PACKAGE_PREFIX}-vulkan-loader")
source=("${_realname}-src-${pkgver}"::"https://github.com/GPUOpen-LibrariesAndSDKs/VulkanMemoryAllocator/archive/v${pkgver}.tar.gz"
        "001-vma-fix-stdio-missing.patch")
sha256sums=('2a84762b2d10bf540b9dc1802a198aca8ad1f3d795a4ae144212c595696a360c'
            'd748333686cfa154aee24df53a5d311344db3df82dc43518e0007ac1ab082cc0')

prepare() {
  cd "${srcdir}"/${_realname}-${pkgver}
  patch -Np1 -i "${srcdir}"/001-vma-fix-stdio-missing.patch
}

package() {
  install -Dm644 "${srcdir}/${_realname}-${pkgver}/include/vk_mem_alloc.h" "${pkgdir}${MINGW_PREFIX}/include/vk_mem_alloc.h"
  install -Dm644 "${srcdir}/${_realname}-${pkgver}/LICENSE.txt" "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
