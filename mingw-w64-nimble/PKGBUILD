# Maintainer: David Macek <david.macek.0@gmail.com>

_realname=nimble
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=0.22.2
pkgrel=1
pkgdesc='Package manager for the Nim programming language (mingw-w64)'
arch=('any')
mingw_arch=('mingw64' 'ucrt64')
url='https://github.com/nim-lang/nimble'
msys2_repository_url='https://github.com/nim-lang/nimble'
msys2_references=(
  'archlinux: '
)
license=('spdx:BSD-3-Clause')
depends=("${MINGW_PACKAGE_PREFIX}-libwinpthread"
         "${MINGW_PACKAGE_PREFIX}-openssl")
makedepends=("${MINGW_PACKAGE_PREFIX}-nim"
             "${MINGW_PACKAGE_PREFIX}-cc"
             "git")
_nimver=2.2.8
_checksumsver=f8f6bd34bfa3fe12c64b919059ad856a96efcba0
_chronosver=0646c444fce7c7ed08ef6f2c9a7abfd172ffe655
_resultsver=df8113dda4c2d74d460a8fa98252b0b771bf1f27
_satver=e63eaea8baf00bed8bcd5a29ffd8823abb265b39
_stewver=b66168735d6f3841c5239c3169d3fe5fe98b1257
_zippyver=a99f6a7d8a8e3e0213b3cad0daf0ea974bf58e3f
source=("https://github.com/nim-lang/nimble/archive/v${pkgver}/${_realname}-${pkgver}.tar.gz"
        "https://github.com/nim-lang/Nim/archive/v${_nimver}/nim-${_nimver}.tar.gz"
        "git+https://github.com/nim-lang/checksums.git#commit=${_checksumsver}"
        "chronos::git+https://github.com/status-im/nim-chronos.git#commit=${_chronosver}"
        "results::git+https://github.com/arnetheduck/nim-results.git#commit=${_resultsver}"
        "git+https://github.com/nim-lang/sat.git#commit=${_satver}"
        "stew::git+https://github.com/status-im/nim-stew.git#commit=${_stewver}"
        "git+https://github.com/guzba/zippy.git#commit=${_zippyver}")
sha256sums=('62c75deba4c468386dd178f830079b0c0634745c329b4a0c065317a83f05b618'
            'e409930c277ad5178427761da4835bd54e3d64f3dc20256bdff1d17084763f37'
            'bf8e33cc93fc22ba62e5511240a9820c7a4f18a5fdd1e8d1f31cec3270d2fec9'
            'a53c2f1ae9f334c69a0e6f26395be279c0ac84e2fca8c4f5cdf3fb5f9fec1031'
            '23b3a1c3754a118c84241ad3f2283f87f8f299cdb6f9f9a5931d680fc609f21e'
            'b9e770e90a143f4022d805edba729e1afdfbe7dcff95f392571d1f9558ef220b'
            '99b53b682b35f3bf7cfc020eea22be4b9d56cd23f05d613d5c603bc08677f0cc'
            '70577edba2d0dd17787abb07d4e496ff1dec888bf378d94218ccaa2a9194c677')

prepare() {
  for _dir in checksums chronos results sat stew zippy; do
    cp -r ${_dir}/* ${_realname}-${pkgver}/vendor/${_dir}/
  done

  _srcdir=$(cygpath -m ${srcdir})
  sed -i "s|from \"\$nim\" / compiler/nimblecmd|from \"${_srcdir}/Nim-${_nimver}\"/compiler/nimblecmd|g" ${_realname}-${pkgver}/src/nimblepkg/tools.nim
  sed -i "s|import ../dist/checksums/src/checksums/sha1|import \"${_srcdir}\"/checksums/src/checksums/sha1|g" Nim-${_nimver}/compiler/nimblecmd.nim
}

build() {
  cd "${srcdir}/${_realname}-${pkgver}"

  nim c -d:release src/nimble.nim
}

package() {
  cd "${srcdir}/${_realname}-${pkgver}"

  install -Dm 755 "src/nimble.exe" -t "${pkgdir}${MINGW_PREFIX}/bin/"
  install -Dm 644  "license.txt" "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
