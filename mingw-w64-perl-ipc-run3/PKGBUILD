# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=IPC-Run3
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=0.049
pkgrel=1
pkgdesc="Run a subprocess with input/output redirection. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/IPC-Run3"
msys2_repository_url="https://github.com/rjbs/IPC-Run3"
msys2_references=(
  'purl: pkg:cpan/RJBS/IPC-Run3'
)
license=('spdx:BSD-2-Clause OR Artistic-2.0 OR GPL-3.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/R/RJ/RJBS/${_perlname}-${pkgver}.tar.gz")
sha256sums=('9d048ae7b9ae63871bae976ba01e081d887392d904e5d48b04e22d35ed22011a')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  mingw32-make DESTDIR="${pkgdir}/" install
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
