_realname=kimi-code
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=0.28.1
pkgrel=1
pkgdesc='An open-source AI coding agent developed by Moonshot AI and highly optimized for Kimi models (mingw-w64)'
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://github.com/MoonshotAI/kimi-code'
msys2_repository_url='https://github.com/MoonshotAI/kimi-code'
msys2_changelog_url='https://github.com/MoonshotAI/kimi-code/blob/main/apps/kimi-code/CHANGELOG.md'
msys2_references=(
  'aur: kimi-code'
  'purl: pkg:npm/@moonshot-ai/kimi-code'
)
license=('spdx:MIT')
depends=("bash"
         "${MINGW_PACKAGE_PREFIX}-git"
         "${MINGW_PACKAGE_PREFIX}-nodejs")
source=("https://registry.npmjs.org/@moonshot-ai/${_realname}/-/${_realname}-${pkgver}.tgz")
sha256sums=('aafbea0441eef5dae3f752accd51713341039fd1c117d166835609e641e094b9')
options=('!strip')

package() {
  "${MINGW_PREFIX}"/bin/npm install -g \
    --cache "${srcdir}/npm-cache" \
    --prefix "${pkgdir}${MINGW_PREFIX}" \
    "${srcdir}/${_realname}-${pkgver}.tgz"

  install -vDm644 -t "${pkgdir}${MINGW_PREFIX}/share/doc/${_realname}" \
    "${srcdir}/package/README.md"
  install -vDm644 "${srcdir}/package/LICENSE" \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
