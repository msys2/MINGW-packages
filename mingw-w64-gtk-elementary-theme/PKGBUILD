# Maintainer: Alberto Fanjul Alonso <albfan@gnome.org>

_realname=gtk-elementary-theme
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=8.2.2
pkgrel=1
pkgdesc="The GTK Stylesheet for elementary OS (mingw-w64)"
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url="https://github.com/elementary/stylesheet"
msys2_repository_url='https://github.com/elementary/stylesheet'
msys2_references=(
  'archlinux: gtk-theme-elementary'
)
license=("spdx:GPL-3.0-or-later")
makedepends=("${MINGW_PACKAGE_PREFIX}-meson"
             "${MINGW_PACKAGE_PREFIX}-gettext-tools"
             "${MINGW_PACKAGE_PREFIX}-sassc")
source=(${_realname}-${pkgver}.tar.gz::https://github.com/elementary/stylesheet/archive/${pkgver}.tar.gz)
sha256sums=('b5f016c9e7c528d18bb1fa7a405bc294af336a9d967574a66eb22e5fffb89aa9')

build() {
  MSYS2_ARG_CONV_EXCL="--prefix=" \
  ${MINGW_PREFIX}/bin/meson.exe setup \
    --prefix="${MINGW_PREFIX}" \
    --buildtype plain \
    --wrap-mode nodownload \
    build-${MSYSTEM} \
    stylesheet-${pkgver}

  ${MINGW_PREFIX}/bin/meson.exe compile -C build-${MSYSTEM}
}

package() {
  ${MINGW_PREFIX}/bin/meson.exe install -C build-${MSYSTEM} --destdir="${pkgdir}"

  install -Dm644 "${srcdir}"/stylesheet-${pkgver}/COPYING \
    "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/COPYING
}
