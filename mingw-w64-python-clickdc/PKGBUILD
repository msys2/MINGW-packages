# Contributor: Kreijstal <kreijstal@hotmail.com>

_realname=clickdc
pkgbase=mingw-w64-python-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-python-${_realname}")
pkgver=0.1.1
pkgrel=1
pkgdesc='Manage click arguments using python dataclass (mingw-w64)'
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url='https://github.com/Kamilcuk/clickdc'
msys2_repository_url='https://github.com/Kamilcuk/clickdc'
msys2_references=(
  'purl: pkg:pypi/clickdc'
)
license=('spdx:MIT')
depends=("${MINGW_PACKAGE_PREFIX}-python"
         "${MINGW_PACKAGE_PREFIX}-python-click"
         "${MINGW_PACKAGE_PREFIX}-python-typing_extensions")
makedepends=("${MINGW_PACKAGE_PREFIX}-python-build"
             "${MINGW_PACKAGE_PREFIX}-python-installer"
             "${MINGW_PACKAGE_PREFIX}-python-setuptools"
             "${MINGW_PACKAGE_PREFIX}-python-wheel")
options=('!strip')
source=("https://pypi.org/packages/source/${_realname::1}/${_realname}/${_realname}-${pkgver}.tar.gz")
sha256sums=('077f04d7ad00509b43aa8e37a9c7df307c00a73f7fef265235ef98ca54235b9b')

prepare() {
  cd "${srcdir}/${_realname}-${pkgver}"
  # Replace setuptools-git-versioning with a static version since we build
  # from a release tarball without a git checkout.
  sed -i \
    -e 's|"setuptools-git-versioning<2",||' \
    -e 's|dynamic = \["version", "dependencies", "optional-dependencies"\]|dynamic = ["dependencies", "optional-dependencies"]\nversion = "'"${pkgver}"'"|' \
    -e '/\[tool.setuptools-git-versioning\]/,/^$/d' \
    pyproject.toml
}

build() {
  cp -r "${_realname}-${pkgver}" "python-build-${MSYSTEM}" && cd "python-build-${MSYSTEM}"
  ${MINGW_PREFIX}/bin/python -m build --wheel --skip-dependency-check --no-isolation
}

package() {
  cd "${srcdir}/python-build-${MSYSTEM}"
  MSYS2_ARG_CONV_EXCL="--prefix=" \
    ${MINGW_PREFIX}/bin/python -m installer --prefix=${MINGW_PREFIX} \
    --destdir="${pkgdir}" dist/*.whl

  install -Dm644 "${srcdir}/${_realname}-${pkgver}/LICENSE" \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/python-${_realname}/LICENSE"
}
