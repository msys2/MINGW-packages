+// Parse a PATH spec into a vector<string>
+static void make_path_vec(const char *ep, vector<string>& vec)
+{
+    if (ep && *ep) {
+        string eps(ep);
+        trimstring(eps, ";");
+        stringToTokens(eps, vec, ";");
+    }
+}
