# Contributor: Kreijstal <kreijstal@hotmail.com>

_realname=libretro-genesis-plus-gx
_corename=genesis_plus_gx
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=r1.1656ce5
pkgrel=1
pkgdesc='Sega Master System / Game Gear / Mega Drive / Genesis libretro core (Genesis Plus GX) (mingw-w64)'
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://www.libretro.com/'
msys2_repository_url='https://github.com/libretro/Genesis-Plus-GX'
license=('custom:non-commercial')
groups=("${MINGW_PACKAGE_PREFIX}-libretro")
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "git" "make")
optdepends=("${MINGW_PACKAGE_PREFIX}-retroarch: frontend that loads this core"
            "${MINGW_PACKAGE_PREFIX}-libretro-core-info: required for the core to show up in the menu")
_commit=1656ce52ea42c15aa179e776eb0d6bcd59d6ae91
source=("Genesis-Plus-GX::git+https://github.com/libretro/Genesis-Plus-GX.git#commit=${_commit}"
        "0001-Makefile-libretro-drop-Wl-version-script-for-PE-COFF.patch")
sha256sums=('4cd27e8951f937e624f2fb583085b0d4f95796dab07805470a228574a46e8b97'
            '9d141a01d9c407886a496e64a0a78dbceb9a019b883b1a35bf0b3d1fdcd1b10d')

pkgver() {
  cd Genesis-Plus-GX
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd Genesis-Plus-GX
  patch -Np1 -i "${srcdir}/0001-Makefile-libretro-drop-Wl-version-script-for-PE-COFF.patch"
}

build() {
  cd Genesis-Plus-GX
  make -f Makefile.libretro platform=win
}

package() {
  install -Dm755 "Genesis-Plus-GX/${_corename}_libretro.dll" \
    "${pkgdir}${MINGW_PREFIX}/lib/libretro/${_corename}_libretro.dll"
  install -Dm644 Genesis-Plus-GX/LICENSE.txt \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
