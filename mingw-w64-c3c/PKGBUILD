# Maintainer: Maksim Bondarenkov <maksapple2306@gmail.com>

_realname=c3c
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=0.7.10
pkgrel=2
pkgdesc="Compiler for the C3 language (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://c3-lang.org'
msys2_repository_url='https://github.com/c3lang/c3c'
license=('spdx:LGPL-3.0-or-later OR MIT')
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs"
         "${MINGW_PACKAGE_PREFIX}-llvm-libs"
         "${MINGW_PACKAGE_PREFIX}-zlib"
         "${MINGW_PACKAGE_PREFIX}-zstd")
makedepends=("${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-ninja"
             "${MINGW_PACKAGE_PREFIX}-clang"
             "${MINGW_PACKAGE_PREFIX}-llvm"
             "${MINGW_PACKAGE_PREFIX}-lld"
             "git")
source=("git+${msys2_repository_url}.git#tag=v${pkgver}"
        "001-fix-llvm-definitions.patch"
        "install-man.patch")
sha256sums=('57c290de622d75fec8748e78380737d4052119d717a63326530596d3aa12f828'
            '812021ec899900b0d59378a8d678a03c1c48d42367544c4d5876a5faad81dcce'
            'c800461ae8d1c6be4bb76018a7aee93b5d980664959195ba85c1195686fa5f4d')

prepare() {
  git -C c3c apply ../001-fix-llvm-definitions.patch
  git -C c3c apply ../install-man.patch

  sed -i "s|22|23|g" c3c/CMakeLists.txt
  sed -i "s|libLLVM.a|libLLVM-22|g" c3c/CMakeLists.txt
  sed -i "s|\.so||g" c3c/CMakeLists.txt
  sed -i "s|-Werror||g" c3c/CMakeLists.txt
}

build() {
  declare -a extra_config
  if check_option "debug" "n"; then
    extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  CC=clang \
  CXX=clang++ \
  CXXFLAGS+=" -fuse-ld=lld" \
  LDFLAGS+=" -lzstd -lz" \
  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    cmake \
      -GNinja \
      -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
      -DC3_LINK_DYNAMIC=ON \
      "${extra_config[@]}" \
      -S "${_realname}" \
      -B "build-${MSYSTEM}"

  cmake --build "build-${MSYSTEM}"
}

check() {
  cmake --build "build-${MSYSTEM}" --target test
}

package() {
  DESTDIR="${pkgdir}" cmake --install "build-${MSYSTEM}"

  install -Dm644 "${_realname}"/LICENSE{,_SRC} -t "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/"
}
