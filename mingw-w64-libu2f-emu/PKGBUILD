# Maintainer: Stefan Weil <sw@weilnetz.de>

_realname=libu2f-emu
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=0.0.0.r148.gd1c4b9c
pkgrel=1
pkgdesc="Universal 2nd Factor (U2F) Emulation C Library (mingw-w64)"
arch=('any')
# clang compilers need upstream fixes, and mingw32 also fails.
mingw_arch=('mingw64' 'ucrt64')
url='https://github.com/Agnoctopus/libu2f-emu'
msys2_repository_url="${url}"
license=('spdx:GPL-2.0-or-later')
depends=("${MINGW_PACKAGE_PREFIX}-openssl"
         "${MINGW_PACKAGE_PREFIX}-libcbor")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-autotools"
             "${MINGW_PACKAGE_PREFIX}-pkgconf"
             "autoconf-archive"
             "git")
_commit="d1c4b9c2e1c42e8931033912c8b609521f2a7756"
source=("${_realname}::git+${url}.git#commit=${_commit}")
sha256sums=('25d0527096d33c349d11b29f0f2936b2908daea2fb65249bab2ea63ef91d9de1')

pkgver() {
  cd "${_realname}"
  printf "0.0.0.r%s.g%s" "$(git rev-list --count "${_commit}")" "$(git rev-parse --short "${_commit}")"
}

prepare() {
  cd "${_realname}"
  ./autogen.sh
}

build() {
  mkdir -p "${srcdir}/build-${MSYSTEM}" && cd "${srcdir}/build-${MSYSTEM}"

  ../"${_realname}"/configure \
    --host="${MINGW_CHOST}" \
    --prefix="${MINGW_PREFIX}" \
    --enable-shared \
    --enable-static \
    --disable-Werror \
    --enable-compile-warnings=yes

  make MY_WARN_CFLAGS=-Wall
}

check() {
  cd "build-${MSYSTEM}"
  make check || true
}

package() {
  cd "build-${MSYSTEM}"
  make DESTDIR="${pkgdir}" install
  install -Dm644 "${srcdir}/${_realname}/LICENSE" \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
