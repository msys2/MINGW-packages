# Maintainer: Stefan Weil <sw@weilnetz.de>

_realname=libu2f-emu
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=0.0.0.r148.gd1c4b9c
pkgrel=1
pkgdesc="Universal 2nd Factor (U2F) Emulation C Library (mingw-w64)"
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url='https://github.com/Agnoctopus/libu2f-emu'
msys2_repository_url="${url}"
license=('spdx:GPL-2.0-or-later')
depends=("${MINGW_PACKAGE_PREFIX}-openssl")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-pkgconf"
             "${MINGW_PACKAGE_PREFIX}-meson"
             "${MINGW_PACKAGE_PREFIX}-ninja"
             "${MINGW_PACKAGE_PREFIX}-gtest"
             "${MINGW_PACKAGE_PREFIX}-doxygen"
             "${MINGW_PACKAGE_PREFIX}-graphviz"
             "git")
_commit="d1c4b9c2e1c42e8931033912c8b609521f2a7756"
source=("${_realname}::git+${url}.git#commit=${_commit}"
        "0001-disable-gtest.patch"
        "0002-no-version-script.patch")
sha256sums=('25d0527096d33c349d11b29f0f2936b2908daea2fb65249bab2ea63ef91d9de1'
            '0f2d148d0278ce4eff073ad881e51e34b47e0996f6e3fc59bb67a512b9eb41af'
            'e6f841f553d44fbfb5304e6d491e3a5e903e6d2304a5c08bab4e58e459b16bfb')

pkgver() {
  cd "${_realname}"
  printf "0.0.0.r%s.g%s" "$(git rev-list --count "${_commit}")" "$(git rev-parse --short "${_commit}")"
}

prepare() {
  cd "${_realname}"

  patch -p1 -i "${srcdir}/0001-disable-gtest.patch"
  patch -p1 -i "${srcdir}/0002-no-version-script.patch"
}

build() {
  MSYS2_ARG_CONV_EXCL="--prefix=" \
    meson setup \
      --prefix="${MINGW_PREFIX}" \
      --wrap-mode=nodownload \
      --auto-features=enabled \
      --buildtype=plain \
      -Dwerror=false \
      "build-${MSYSTEM}" \
      "${_realname}"

  meson compile -C "build-${MSYSTEM}"
}

check() {
  meson test -C "build-${MSYSTEM}"
}

package() {
  meson install -C "build-${MSYSTEM}" --destdir "${pkgdir}"

  install -Dm644 "${srcdir}/${_realname}/LICENSE" \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
