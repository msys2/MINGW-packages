# Maintainer: Christoph Reiter <reiter.christoph@gmail.com>

_realname=zizmor
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=1.25.0
pkgrel=1
pkgdesc="A static analysis tool for GitHub Actions (mingw-w64)"
url='https://github.com/zizmorcore/zizmor'
msys2_repository_url='https://github.com/zizmorcore/zizmor'
msys2_changelog_url='https://docs.zizmor.sh/release-notes/'
msys2_references=(
  'anitya: 378497'
  'archlinux: zizmor'
  'purl: pkg:cargo/zizmor'
)
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
license=('spdx:MIT')
makedepends=("${MINGW_PACKAGE_PREFIX}-rust")
source=("https://github.com/zizmorcore/${_realname}/archive/v${pkgver}/${_realname}-${pkgver}.tar.gz"
        "aws-lc-sys.tar.gz::https://crates.io/api/v1/crates/aws-lc-sys/0.36.0/download"
        "aws-lc-sys-clang-fix.patch")
sha256sums=('d4eb078dca55b8a2e289a9a111639c73a2b2b725d879f5ba8c809038c3f254bd'
            '43a442ece363113bd4bd4c8b18977a7798dd4d3c3383f34fb61936960e8f4ad8'
            '07cb2edffb4222b3a04e904b29f22b18946e953af39167c263754adb8ae1c910')

prepare() {
  cd "${_realname}-${pkgver}"


  patch -d ../aws-lc-sys-0.36.0 -p1 -i ../aws-lc-sys-clang-fix.patch
  cat >> Cargo.toml <<END
[patch.crates-io]
aws-lc-sys.path = "../aws-lc-sys-0.36.0"
END
  cargo update -p aws-lc-sys

  cargo fetch --locked --target "${RUST_CHOST}"
}

build() {
  cd "${_realname}-${pkgver}"

  cargo build --frozen --release -p zizmor
}

check() {
  cd "${_realname}-${pkgver}"

  cargo test --frozen --release -p zizmor
}

package() {
  cd "${_realname}-${pkgver}"

  install -Dm755 -t "${pkgdir}${MINGW_PREFIX}/bin" target/release/zizmor.exe

  local _complete="target/release/zizmor --completions"
  install -Dm644 <($_complete bash) "${pkgdir}${MINGW_PREFIX}/share/bash-completion/completions/${_realname}"
  install -Dm644 <($_complete fish) "${pkgdir}${MINGW_PREFIX}/share/fish/vendor_completions.d/${_realname}.fish"
  install -Dm644 <($_complete zsh) "${pkgdir}${MINGW_PREFIX}/share/zsh/site-functions/_${_realname}"
  install -Dm644 LICENSE -t "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}"
}
