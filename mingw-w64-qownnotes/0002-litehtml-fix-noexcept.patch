The noexcept compat shim in os_types.h uses `#if _MSC_VER < 1900`.
When building with clang on Windows, _MSC_VER is undefined and evaluates
to 0, which is < 1900, so `noexcept` gets blanked out globally, breaking
all of libc++. Guard it with `defined(_MSC_VER)` so it only fires for
actual old MSVC.
diff --git a/libraries/qlitehtml/src/3rdparty/litehtml/include/litehtml/os_types.h b/libraries/qlitehtml/src/3rdparty/litehtml/include/litehtml/os_types.h
index 1111111..2222222 100644
--- a/libraries/qlitehtml/src/3rdparty/litehtml/include/litehtml/os_types.h
+++ b/libraries/qlitehtml/src/3rdparty/litehtml/include/litehtml/os_types.h
@@ -8,7 +8,7 @@ namespace litehtml {
 #if defined(WIN32) || defined(_WIN32) || defined(WINCE)
 
 // noexcept appeared since Visual Studio 2013
-#if _MSC_VER < 1900
+#if defined(_MSC_VER) && _MSC_VER < 1900
 #define noexcept
 #endif
 
