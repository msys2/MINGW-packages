# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Class-Load
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=0.25
pkgrel=1
pkgdesc="A working (require 'Class::Name') and more. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Class-Load"
msys2_repository_url="https://github.com/moose/Class-Load"
msys2_references=(
  'purl: pkg:cpan/ETHER/Class-Load'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-data-optlist"
         "${MINGW_PACKAGE_PREFIX}-perl-module-implementation"
         "${MINGW_PACKAGE_PREFIX}-perl-module-runtime"
         "${MINGW_PACKAGE_PREFIX}-perl-namespace-clean"
         "${MINGW_PACKAGE_PREFIX}-perl-package-stash"
         "${MINGW_PACKAGE_PREFIX}-perl-test-fatal"
         "${MINGW_PACKAGE_PREFIX}-perl-try-tiny")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/E/ET/ETHER/${_perlname}-${pkgver}.tar.gz")
sha256sums=('2a48fa779b5297e56156380e8b32637c6c58decb4f4a7f3c7350523e11275f8f')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" install
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
