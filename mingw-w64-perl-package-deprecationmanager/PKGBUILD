# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Package-DeprecationManager
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=0.18
pkgrel=1
pkgdesc="Manage deprecation warnings for your distribution. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Package-DeprecationManager"
msys2_repository_url="https://github.com/moose/Package-DeprecationManager"
msys2_references=(
  'purl: pkg:cpan/DROLSKY/Package-DeprecationManager'
)
license=('spdx:Artistic-2.0')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-module-implementation"
         "${MINGW_PACKAGE_PREFIX}-perl-namespace-autoclean"
         "${MINGW_PACKAGE_PREFIX}-perl-package-stash"
         "${MINGW_PACKAGE_PREFIX}-perl-params-util"
         "${MINGW_PACKAGE_PREFIX}-perl-sub-install")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/D/DR/DROLSKY/${_perlname}-${pkgver}.tar.gz")
sha256sums=('b68d3f0ced55b7615fddbb6029b89f92a34fe0dd8c6fd6bceffc157d56834fe8')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" install
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
