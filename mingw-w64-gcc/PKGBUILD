package_libstdc++() {
  pkgdesc="C++ runtime libraries shipped by GCC (mingw-w64)"
  depends=("${MINGW_PACKAGE_PREFIX}-libgcc=${pkgver}-${pkgrel}"
           "${MINGW_PACKAGE_PREFIX}-libwinpthread")
  conflicts=("${MINGW_PACKAGE_PREFIX}-gcc-libs<=15.2.0-13")
  groups=("${MINGW_PACKAGE_PREFIX}-toolchain")
  license=(spdx:GPL-3.0-or-later WITH GCC-exception-3.1)

  cd "${srcdir}"/build-${MSYSTEM}

  make -C $CHOST/libstdc++-v3/src DESTDIR="${pkgdir}" install-toolexeclibLTLIBRARIES
  make -C $CHOST/libstdc++-v3/src/experimental DESTDIR="${pkgdir}" install-toolexeclibLTLIBRARIES
  make -C $CHOST/libstdc++-v3/src/filesystem DESTDIR="${pkgdir}" install-toolexeclibLTLIBRARIES
  make -C $CHOST/libstdc++-v3/po DESTDIR="${pkgdir}" install

  install -Dm644 "${srcdir}"/${_sourcedir}/COPYING3        "${pkgdir}"${MINGW_PREFIX}/share/licenses/libstdc++/COPYING3
  install -Dm644 "${srcdir}"/${_sourcedir}/COPYING.RUNTIME "${pkgdir}"${MINGW_PREFIX}/share/licenses/libstdc++/COPYING.RUNTIME
}

# template start; name=mingw-w64-splitpkg-wrappers; version=1.0;
# vim: set ft=bash :

# generate wrappers
for _name in "${pkgname[@]}"; do
  _short="package_${_name#${MINGW_PACKAGE_PREFIX}-}"
  _func="$(declare -f "${_short}")"
  eval "${_func/#${_short}/package_${_name}}"
done
# template end;
