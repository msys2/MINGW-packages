# Contributor: dragon-archer <dragon-archer@outlook.com>

_realname=ast-serialize
pkgbase=mingw-w64-python-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-python-${_realname}")
pkgver=0.5.0
pkgrel=1
pkgdesc='Fast Python parser that generates a serialized AST (mingw-w64)'
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://github.com/mypyc/ast_serialize'
msys2_repository_url='https://github.com/mypyc/ast_serialize'
msys2_references=(
  'archlinux: python-ast-serialize'
  'gentoo: dev-python/ast-serialize'
  'purl: pkg:pypi/ast-serialize'
)
license=('spdx:MIT')
depends=("${MINGW_PACKAGE_PREFIX}-python")
makedepends=(
  "${MINGW_PACKAGE_PREFIX}-python-build"
  "${MINGW_PACKAGE_PREFIX}-python-installer"
  "${MINGW_PACKAGE_PREFIX}-python-maturin"
  "${MINGW_PACKAGE_PREFIX}-rust"
)
options=('!strip')
source=("https://pypi.org/packages/source/${_realname::1}/${_realname/-/_}/${_realname/-/_}-${pkgver}.tar.gz")
sha256sums=('5880091bfe6f4f986f22866375c2e884843e7a0b6343ae41aeea659613d879b6')

prepare() {
  cd "${_realname/-/_}-${pkgver}"

  cargo fetch --locked --target ${RUST_CHOST} --config='net.git-fetch-with-cli=true'
}

build() {
  cp -r ${_realname/-/_}-${pkgver} python-build-${MSYSTEM} && cd python-build-${MSYSTEM}

  export _PYTHON_HOST_PLATFORM=$(python -c 'import sysconfig, sys; sys.stdout.write(sysconfig.get_platform())')
  python -m build --wheel --skip-dependency-check --no-isolation
}

check() {
  cd "${_realname/-/_}-${pkgver}"

  cargo test --release --frozen --all-features
}

package() {
  cd python-build-${MSYSTEM}

  MSYS2_ARG_CONV_EXCL="--prefix=" \
    python -m installer --prefix=${MINGW_PREFIX} --destdir="${pkgdir}" dist/*.whl

  install -Dm644 "${srcdir}"/${_realname/-/_}-${pkgver}/LICENSE \
    "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE
}
