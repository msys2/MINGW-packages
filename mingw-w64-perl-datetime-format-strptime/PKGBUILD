# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=DateTime-Format-Strptime
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=1.80
pkgrel=1
pkgdesc="	Parse and format strp and strf time patterns. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/DateTime-Format-Strptime"
msys2_repository_url="https://github.com/houseabsolute/DateTime-Format-Strptime"
msys2_references=(
  'purl: pkg:cpan/DROLSKY/DateTime-Format-Strptime'
)
license=('spdx:Artistic-2.0')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-datetime"
         "${MINGW_PACKAGE_PREFIX}-perl-datetime-locale"
         "${MINGW_PACKAGE_PREFIX}-perl-datetime-timezone"
         "${MINGW_PACKAGE_PREFIX}-perl-package-deprecationmanager"
         "${MINGW_PACKAGE_PREFIX}-perl-params-validate")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/D/DR/DROLSKY/${_perlname}-${pkgver}.tar.gz")
sha256sums=('efe5e2be70425efc123a4e57f4b96b2d23beb03200c8326495b5b433b6b77158')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" install
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
