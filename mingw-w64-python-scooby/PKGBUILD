# Maintainer: Martin Diehl <aur@martin-diehl.net>
# Maintainer (msys2): Rafal Brzegowy <rafal.brzegowy@yahoo.com>

_realname=scooby
pkgbase=mingw-w64-python-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-python-${_realname}")
pkgver=0.11.1
pkgrel=1
pkgdesc='A Great Dane turned Python environment detective (mingw-w64)'
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64')
url='https://github.com/banesullivan/scooby'
msys2_repository_url='https://github.com/banesullivan/scooby'
msys2_references=(
  'aur: python-scooby'
)
license=('spdx:MIT')
depends=("${MINGW_PACKAGE_PREFIX}-python")	
makedepends=("${MINGW_PACKAGE_PREFIX}-python-pkgconfig"
             "${MINGW_PACKAGE_PREFIX}-python-build"
             "${MINGW_PACKAGE_PREFIX}-python-installer"
             "${MINGW_PACKAGE_PREFIX}-python-setuptools")
source=(https://github.com/banesullivan/${_realname}/archive/v${pkgver}/${_realname}-${pkgver}.tar.gz)
sha256sums=('c3631cbd29de013709e1c195a1c77d43f34b6276d1366d901b9bb36356c15f53')

build() {
  cp -r "${_realname}-${pkgver}" "python-build-${MSYSTEM}" && cd "python-build-${MSYSTEM}"

  ${MINGW_PREFIX}/bin/python -m build --wheel --skip-dependency-check --no-isolation
}

package() {
  cd "${srcdir}/python-build-${MSYSTEM}"

  MSYS2_ARG_CONV_EXCL="--prefix=" \
    ${MINGW_PREFIX}/bin/python -m installer --prefix=${MINGW_PREFIX} \
    --destdir="${pkgdir}" dist/*.whl
}
