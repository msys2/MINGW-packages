# Contributor: Kreijstal <kreijstal@hotmail.com>

_realname=libretro-nestopia
_corename=nestopia
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=r1.b0fd87d
pkgrel=1
pkgdesc='Nintendo Entertainment System libretro core (Nestopia UE) (mingw-w64)'
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://www.libretro.com/'
msys2_repository_url='https://github.com/libretro/nestopia'
license=('spdx:GPL-2.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-libretro")
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "git" "make")
optdepends=("${MINGW_PACKAGE_PREFIX}-retroarch: frontend that loads this core"
            "${MINGW_PACKAGE_PREFIX}-libretro-core-info: required for the core to show up in the menu")
_commit=b0fd87dd07e3c52903435d302b04e5e97796f127
source=("nestopia::git+https://github.com/libretro/nestopia.git#commit=${_commit}"
        "0001-libretro-Makefile-drop-Wl-version-script-for-PE-COFF.patch")
sha256sums=('63f205f46735380fc3093a9e519a82e46d85fad38b18ff99fcab8da6dc93c74e'
            '1a9ac46e87c8fd1f24b4016a1f178bf8721ac409fe7b2526e53700fe0a616743')

pkgver() {
  cd nestopia
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd nestopia
  patch -Np1 -i "${srcdir}/0001-libretro-Makefile-drop-Wl-version-script-for-PE-COFF.patch"
}

build() {
  cd nestopia/libretro
  make platform=win
}

package() {
  install -Dm755 "nestopia/libretro/${_corename}_libretro.dll" \
    "${pkgdir}${MINGW_PREFIX}/lib/libretro/${_corename}_libretro.dll"
  install -Dm644 nestopia/COPYING \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
