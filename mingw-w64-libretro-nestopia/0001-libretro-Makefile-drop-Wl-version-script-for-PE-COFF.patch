From: Kreijstal <kreijstal@hotmail.com>
Subject: libretro Makefile: drop -Wl,--version-script for PE/COFF

-Wl,--version-script=link.T is an ELF-only feature; binutils silently
ignores it on PE/COFF, but lld (used by CLANG{64,ARM64}) errors out.
Symbol export on Windows DLLs is governed by __declspec, so the flag
is meaningless here regardless of the linker.

diff --git a/libretro/Makefile b/libretro/Makefile
index a8ddae3..e915a3a 100644
--- a/libretro/Makefile
+++ b/libretro/Makefile
@@ -63,7 +63,7 @@ unixcygpath = /$(subst :,,$(call unixpath,$1))
 ifeq ($(platform), unix)
 	TARGET := $(TARGET_NAME)_libretro.so
 	fpic := -fPIC
-	SHARED := -shared -Wl,-version-script=link.T -Wl,-no-undefined
+	SHARED := -shared  -Wl,-no-undefined
 ifeq ($(shell uname -s), Haiku)
 	LDFLAGS += -lroot
 endif
@@ -159,7 +159,7 @@ else ifeq ($(platform), theos_ios)
 else ifeq ($(platform), qnx)
 	TARGET := $(TARGET_NAME)_libretro_qnx.so
 	fpic := -fPIC
-	SHARED := -lcpp -lm -shared -Wl,-version-script=link.T -Wl,-no-undefined
+	SHARED := -lcpp -lm -shared  -Wl,-no-undefined
 	HAS_GCC := 0
 	CC = qcc -Vgcc_ntoarmv7le
 	CXX = QCC -Vgcc_ntoarmv7le_cpp
@@ -200,7 +200,7 @@ else ifeq ($(platform), ctr)
 else ifeq ($(platform), rpi1)
 	TARGET := $(TARGET_NAME)_libretro.so
 	fpic := -fPIC
-	SHARED := -shared -Wl,-version-script=link.T -Wl,-no-undefined
+	SHARED := -shared  -Wl,-no-undefined
 	PLATFORM_DEFINES += -marm -mcpu=arm1176jzf-s -mfpu=vfp -mfloat-abi=hard -ffast-math
 	PLATFORM_DEFINES += -DARM11
 
@@ -208,7 +208,7 @@ else ifeq ($(platform), rpi1)
 else ifeq ($(platform), rpi2)
 	TARGET := $(TARGET_NAME)_libretro.so
 	fpic := -fPIC
-	SHARED := -shared -Wl,-version-script=link.T -Wl,-no-undefined
+	SHARED := -shared  -Wl,-no-undefined
 	PLATFORM_DEFINES += -marm -mcpu=cortex-a7 -mfpu=neon-vfpv4 -mfloat-abi=hard -ffast-math
 	PLATFORM_DEFINES += -DARM
 
@@ -216,7 +216,7 @@ else ifeq ($(platform), rpi2)
 else ifeq ($(platform), rpi3)
 	TARGET := $(TARGET_NAME)_libretro.so
 	fpic := -fPIC
-	SHARED := -shared -Wl,-version-script=link.T -Wl,-no-undefined
+	SHARED := -shared  -Wl,-no-undefined
 	PLATFORM_DEFINES += -marm -mcpu=cortex-a53 -mfpu=neon-fp-armv8 -mfloat-abi=hard -ffast-math
 	PLATFORM_DEFINES += -DARM
 
@@ -224,14 +224,14 @@ else ifeq ($(platform), rpi3)
 else ifeq ($(platform), rpi3_64)
 	TARGET := $(TARGET_NAME)_libretro.so
 	fpic := -fPIC
-	SHARED := -shared -Wl,-version-script=link.T -Wl,-no-undefined
+	SHARED := -shared  -Wl,-no-undefined
 	PLATFORM_DEFINES += -mcpu=cortex-a53 -mtune=cortex-a53 -ffast-math
 
 # Raspberry Pi 4 (64-bit)
 else ifeq ($(platform), rpi4_64)
 	TARGET := $(TARGET_NAME)_libretro.so
 	fpic := -fPIC
-	SHARED := -shared -Wl,-version-script=link.T -Wl,-no-undefined
+	SHARED := -shared  -Wl,-no-undefined
 	PLATFORM_DEFINES += -mcpu=cortex-a72 -mtune=cortex-a72 -ffast-math
 
 # Lightweight PS3 Homebrew SDK
@@ -417,7 +417,7 @@ else ifeq ($(platform), gcw0)
 	fpic := -fPIC
 	PLATFORM_DEFINES += -ffast-math -march=mips32 -mtune=mips32r2 -mhard-float
 	PLATFORM_DEFINES += -fomit-frame-pointer
-	SHARED := -shared -Wl,-version-script=link.T -Wl,-no-undefined
+	SHARED := -shared  -Wl,-no-undefined
 	CXXFLAGS += -fno-rtti -std=gnu++11
 	CFLAGS += -std=gnu11
 
@@ -471,7 +471,7 @@ else ifeq ($(platform), libnx)
 else ifeq ($(platform), classic_armv7_a7)
 	TARGET := $(TARGET_NAME)_libretro.so
 	fpic := -fPIC
-	SHARED := -shared -Wl,--version-script=link.T -Wl,-no-undefined
+	SHARED := -shared  -Wl,-no-undefined
 	CFLAGS += -Ofast \
 	-flto=4 -fwhole-program -fuse-linker-plugin \
 	-fdata-sections -ffunction-sections -Wl,--gc-sections \
@@ -503,7 +503,7 @@ else ifeq ($(platform), classic_armv7_a7)
 else ifeq ($(platform), classic_armv8_a35)
 	TARGET := $(TARGET_NAME)_libretro.so
 	fpic := -fPIC
-	SHARED := -shared -Wl,-version-script=link.T -Wl,-no-undefined
+	SHARED := -shared  -Wl,-no-undefined
 	CFLAGS += -Ofast \
 	-fuse-linker-plugin \
 	-fno-stack-protector -fno-ident -fomit-frame-pointer \
@@ -523,7 +523,7 @@ else ifeq ($(platform), classic_armv8_a35)
 else ifneq (,$(findstring armv,$(platform)))
 	TARGET := $(TARGET_NAME)_libretro.so
 	fpic := -fPIC
-	SHARED := -shared -Wl,-version-script=link.T -Wl,-no-undefined
+	SHARED := -shared  -Wl,-no-undefined
 	ifneq (,$(findstring cortexa5,$(platform)))
 		PLATFORM_DEFINES += -marm -mcpu=cortex-a5
 	else ifneq (,$(findstring cortexa8,$(platform)))
@@ -713,7 +713,7 @@ else
 	TARGET := $(TARGET_NAME)_libretro.dll
 	CC ?= gcc
 	CXX ?= g++
-	SHARED := -shared -static-libgcc -static-libstdc++ -Wl,-no-undefined -Wl,-version-script=link.T
+	SHARED := -shared -static-libgcc -static-libstdc++ -Wl,-no-undefined 
 
 endif
 
