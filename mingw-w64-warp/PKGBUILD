# Maintainer: Maksim Bondarenkov <maksapple2306@gmail.com>

_realname=warp
pkgbase=mingw-w64-${_realname}-terminal
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}-terminal"
pkgver=0.2026.04.29.08.56.stable_00
pkgrel=1
pkgdesc="Agentic development environment, born out of the terminal (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://github.com/warpdotdev/warp'
license=('spdx:AGPL-3.0-or-later AND MIT')
makedepends=("${MINGW_PACKAGE_PREFIX}-rust"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-jq")
source=("${url}/archive/v${pkgver}/${_realname}-${pkgver}.tar.gz")
sha256sums=('5d901b88596f4f0136d4b0b2822126eb444010e222989fd758ef0d58fa50cce5')

prepare() {
  cd "${_realname}-${pkgver}"

  rm rust-toolchain.toml
  cargo fetch --locked --target "${RUST_CHOST}"
}

build() {
  cd "${_realname}-${pkgver}"

  cargo build --frozen --profile release-lto --bin warp-oss
}

check() {
  cd "${_realname}-${pkgver}"

  cargo test --frozen --profile release-lto
}

package() {
  cd "${_realname}-${pkgver}"

  install -Dm755 target/release-lto/warp-oss "${pkgdir}${MINGW_PREFIX}/bin/warp-oss"

  install -Dm644 LICENSE-{AGPL,MIT} -t "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/"
}
