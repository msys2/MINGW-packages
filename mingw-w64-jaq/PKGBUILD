

_realname=jaq
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=3.1.0
pkgrel=1
pkgdesc="A jq clone (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://github.com/01mf02/jaq"
msys2_repository_url="${url}"
msys2_references=(
  'archlinux: jaq'
)
license=('spdx:MIT')
makedepends=("${MINGW_PACKAGE_PREFIX}-rust")
conflicts=("${MINGW_PACKAGE_PREFIX}-jq")
provides=("${MINGW_PACKAGE_PREFIX}-jq")
source=("${url}/archive/refs/tags/v${pkgver}.tar.gz"
        "${url}/releases/download/v${pkgver}/jaq.1")
sha256sums=('8ad074d7e90e07ad7e77048dcf0d0e7ad434b8e3e38044260b9457d4551e644d'
            'f7b1a9447fd7681befe793a5c65e7acbbd08a7eb9d5f4ad61945270d41baf0c9')

prepare() {
  cd "${srcdir}"/${_realname}-${pkgver}
  cargo fetch --locked --target "${RUST_CHOST}"
}

build() {
  cd "${_realname}-$pkgver"
  cargo build --frozen --release
}

package() {
  cd "${_realname}-$pkgver"
  install -Dm755 "target/release/jaq" "${pkgdir}${MINGW_PREFIX}/bin/jaq"
  install -Dm644 ../jaq.1 -t "${pkgdir}${MINGW_PREFIX}/share/man/man1"
  install -Dm644 LICENSE-MIT "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
  cd "${pkgdir}${MINGW_PREFIX}/bin"
  ln jaq jq
}
