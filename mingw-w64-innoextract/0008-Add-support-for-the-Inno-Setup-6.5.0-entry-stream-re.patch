+
+namespace setup {
+
+void issig_key_entry::load(std::istream & is, const info & /* i */) {
+	
+	// TSetupISSigKeyEntry: PublicX, PublicY, RuntimeID
+	// (Projects/Src/Shared.Struct.pas at tag is-6_5_0 in
+	// https://github.com/jrsoftware/issrc).
+	is >> util::binary_string(public_x);
+	is >> util::binary_string(public_y);
+	is >> util::binary_string(runtime_id);
+	
+}
