        "0009-data-widen-the-per-file-location-start-offset-to-64-.patch"
        "0010-Add-support-for-the-Inno-Setup-6.6.0-entry-stream-re.patch"
        "0011-Add-support-for-Inno-Setup-6.7.0-and-6.7.1.patch")
