--- VTK-9.5.2/Common/Core/vtkLongLongArray.cxx.orig	2025-09-17 22:02:27.000000000 +0200
+++ VTK-9.5.2/Common/Core/vtkLongLongArray.cxx	2026-05-09 00:03:33.948897000 +0200
@@ -3,6 +3,19 @@
 // Instantiate superclass first to give the template a DLL interface.
 #define VTK_AOS_DATA_ARRAY_TEMPLATE_INSTANTIATING
 #include "vtkAOSDataArrayTemplate.txx"
+
+VTK_ABI_NAMESPACE_BEGIN
+template <>
+VTKCOMMONCORE_EXPORT vtkTypeBool vtkAOSDataArrayTemplate<long long>::IsTypeOf(const char* type)
+{
+  if (!strcmp(typeid(vtkAOSDataArrayTemplate<long long>).name(), type))
+  {
+    return 1;
+  }
+  return vtkGenericDataArray<vtkAOSDataArrayTemplate<long long>, long long>::IsTypeOf(type);
+}
+VTK_ABI_NAMESPACE_END
+
 VTK_AOS_DATA_ARRAY_TEMPLATE_INSTANTIATE(long long);
 
 #include "vtkLongLongArray.h"
