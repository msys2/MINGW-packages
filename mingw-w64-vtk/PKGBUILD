# Helper macros to help make tasks easier #
apply_patch_with_msg() {
  for _patch in "$@"
  do
    msg2 "Applying ${_patch}"
    patch -Nbp1 -i "${srcdir}/${_patch}"
  done
}

prepare() {
  cd "${srcdir}/${_realname}-${pkgver}"

  _fast_float_version=$(pacman -Q ${MINGW_PACKAGE_PREFIX}-fast_float | sed -e 's/.* //; s/-.*//g')
  sed -i "s|7.0.0|${_fast_float_version}|g" ThirdParty/fast_float/CMakeLists.txt

  apply_patch_with_msg \
    001-include-missing-header-on-windows.patch \
    002-fix-build-with-external-ioss.patch \
    003-fix-build-with-gdal-3.13.patch \
    004-accept-future-versions-of-boost-and-occ.patch \
    005-use-localtime_s-on-mingw.patch
  # Fix FindEXPAT.cmake
  apply_patch_with_msg \
    813783b0.patch \
    417ada87.patch \
    987fb480.patch

  # Succeeds with Clang but fails with GCC!
  if [[ ${CC} == gcc ]]; then
    apply_patch_with_msg \
      006-Fix-MinGW-GCC-extern-template-IsTypeOf-for-vtkAOSDataArrayTemplate.patch
  else
    apply_patch_with_msg \
      007-dll-export-some-functions.patch
  fi
}

build() {
  declare -a _extra_config
  if check_option "debug" "n"; then
    _extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    _extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  if [[ ${MSYSTEM} == MINGW64 ]]; then
    _extra_config+=("-DVTK_MODULE_ENABLE_VTK_RenderingAnari=NO"
                    "-DVTK_MODULE_USE_EXTERNAL_VTK_scn=OFF"
                    "-DVTK_MODULE_USE_EXTERNAL_VTK_verdict=OFF"
                    "-DVTK_MODULE_USE_EXTERNAL_VTK_vtkviskores=OFF")
  fi

  _tk_version=$(echo "puts \$tcl_version" | tclsh)
  CXXFLAGS+=" -isystem $(cygpath -m ${MINGW_PREFIX})/include/tk${_tk_version}/tk-private/win"
  CXXFLAGS+=" -isystem $(cygpath -m ${MINGW_PREFIX})/include/tk${_tk_version}/tk-private/generic"

  CXXFLAGS+=" -D_USE_MATH_DEFINES -w -Wa,-mbig-obj" \
  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
  ${MINGW_PREFIX}/bin/cmake \
    -Wno-dev \
    -G"Ninja" \
    -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
    -DCMAKE_INSTALL_LICENSEDIR=share/licenses/vtk \
    -DBUILD_SHARED_LIBS=ON \
    -DPython3_EXECUTABLE="${MINGW_PREFIX}/bin/python.exe" \
    -DVTK_BUILD_TESTING=OFF \
    -DVTK_VERSIONED_INSTALL=OFF \
    -DVTK_BUILD_ALL_MODULES=ON \
    -DVTK_GROUP_ENABLE_MPI=NO \
    -DVTK_GROUP_ENABLE_Web=NO \
    -DVTK_MODULE_ENABLE_VTK_FiltersONNX=NO \
    -DVTK_MODULE_ENABLE_VTK_FiltersParallelVerdict=WANT \
    -DVTK_MODULE_ENABLE_VTK_FiltersTemporal=WANT \
    -DVTK_MODULE_ENABLE_VTK_IOERF=WANT \
    -DVTK_MODULE_ENABLE_VTK_IOFDS=WANT \
    -DVTK_MODULE_ENABLE_VTK_IOUSD=NO \
    -DVTK_MODULE_ENABLE_VTK_RenderingOpenXRRemoting=NO \
    -DVTK_MODULE_ENABLE_VTK_RenderingZSpace=NO \
    -DVTK_USE_EXTERNAL=ON \
    -DVTK_USE_TK=ON \
    -DVTK_MODULE_USE_EXTERNAL_VTK_pegtl=OFF \
    -DVTK_MODULE_USE_EXTERNAL_VTK_token=OFF \
    -DVTK_WRAP_JAVA=OFF \
    -DVTK_WRAP_PYTHON=ON \
    -DVTK_SMP_IMPLEMENTATION_TYPE=TBB \
    -DVTK_SMP_ENABLE_SEQUENTIAL=ON \
    -DVTK_SMP_ENABLE_STDTHREAD=ON \
    -DVTK_SMP_ENABLE_OPENMP=ON \
    -DVTK_USE_VIDEO_FOR_WINDOWS=ON \
    -DVTK_ENABLE_OSPRAY=OFF \
    -DVTK_ENABLE_REMOTE_MODULES=OFF \
    -DHDF5_IS_PARALLEL=OFF \
    "${_extra_config[@]}" \
    -S ${_realname}-${pkgver} \
    -B build-${MSYSTEM}

  ${MINGW_PREFIX}/bin/cmake --build build-${MSYSTEM}
}

package() {
  DESTDIR="${pkgdir}" ${MINGW_PREFIX}/bin/cmake --install build-${MSYSTEM}

  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/Copyright.txt \
    "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE

  # Remove third party CMake patching for older versions than ours
  rm -rfv "${pkgdir}"${MINGW_PREFIX}/lib/cmake/vtk/patches/{3.{1{3,6,9},2{0,2,3}},4.3}
}
