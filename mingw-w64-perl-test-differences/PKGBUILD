# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Test-Differences
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=0.72
pkgrel=2
pkgdesc="Test strings and data structures and show differences if not ok. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Test-Differences"
msys2_repository_url="https://github.com/DrHyde/perl-modules-Test-Differences"
msys2_references=(
  'purl: pkg:cpan/DCANTRELL/Test-Differences'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-text-diff")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/D/DC/DCANTRELL/${_perlname}-${pkgver}.tar.gz")
sha256sums=('648844b9dcb7dae6f9b5a15c9359d0f09de247a624b65c4620ebff249558f913')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  mingw32-make DESTDIR="${pkgdir}/" install
}
