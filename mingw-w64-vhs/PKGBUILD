_realname=vhs
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=0.11.0
pkgrel=1
pkgdesc="A tool for recording terminal GIFs (mingw-w64)"
arch=(any)
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url="https://github.com/charmbracelet/vhs"
msys2_references=(
  'archlinux: vhs'
)
license=('MIT')
depends=("${MINGW_PACKAGE_PREFIX}-ffmpeg" "${MINGW_PACKAGE_PREFIX}-ttyd")
makedepends=('git' "${MINGW_PACKAGE_PREFIX}-go")
options=(!lto)
source=("${url}/archive/v${pkgver}/${_realname}-${pkgver}.tar.gz")
sha512sums=('287499e48eec16a5465ff9d20e0b76a04cccd2d5107d8ca4aab95d7d6a19a8ce95231dfd0f4a7a62a7b7da651577e43b505c29b75e83ca7b29921e2d266a736d')

prepare() {
  cd "${_realname}-${pkgver}"
  mkdir -p build
  export GOROOT=${MINGW_PREFIX}/lib/go
  export GOPATH="${srcdir}"
  go mod download
}

build() {
  cd "${_realname}-${pkgver}"

  # set Go flags
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export GOROOT=${MINGW_PREFIX}/lib/go
  export GOPATH="${srcdir}"

  go build \
    -trimpath \
    -buildmode=pie \
    -mod=readonly \
    -modcacherw \
    -ldflags "-linkmode external -extldflags \"${LDFLAGS}\" ${_BUILDINFO}" \
    -o dist/${_realname}.exe \
    .
}

package() {
  cd "${_realname}-${pkgver}"
  install -Dm 755 "dist/${_realname}.exe" -t "${pkgdir}/$MINGW_PREFIX/bin"
  install -Dm 644 LICENSE  -t "${pkgdir}/$MINGW_PREFIX/share/licenses/${_realname}"
  install -Dm 644 README.md -t "${pkgdir}/$MINGW_PREFIX/share/doc/${_realname}"
}
