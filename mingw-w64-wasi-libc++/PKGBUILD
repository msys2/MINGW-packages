# Maintainer: Maksim Bondarenkov <maksapple2306@gmail.com>

_realname=wasi-libc++
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=22.1.7
pkgrel=1
pkgdesc="LLVM C++ standard library (WASI) (mingw-w64)"
url="https://libcxx.llvm.org/"
license=('Apache-2.0 WITH LLVM-exception')
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
depends=("${MINGW_PACKAGE_PREFIX}-wasi-libc"
         "${MINGW_PACKAGE_PREFIX}-wasi-compiler-rt")
makedepends=("${MINGW_PACKAGE_PREFIX}-clang"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-ninja"
             "${MINGW_PACKAGE_PREFIX}-python"
             "${MINGW_PACKAGE_PREFIX}-llvm"
             "${MINGW_PACKAGE_PREFIX}-lld"
             "${MINGW_PACKAGE_PREFIX}-wasm-component-ld")
options=('!buildflags' '!strip')
source=("https://github.com/llvm/llvm-project/releases/download/llvmorg-${pkgver}/llvm-project-${pkgver}.src.tar.xz"{,.sig})
sha256sums=('5cc4a3f12bba50b6bdfb4b61bdc852117a0ff2517807c3902fc13267fb93562e'
            'SKIP')
validpgpkeys=('474E22316ABF4785A88C6E8EA2C794A986419D8A'  # Tom Stellard <tstellar@redhat.com>
              'D574BD5D1D0E98895E3BF90044F2485E45D59042'  # Tobias Hieta <tobias@hieta.se>
              'FFB3368980F3E6BB5737145A316C56D064CACBA5'  # Douglas Yung <douglas.yung@sony.com>
              '71046D1E9C6656BDD61171873E83BABF4A4F9E85'  # Cullen Rhodes <cullen.rhodes@arm.com>
)
noextract=("llvm-project-${pkgver}.src.tar.xz")

_targets=(wasm32-wasi wasm32-wasip1 wasm32-wasip2) # wasm32-wasip1-threads target is broken now

prepare() {
  plain "Extracting llvm-project-${pkgver}.src.tar.xz due to symlink(s) without pre-existing target(s)"
  bsdtar -xJf llvm-project-${pkgver}.src.tar.xz || true

  cd "llvm-project-${pkgver}.src/cmake"
  # Platform files have been copied from
  # https://github.com/WebAssembly/wasi-sdk/tree/main/cmake/Platform
  mkdir Platform
  echo 'set(WASI 1)' > Platform/WASI.cmake
}

build() {
  # Build options are derived from
  # https://github.com/WebAssembly/wasi-sdk/blob/main/cmake/wasi-sdk-sysroot.cmake

  local target extra_cflags
  for target in "${_targets[@]}"; do
    extra_cflags="-Wno-deprecated -fno-exceptions"

    if [[ ${target} = *threads* ]]; then
      extra_cflags+=" -lpthread"
    fi

    local cmake_options=(
      -S "llvm-project-${pkgver}.src/runtimes"
      -B "build-${MSYSTEM}-${target}"
      -G Ninja
      -DCMAKE_AR="${MINGW_PREFIX}/bin/llvm-ar.exe"
      -DCMAKE_ASM_COMPILER="${MINGW_PREFIX}/bin/clang.exe"
      -DCMAKE_BUILD_TYPE=Release
      -DCMAKE_CXX_COMPILER="${MINGW_PREFIX}/bin/clang++.exe"
      -DCMAKE_CXX_COMPILER_WORKS=ON
      -DCMAKE_CXX_FLAGS=-fno-exceptions
      -DCMAKE_CXX_LINKER_DEPFILE_SUPPORTED=OFF
      -DCMAKE_C_COMPILER="${MINGW_PREFIX}/bin/clang.exe"
      -DCMAKE_C_COMPILER_WORKS=ON
      -DCMAKE_C_FLAGS=-fno-exceptions
      -DCMAKE_C_LINKER_DEPFILE_SUPPORTED=OFF
      -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}/share/wasi-sysroot"
      -DCMAKE_RANLIB="${MINGW_PREFIX}/bin/llvm-ranlib.exe"
      -DCMAKE_SYSROOT="${MINGW_PREFIX}/share/wasi-sysroot"
      -DCMAKE_SYSTEM_NAME=WASI
      -DCMAKE_SYSTEM_PROCESSOR=wasm32
      -DCMAKE_SYSTEM_VERSION=1
      -DCMAKE_ASM_COMPILER_TARGET="${target}"
      -DCMAKE_CXX_COMPILER_TARGET="${target}"
      -DCMAKE_C_COMPILER_TARGET="${target}"
      -DCMAKE_INSTALL_INCLUDEDIR="${MINGW_PREFIX}/share/wasi-sysroot/include/${target}"
      -DCMAKE_STAGING_PREFIX="${MINGW_PREFIX}/share/wasi-sysroot"
      -DCMAKE_POSITION_INDEPENDENT_CODE=ON
      -DLIBCXX_ENABLE_THREADS=ON
      -DLIBCXX_HAS_PTHREAD_API=ON
      -DLIBCXX_HAS_EXTERNAL_THREAD_API=OFF
      -DLIBCXX_HAS_WIN32_THREAD_API=OFF
      -DLLVM_COMPILER_CHECKED=ON
      -DLIBCXX_ENABLE_EXCEPTIONS=OFF
      -DLIBCXX_ENABLE_FILESYSTEM=ON
      -DLIBCXX_ENABLE_ABI_LINKER_SCRIPT=OFF
      -DLIBCXX_CXX_ABI=libcxxabi
      -DLIBCXX_HAS_MUSL_LIBC=OFF
      -DLIBCXX_ABI_VERSION=2
      -DLIBCXXABI_ENABLE_EXCEPTIONS=OFF
      -DLIBCXXABI_ENABLE_SHARED=ON
      -DLIBCXXABI_SILENT_TERMINATE=ON
      -DLIBCXXABI_ENABLE_THREADS=ON
      -DLIBCXXABI_HAS_PTHREAD_API=ON
      -DLIBCXXABI_HAS_EXTERNAL_THREAD_API=OFF
      -DLIBCXXABI_HAS_WIN32_THREAD_API=OFF
      -DLIBCXXABI_USE_LLVM_UNWINDER=OFF
      -DCMAKE_C_FLAGS="${extra_cflags}"
      -DCMAKE_ASM_FLAGS="${extra_cflags}"
      -DCMAKE_CXX_FLAGS="${extra_cflags}"
      -DLIBCXX_LIBDIR_SUFFIX="/${target}"
      -DLIBCXXABI_LIBDIR_SUFFIX="/${target}"
      -DLIBCXX_INCLUDE_TESTS=OFF
      -DLIBCXX_INCLUDE_BENCHMARKS=OFF
      -DLLVM_ENABLE_RUNTIMES="libcxx;libcxxabi"
      -DUNIX=ON
    )

    MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=;-DCMAKE_INSTALL_INCLUDEDIR=;-DCMAKE_STAGING_PREFIX=;-DLIBCXX_LIBDIR_SUFFIX=;-DLIBCXXABI_LIBDIR_SUFFIX=" \
      cmake "${cmake_options[@]}"
    cmake --build "build-${MSYSTEM}-${target}"
  done
}

package() {
  mkdir -p "${pkgdir}${MINGW_PREFIX}/share/wasi-sysroot/include/c++/v1"

  local target
  for target in "${_targets[@]}"; do
    DESTDIR="${pkgdir}" cmake --install "build-${MSYSTEM}-${target}"
  done

  # reduce duplication
  hardlink -c "${pkgdir}${MINGW_PREFIX}/share/wasi-sysroot"

  install -Dm644 llvm-project-${pkgver}.src/libcxx/LICENSE.TXT "${pkgdir}${MINGW_PREFIX}"/share/licenses/${_realname}/LICENSE
}
