diff -ruN '--exclude=*.orig' '--exclude=build-*' onnxruntime-1.24.4-pristine/onnxruntime/core/mlas/lib/amd64/macamd64.inc onnxruntime-1.24.4/onnxruntime/core/mlas/lib/amd64/macamd64.inc
--- onnxruntime-1.24.4-pristine/onnxruntime/core/mlas/lib/amd64/macamd64.inc	1970-01-01 01:00:00.000000000 +0100
+++ onnxruntime-1.24.4/onnxruntime/core/mlas/lib/amd64/macamd64.inc	2026-04-28 20:53:05.462543500 +0200
@@ -0,0 +1,60 @@
+; macamd64.inc -- SEH frame macros for UASM (replaces Windows SDK header)
+push_reg MACRO reg
+    push    reg
+    .pushreg reg
+ENDM
+
+rex_push_reg MACRO reg
+    push    reg
+    .pushreg reg
+ENDM
+
+alloc_stack MACRO size
+    sub     rsp, size
+    .allocstack size
+ENDM
+
+save_reg MACRO reg, offset
+    mov     [rsp+offset], reg
+    .savereg reg, offset
+ENDM
+
+save_xmm128 MACRO reg, offset
+    movaps  [rsp+offset], reg
+    .savexmm128 reg, offset
+ENDM
+
+END_PROLOGUE MACRO
+    .endprolog
+ENDM
+
+BEGIN_EPILOGUE MACRO
+ENDM
+
+LEAF_ENTRY MACRO Name, Section
+    Section SEGMENT
+    ALIGN   16
+    PUBLIC  Name
+    Name PROC
+ENDM
+
+LEAF_END MACRO Name, Section
+    Name ENDP
+    Section ENDS
+ENDM
+
+NESTED_ENTRY MACRO Name, Section, Handler
+    Section SEGMENT
+    ALIGN   16
+    PUBLIC  Name
+    IF @SizeStr(<Handler>) GT 0
+        Name PROC FRAME:Handler
+    ELSE
+        Name PROC FRAME
+    ENDIF
+ENDM
+
+NESTED_END MACRO Name, Section
+    Name ENDP
+    Section ENDS
+ENDM
