# Maintainer: Johannes Schindelin <johannes.schindelin@gmx.de>

_realname=onnxruntime
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=1.24.4
pkgrel=1
pkgdesc="Cross-platform inference and training machine-learning accelerating engine (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64')
url='https://onnxruntime.ai'
msys2_repository_url="https://github.com/microsoft/onnxruntime"
msys2_references=(
  'purl: pkg:github/microsoft/onnxruntime'
)
license=('spdx:MIT')
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-ninja"
             "${MINGW_PACKAGE_PREFIX}-python"
             "${MINGW_PACKAGE_PREFIX}-nlohmann-json"
             "${MINGW_PACKAGE_PREFIX}-eigen3"
             "${MINGW_PACKAGE_PREFIX}-uasm")
source=("https://github.com/microsoft/onnxruntime/archive/refs/tags/v${pkgver}/${_realname}-${pkgver}.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd ${_realname}-${pkgver}

  # MinGW-w64 provides real SAL annotations via sal.h; the blanket
  # "not MSVC => stub them out" guard collides with those definitions
  # and triggers -Werror redefinition errors.
  sed -i 's/^#ifndef _MSC_VER$/#if !defined(_MSC_VER) \&\& !defined(__MINGW32__)/' \
    include/onnxruntime/core/session/onnxruntime_c_api.h

  # MinGW supports _aligned_malloc (from malloc.h) just like MSVC.
  # Without this, the non-MSVC C++ fallback uses posix_memalign which
  # does not exist on Windows.
  sed -i 's/^#ifdef _MSC_VER$/\#if defined(_MSC_VER) || defined(_WIN32)/' \
    onnxruntime/core/mlas/lib/mlasi.h

  # Several cmake files use if(WIN32) to guard MSVC-specific compiler
  # flags (/wd, /Zc:, /w1).  GCC interprets these as file paths, causing
  # fatal errors.  Narrow the guards to if(MSVC).
  sed -i '0,/^if (WIN32)/{s/^if (WIN32)/if (MSVC)/}' \
    cmake/CMakeLists.txt
  sed -i 's/^if(WIN32)$/if(MSVC)/' \
    cmake/onnxruntime_common.cmake

  # The platform-file selection at the top of onnxruntime_common.cmake uses
  # if(MSVC) to choose between windows/ and posix/ sources.  MinGW is on
  # Windows but not MSVC, so it needs the Windows platform files.
  # However, some Windows files (telemetry, ETW logging) require
  # TraceLoggingProvider.h from the Windows 10 SDK, which MinGW lacks.
  # Strategy: change if(MSVC) to if(WIN32) so MinGW enters the block,
  # then filter out SDK-specific files for non-MSVC compilers.
  sed -i '33s/^if(MSVC)$/if(WIN32)/' \
    cmake/onnxruntime_common.cmake
  # After the file(GLOB) expansion, remove MSVC-SDK-only files for MinGW.
  # telemetry needs TraceLoggingProvider.h, etw_sink needs full ETW.
  sed -i '/^file(GLOB onnxruntime_common_src CONFIGURE_DEPENDS/,/)/{
    /)/a\
if(WIN32 AND NOT MSVC)\
    list(FILTER onnxruntime_common_src EXCLUDE REGEX "windows/telemetry")\
    list(FILTER onnxruntime_common_src EXCLUDE REGEX "windows/logging/")\
endif()
  }' cmake/onnxruntime_common.cmake

  # device_discovery.cc needs dxcore.h / d3d12.h from the Windows SDK.
  # Only MSVC has these.
  sed -i 's/^if (WIN32)$/if (MSVC)/' \
    cmake/onnxruntime_common.cmake

  sed -i '0,/^if (WIN32)/{s/^if (WIN32)/if (MSVC)/}' \
    cmake/onnxruntime_mlas.cmake

  # MinGW's <winerror.h> only typedefs HRESULT when
  # INLINE_HRESULT_FROM_WIN32 is defined.  Include <windef.h>
  # to get the unconditional typedef.
  sed -i 's|^#include <winerror.h>$|#include <windef.h>\n#include <winerror.h>|' \
    include/onnxruntime/core/common/status.h

  # Decouple env.h from the Windows-SDK-only telemetry header.
  # Replace the WindowsTelemetry include and member with the base Telemetry
  # class when not building with MSVC.
  sed -i 's|^#include "core/platform/windows/telemetry.h"$|#ifdef _MSC_VER\n#include "core/platform/windows/telemetry.h"\n#else\n#include "core/platform/telemetry.h"\n#endif|' \
    onnxruntime/core/platform/windows/env.h
  sed -i 's/^  WindowsTelemetry telemetry_provider_;/#ifdef _MSC_VER\n  WindowsTelemetry telemetry_provider_;\n#else\n  Telemetry telemetry_provider_;\n#endif/' \
    onnxruntime/core/platform/windows/env.h

  # MSVC's i64 integer literal suffix does not exist in GCC.
  sed -i 's/116444736000000000i64/116444736000000000LL/' \
    onnxruntime/core/platform/windows/env_time.cc

  # Make tracing.h MinGW-safe: it includes <TraceLoggingProvider.h> which
  # MinGW lacks.  On MinGW, make it an empty header.
  cat > include/onnxruntime/core/platform/tracing.h << 'TRACING_H'
#pragma once
#ifdef _MSC_VER
#include <windows.h>
#include <TraceLoggingProvider.h>
TRACELOGGING_DECLARE_PROVIDER(telemetry_provider_handle);
#endif
TRACING_H

  # Make windows/telemetry.h MinGW-safe by providing a stub WindowsTelemetry
  # class when not building with MSVC.  The stub inherits from the base
  # Telemetry class (all virtual no-ops) and adds the EtwInternalCallback
  # typedef plus Register/Unregister stubs so that code referencing these
  # under #ifdef _WIN32 compiles but does nothing on MinGW.
  sed -i '/#pragma once/a\
#ifndef _MSC_VER\
#include "core/platform/telemetry.h"\
#include <functional>\
#include <Windows.h>\
#include <evntprov.h>\
static constexpr size_t TelemetrySampleCount = 10;\
namespace onnxruntime {\
class WindowsTelemetry : public Telemetry {\
public:\
  using EtwInternalCallback = std::function<void(LPCGUID, ULONG, UCHAR,\
      ULONGLONG, ULONGLONG, PEVENT_FILTER_DESCRIPTOR, PVOID)>;\
  static void RegisterInternalCallback(const EtwInternalCallback\&) {}\
  static void UnregisterInternalCallback(const EtwInternalCallback\&) {}\
};\
}\
#else' \
    onnxruntime/core/platform/windows/telemetry.h
  echo '#endif  // _MSC_VER' >> onnxruntime/core/platform/windows/telemetry.h

  # Microsoft's WIL (Windows Implementation Libraries) does not support
  # GCC: its template code assumes MSVC-specific nullptr/int conversions.
  # env.cc only uses wil::unique_handle and wil::unique_hfile for RAII.
  # Provide a minimal shim with just those two types for MinGW.
  cat > onnxruntime/core/platform/windows/mingw_wil_shim.h << 'SHIM'
#pragma once
#include <Windows.h>
#include <cstdlib>
#ifndef FAIL_FAST_LAST_ERROR_IF
#define FAIL_FAST_LAST_ERROR_IF(cond) do { if (cond) std::abort(); } while(0)
#endif
namespace wil {
class unique_handle {
  HANDLE h_ = nullptr;
  void close() { if (h_ && h_ != INVALID_HANDLE_VALUE) { CloseHandle(h_); h_ = nullptr; } }
public:
  unique_handle() = default;
  explicit unique_handle(HANDLE h) : h_(h) {}
  ~unique_handle() { close(); }
  unique_handle(unique_handle&& o) noexcept : h_(o.h_) { o.h_ = nullptr; }
  unique_handle& operator=(unique_handle&& o) noexcept {
    if (this != &o) { close(); h_ = o.h_; o.h_ = nullptr; }
    return *this;
  }
  unique_handle(const unique_handle&) = delete;
  unique_handle& operator=(const unique_handle&) = delete;
  HANDLE get() const { return h_; }
  HANDLE* addressof() { return &h_; }
  HANDLE* put() { close(); return &h_; }
  explicit operator bool() const { return h_ != nullptr && h_ != INVALID_HANDLE_VALUE; }
  void reset(HANDLE h = nullptr) { close(); h_ = h; }
};
using unique_hfile = unique_handle;
}
SHIM
  sed -i 's|^#include <wil/Resource.h>$|#ifdef _MSC_VER\n#include <wil/Resource.h>\n#else\n#include "core/platform/windows/mingw_wil_shim.h"\n#endif|' \
    onnxruntime/core/platform/windows/env.cc

  # MinGW needs explicit includes for _S_IREAD/_S_IWRITE and _SH_DENYWR
  # (MSVC's <io.h> pulls these in transitively; MinGW's does not).
  # Also provide a GCC-compatible __cpuid wrapper: MSVC's __cpuid(int[4], int)
  # intrinsic has a different signature than GCC's __cpuid(level, a, b, c, d)
  # macro from <cpuid.h>.  The Intel hybrid CPU detection code uses MSVC style.
  sed -i '/#include <io.h>/a\#include <share.h>\n#include <sys/stat.h>' \
    onnxruntime/core/platform/windows/env.cc
  sed -i '/#include "core\/platform\/windows\/dll_load_error.h"/a\
#ifndef _MSC_VER\
#include <cpuid.h>\
#undef __cpuid\
static inline void __cpuid(int info[4], int leaf) {\
    __cpuid_count(leaf, 0, info[0], info[1], info[2], info[3]);\
}\
#endif' \
    onnxruntime/core/platform/windows/env.cc

  # GCC does not allow implicit FARPROC-to-void* conversion.
  # There are two call sites: one via a local void* in SearchModulesForSymbol
  # and one in GetSymbolFromLibrary.
  sed -i 's/symbol = GetProcAddress(modules\[i\], name);/symbol = reinterpret_cast<void*>(GetProcAddress(modules[i], name));/' \
    onnxruntime/core/platform/windows/env.cc
  sed -i 's/\*symbol = ::GetProcAddress(reinterpret_cast<HMODULE>(handle), symbol_name.c_str());/*symbol = reinterpret_cast<void*>(::GetProcAddress(reinterpret_cast<HMODULE>(handle), symbol_name.c_str()));/' \
    onnxruntime/core/platform/windows/env.cc

  # ETW (Event Tracing for Windows) requires TraceLoggingProvider.h from
  # the Windows 10 SDK.  MinGW's ntverp.h reports VER_PRODUCTBUILD=3790
  # (Server 2003 era) so ETW_TRACE_LOGGING_SUPPORTED is never defined and
  # the EtwSink class does not exist.  The logging code references it behind
  # #ifdef _WIN32 which fires on MinGW too.  Guard the dead-code branch so
  # the compiler does not try to instantiate make_unique<EtwSink>.
  sed -i '/std::make_unique<EtwSink>/i\#ifdef ETW_TRACE_LOGGING_SUPPORTED' \
    onnxruntime/core/common/logging/logging.cc
  sed -i '/std::make_unique<EtwSink>/a\#endif' \
    onnxruntime/core/common/logging/logging.cc

  # Several headers/sources gate ETW telemetry includes (winmeta.h, evntrace.h,
  # WindowsTelemetry) behind #ifdef _WIN32.  MinGW is _WIN32 but lacks these
  # SDK headers.  Narrow to _MSC_VER.
  sed -i 's/^#ifdef _WIN32$/#ifdef _MSC_VER/' \
    onnxruntime/core/framework/execution_providers.h
  sed -i 's/^#ifdef _WIN32$/#ifdef _MSC_VER/' \
    onnxruntime/core/session/provider_registration.cc
  sed -i 's/defined(_WIN32) && defined(ONNXRUNTIME_ENABLE_INSTRUMENT)/defined(_MSC_VER) \&\& defined(ONNXRUNTIME_ENABLE_INSTRUMENT)/' \
    onnxruntime/core/session/provider_registration.cc

  # _tpause intrinsic requires -mwaitpkg on GCC but spin_pause.cc gates it
  # on _WIN32 (always true on MinGW).  Narrow to _MSC_VER so the GCC path
  # falls through to _mm_pause().
  sed -i 's/#if defined(_WIN32) || defined(__WAITPKG__)/#if defined(_MSC_VER) || defined(__WAITPKG__)/' \
    onnxruntime/core/common/spin_pause.cc

  # onnxruntime_graph.cmake gates /EHsc + MSVC linker flags on WIN32.
  # tensorboard proto has the same problem with /wd flags.
  sed -i 's/^if (WIN32)$/if (MSVC)/' \
    cmake/onnxruntime_graph.cmake
  sed -i 's/^if(WIN32)$/if(MSVC)/' \
    cmake/tensorboard/compat/proto/CMakeLists.txt
  # profiler.cc: the StartProfiling<T> template calls fstream::open(basic_string<T>)
  # which does not compile with libstdc++ when T=wchar_t.  Wrap with
  # std::filesystem::path so both char and wchar_t work.
  sed -i '/#include "profiler.h"/a\#include <filesystem>' \
    onnxruntime/core/common/profiler.cc
  sed -i 's/profile_stream_.open(file_name,/profile_stream_.open(std::filesystem::path{file_name},/' \
    onnxruntime/core/common/profiler.cc

  # file_sink.h: The Windows variant uses wofstream(wstring) which does not
  # compile on libstdc++.  Wrap with filesystem::path.
  sed -i '/#include <fstream>/a\#include <filesystem>' \
    onnxruntime/core/common/logging/sinks/file_sink.h
  sed -i 's/std::make_unique<std::wofstream>(filename,/std::make_unique<std::wofstream>(std::filesystem::path{filename},/' \
    onnxruntime/core/common/logging/sinks/file_sink.h

  # libstdc++ fstream does not accept std::wstring (an MSVC extension).
  # PathString is std::wstring on Windows; wrap it with std::filesystem::path
  # which libstdc++ does accept.  Use brace initialization to avoid the
  # most vexing parse when constructing temporaries.
  sed -i '/#include <sstream>/a\#include <filesystem>' \
    onnxruntime/core/framework/allocation_planner.cc
  sed -i 's/std::ifstream if_stream(config_file_)/std::ifstream if_stream{std::filesystem::path{config_file_}}/' \
    onnxruntime/core/framework/allocation_planner.cc
  sed -i 's/std::ofstream of_stream(config_file_)/std::ofstream of_stream{std::filesystem::path{config_file_}}/' \
    onnxruntime/core/framework/allocation_planner.cc
  sed -i 's/std::ifstream f(config_file)/std::ifstream f{std::filesystem::path{config_file}}/' \
    onnxruntime/core/framework/allocation_planner.cc

  # windres (MinGW resource compiler) chokes on the VER_STRING=\"...\"
  # define that cmake generates for ninja (no shell to strip backslashes).
  # The .rc file only provides DLL version metadata; just remove it.
  sed -i 's|"${ONNXRUNTIME_ROOT}/core/dll/onnxruntime.rc"||' \
    cmake/onnxruntime.cmake
  sed -i 's|"${ONNXRUNTIME_ROOT}/core/dll/onnxruntime.rc"||' \
    cmake/onnxruntime_providers_cpu.cmake

  # inference_session.cc: The two #ifdef _WIN32 blocks containing
  # active_sessions_mutex_ reference EtwRegistrationManager and EtwSink,
  # which are part of ETW logging (excluded from MinGW build).
  # Narrow both to _MSC_VER.
  sed -i '/#ifdef _WIN32/{N;/active_sessions_mutex_/{s/#ifdef _WIN32/#ifdef _MSC_VER/}}' \
    onnxruntime/core/session/inference_session.cc
  # However, the static member definition of active_sessions_mutex_ is used
  # unconditionally (the declaration in the header has no guard).  Move its
  # definition outside the _MSC_VER block; only the ETW callback stays guarded.
  sed -i '/^#ifdef _MSC_VER$/{N;/^#ifdef _MSC_VER\nstd::mutex InferenceSession::active_sessions_mutex_/{s/^#ifdef _MSC_VER\n//}}' \
    onnxruntime/core/session/inference_session.cc
  sed -i '/^onnxruntime::WindowsTelemetry::EtwInternalCallback/i\#ifdef _MSC_VER' \
    onnxruntime/core/session/inference_session.cc
  # Same fstream(wstring) pattern as allocation_planner.cc.
  sed -i '/#include <sstream>/a\#include <filesystem>' \
    onnxruntime/core/session/inference_session.cc
  sed -i 's/std::ifstream bytes_stream(model_uri, std::ifstream::in | std::ifstream::binary)/std::ifstream bytes_stream{std::filesystem::path{model_uri}, std::ifstream::in | std::ifstream::binary}/' \
    onnxruntime/core/session/inference_session.cc

  # logging.cc: EtwRegistrationManager::Instance() and ORTTraceLoggingKeyword
  # are only available with MSVC ETW infrastructure.  Guard the ETW-referencing
  # blocks.  The include of etw_sink.h also needs an _MSC_VER guard.
  sed -i 's|^#include "core/platform/windows/logging/etw_sink.h"|#ifdef _MSC_VER\n#include "core/platform/windows/logging/etw_sink.h"\n#endif|' \
    onnxruntime/core/common/logging/logging.cc
  sed -i '/#ifdef _WIN32/{N;/auto\& manager =/{s/#ifdef _WIN32/#ifdef _MSC_VER/}}' \
    onnxruntime/core/common/logging/logging.cc

  # Global fstream(wstring) fix for test code.  libstdc++ does not accept
  # std::wstring in fstream constructors (MSVC extension), but does accept
  # std::filesystem::path.  Wrap the first argument of all fstream
  # constructors in test/ with std::filesystem::path{} so both char and
  # wchar_t paths work.  This is a broad sed across all test .cc files.
  find onnxruntime/test -name '*.cc' | while read f; do
    grep -qE '(ifstream|ofstream)' "$f" || continue
    # Add #include <filesystem> after first #include if not already present
    grep -q '<filesystem>' "$f" || \
      sed -i '0,/#include/{/#include/a\#include <filesystem>
      }' "$f"
    # Wrap first arg of fstream(var, flags) and fstream{var, flags}
    # with std::filesystem::path{}.  The brace-init pattern [^,}]* stops
    # at } so it won't double-wrap already-wrapped expressions.
    sed -i \
      -e 's/\(std::ifstream [a-zA-Z_][a-zA-Z_0-9]*\)(\([^,)]*\),/\1(std::filesystem::path{\2},/g' \
      -e 's/\(std::ofstream [a-zA-Z_][a-zA-Z_0-9]*\)(\([^,)]*\),/\1(std::filesystem::path{\2},/g' \
      -e 's/\(std::ifstream [a-zA-Z_][a-zA-Z_0-9]*\){\([^,}]*\),/\1{std::filesystem::path{\2},/g' \
      -e 's/\(std::ofstream [a-zA-Z_][a-zA-Z_0-9]*\){\([^,}]*\),/\1{std::filesystem::path{\2},/g' \
      "$f"
  done
  # Special cases not caught by the generic pattern:
  # test_utils.cc: brace-init with explicit wstring type cast
  sed -i 's/std::ifstream stream{std::basic_string<ORTCHAR_T>{model_path}/std::ifstream stream{std::filesystem::path{std::basic_string<ORTCHAR_T>{model_path}}/' \
    onnxruntime/test/util/test_utils.cc
  # env_test.cc: single-argument brace-init ofstream
  sed -i 's/std::ofstream outfile{sub_dir + ORT_TSTR("\/file")}/std::ofstream outfile{std::filesystem::path{sub_dir + ORT_TSTR("\/file")}}/' \
    onnxruntime/test/platform/env_test.cc
  # sinks_test.cc: The #ifdef _WIN32 guards that select wide-char stream types
  # (std::wclog, std::wcerr, std::wofstream) do not work on MinGW's libstdc++.
  # Narrow those specific guards to _MSC_VER so MinGW uses narrow streams.
  # Leave the FileSink guard as _WIN32 (it uses ToWideString which works fine).
  sed -i '/#ifdef _WIN32/{N;/wofstream\|wclog\|wcerr/{s/#ifdef _WIN32/#ifdef _MSC_VER/}}' \
    onnxruntime/test/common/logging/sinks_test.cc

  # test/util/file_util.cc uses _SH_DENYRW (from share.h) and _S_IREAD
  # (from sys/stat.h) which MinGW does not pull in transitively via io.h.
  sed -i '/#include <io.h>/a\#include <share.h>\n#include <sys/stat.h>' \
    onnxruntime/test/util/file_util.cc

  # onnxruntime_unittests.cmake: /wd26409 is an MSVC warning flag passed
  # to the custom_op_library and benchmark targets inside non-UNIX blocks
  # without an MSVC guard.  GCC interprets it as a file path.
  sed -i 's/if (NOT onnxruntime_USE_CUDA)/if (MSVC AND NOT onnxruntime_USE_CUDA)/' \
    cmake/onnxruntime_unittests.cmake

  # test_main.cc: std::locale(".UTF-8", std::locale::ctype) is MSVC-only
  # (libstdc++ does not have this two-arg locale constructor).
  # Also, std::wclog.imbue() only makes sense when using wide streams.
  sed -i '/#ifdef _WIN32/{N;N;/wclog/{s/#ifdef _WIN32/#ifdef _MSC_VER/}}' \
    onnxruntime/test/unittest_main/test_main.cc

  # element_wise_ops_test.cc: TrigFloatTest template uses noexcept function
  # references, but MinGW's math functions (sinf, cosf, etc.) are not
  # declared noexcept.  Extend the _LIBCPP_VERSION guard to also cover MinGW.
  sed -i 's/#ifdef _LIBCPP_VERSION/#if defined(_LIBCPP_VERSION) || defined(__MINGW32__)/' \
    onnxruntime/test/providers/cpu/math/element_wise_ops_test.cc

  # strings_helper.h: missing <cstdint> for int64_t (MSVC pulls it in
  # transitively; MinGW does not).
  sed -i '/#include <string_view>/a\#include <cstdint>' \
    onnxruntime/test/perftest/strings_helper.h

  # main.cc (onnx test runner): ifstream(ConcatPathComponent(...)) spans
  # multiple lines so the global fstream sed can't catch it.  The result
  # is a wstring which libstdc++ can't handle.
  sed -i '/#include "TestCase.h"/a\#include <filesystem>' \
    onnxruntime/test/onnx/main.cc
  sed -i 's/std::ifstream overrides_ifstream(ConcatPathComponent(/std::ifstream overrides_ifstream(std::filesystem::path{ConcatPathComponent(/' \
    onnxruntime/test/onnx/main.cc
  sed -i 's/ORT_TSTR("onnx_backend_test_series_overrides.jsonc")));/ORT_TSTR("onnx_backend_test_series_overrides.jsonc"))});/' \
    onnxruntime/test/onnx/main.cc

  # Test executables using wmain (wide entry point under #ifdef _WIN32)
  # need -municode on MinGW so the CRT startup calls wmain instead of
  # looking for WinMain.
  sed -i '/set_target_properties(onnx_test_runner PROPERTIES FOLDER/a\
if(MINGW)\
  target_link_options(onnx_test_runner PRIVATE -municode)\
endif()' \
    cmake/onnxruntime_unittests.cmake
  sed -i '/set_target_properties(onnxruntime_perf_test PROPERTIES FOLDER/a\
if(MINGW)\
  target_link_options(onnxruntime_perf_test PRIVATE -municode)\
endif()' \
    cmake/onnxruntime_unittests.cmake

  # performance_runner.cc: ofstream::open(wstring) not supported by
  # libstdc++.  Wrap with filesystem::path.
  sed -i '/#include "performance_runner.h"/a\#include <filesystem>' \
    onnxruntime/test/perftest/performance_runner.cc
  sed -i 's/outfile.open(path,/outfile.open(std::filesystem::path{path},/' \
    onnxruntime/test/perftest/performance_runner.cc

  # test_model_loading.cc: uses wil/Resource.h for unique_hfile RAII
  # wrappers.  Same fix as env.cc: use our MinGW WIL shim.
  sed -i 's|^#include <wil/Resource.h>$|#ifdef _MSC_VER\n#include <wil/Resource.h>\n#else\n#include "core/platform/windows/mingw_wil_shim.h"\n#endif|' \
    onnxruntime/test/shared_lib/test_model_loading.cc

  # MLAS assembly: The MASM .asm kernels cannot be assembled by GCC's as(1),
  # but UASM (MASM-compatible assembler) handles them.  Provide the SEH
  # macros that MASM gets from the Windows SDK's macamd64.inc, enable AVX-512
  # EVEX encoding, and teach cmake to use UASM for MinGW builds.
  cat > onnxruntime/core/mlas/lib/amd64/macamd64.inc << 'MACAMD64'
; macamd64.inc -- SEH frame macros for UASM (replaces Windows SDK header)
push_reg MACRO reg
    push    reg
    .pushreg reg
ENDM

rex_push_reg MACRO reg
    push    reg
    .pushreg reg
ENDM

alloc_stack MACRO size
    sub     rsp, size
    .allocstack size
ENDM

save_reg MACRO reg, offset
    mov     [rsp+offset], reg
    .savereg reg, offset
ENDM

save_xmm128 MACRO reg, offset
    movaps  [rsp+offset], reg
    .savexmm128 reg, offset
ENDM

END_PROLOGUE MACRO
    .endprolog
ENDM

BEGIN_EPILOGUE MACRO
ENDM

LEAF_ENTRY MACRO Name, Section
    Section SEGMENT
    ALIGN   16
    PUBLIC  Name
    Name PROC
ENDM

LEAF_END MACRO Name, Section
    Name ENDP
    Section ENDS
ENDM

NESTED_ENTRY MACRO Name, Section, Handler
    Section SEGMENT
    ALIGN   16
    PUBLIC  Name
    IF @SizeStr(<Handler>) GT 0
        Name PROC FRAME:Handler
    ELSE
        Name PROC FRAME
    ENDIF
ENDM

NESTED_END MACRO Name, Section
    Name ENDP
    Section ENDS
ENDM
MACAMD64

  # Enable AVX-512 EVEX encoding in UASM (must come before first instruction)
  sed -i '/INCLUDE macamd64.inc/a\        option evex:1' \
    onnxruntime/core/mlas/lib/amd64/mlasi.inc

  # Exclude the 4 .asm files that UASM 2.57 cannot assemble:
  # - ConvSymKernelAvx512Core.asm, QgemmU8X8KernelAvx512Core.asm,
  #   QgemvU8S8KernelAvx512Core.asm: EVEX operand encoding gaps
  # - cvtfp16Avx.asm: AVX-NE-CONVERT instructions (too new for UASM 2.57)
  # These functions will fall back to C++ scalar implementations.
  for f in ConvSymKernelAvx512Core QgemmU8X8KernelAvx512Core \
           QgemvU8S8KernelAvx512Core cvtfp16Avx; do
    sed -i "/${f}.asm/d" cmake/onnxruntime_mlas.cmake
  done

  # For MinGW, enable ASM_MASM language and configure UASM as the assembler.
  # The MSVC path uses enable_language(ASM_MASM) gated behind if(MSVC).
  # Extend it to also fire for MinGW when UASM is available.
  sed -i '/enable_language(ASM_MASM)$/a\  elseif(MINGW)\
    set(CMAKE_ASM_MASM_COMPILER "uasm")\
    set(CMAKE_ASM_MASM_FLAGS "-win64 -I${MLAS_SRC_DIR}/amd64")\
    enable_language(ASM_MASM)' \
    cmake/adjust_global_compile_flags.cmake

  # In onnxruntime_mlas.cmake, the MSVC path calls setup_mlas_source_for_windows().
  # Make MinGW also take that path instead of falling through to the Linux/else branch.
  sed -i 's/^elseif(MSVC)$/elseif(MSVC OR MINGW)/' \
    cmake/onnxruntime_mlas.cmake
  # But setup_mlas_source_for_windows() has /arch:AVX and /arch:AVX2 flags
  # that are MSVC-only.  Guard them and add GCC equivalents for MinGW.
  sed -i 's|set_source_files_properties(\${mlas_platform_srcs_avx} PROPERTIES COMPILE_FLAGS "/arch:AVX")|if(MSVC)\n    set_source_files_properties(${mlas_platform_srcs_avx} PROPERTIES COMPILE_FLAGS "/arch:AVX")\n    elseif(MINGW)\n    set_source_files_properties(${mlas_platform_srcs_avx} PROPERTIES COMPILE_FLAGS "-mavx")\n    endif()|' \
    cmake/onnxruntime_mlas.cmake
  sed -i 's|set_source_files_properties(\${mlas_platform_srcs_avx2} PROPERTIES COMPILE_FLAGS "/arch:AVX2")|if(MSVC)\n    set_source_files_properties(${mlas_platform_srcs_avx2} PROPERTIES COMPILE_FLAGS "/arch:AVX2")\n    elseif(MINGW)\n    set_source_files_properties(${mlas_platform_srcs_avx2} PROPERTIES COMPILE_FLAGS "-mavx2 -mfma")\n    endif()|' \
    cmake/onnxruntime_mlas.cmake
  # Also add GCC flags for specific C++ source files that need SSE4.1/AVX512
  sed -i '/target_sources(onnxruntime_mlas PRIVATE/,/)/ {
    /qgemm_kernel_sse41.cpp/a\
    if(MINGW)\
      set_source_files_properties(${MLAS_SRC_DIR}/qgemm_kernel_sse41.cpp PROPERTIES COMPILE_FLAGS "-msse4.1")\
      set_source_files_properties(${MLAS_SRC_DIR}/qgemm_kernel_amx.cpp PROPERTIES COMPILE_FLAGS "-mavx512f -mavx512bw -mavx512dq -mavx512vl -mamx-int8 -mamx-tile")\
      set_source_files_properties(${MLAS_SRC_DIR}/intrinsics/avx512/quantize_avx512f.cpp PROPERTIES COMPILE_FLAGS "-mavx512f")\
      set_source_files_properties(${MLAS_SRC_DIR}/sqnbitgemm_kernel_avx512.cpp PROPERTIES COMPILE_FLAGS "-mavx512f -mavx512bw -mavx512dq -mavx512vl -mavx512vnni")\
      set_source_files_properties(${MLAS_SRC_DIR}/sqnbitgemm_kernel_avx512vnni.cpp PROPERTIES COMPILE_FLAGS "-mavx512f -mavx512bw -mavx512dq -mavx512vl -mavx512vnni")\
    endif()
  }' cmake/onnxruntime_mlas.cmake

  # The target platform detection only normalizes for MSVC.  MinGW on x64
  # reports CMAKE_SYSTEM_PROCESSOR=AMD64 but setup_mlas_source_for_windows()
  # checks for "x64".  Extend the normalization to also cover MinGW.
  sed -i 's/^if (MSVC)$/if (MSVC OR MINGW)/' \
    cmake/detect_onnxruntime_target_platform.cmake

  # etw_sink.h: The dummy EtwRegistrationManager class (used when ETW is
  # unsupported, which includes MinGW) declares Instance() and SupportsETW()
  # without definitions.  The implementations live in etw_sink.cc which is
  # excluded from the MinGW build.  Make them inline in the dummy class.
  sed -i '/^#else$/,/^#endif/ {
    s/static EtwRegistrationManager\& Instance();/static EtwRegistrationManager\& Instance() { static EtwRegistrationManager instance; return instance; }/
    s/static bool SupportsETW();/static bool SupportsETW() { return false; }/
  }' onnxruntime/core/platform/windows/logging/etw_sink.h
  # The dummy class uses std::function and uint64_t but only includes
  # severity.h.  Add the missing standard headers.
  sed -i '/#include "core\/common\/logging\/severity.h"/a\#include <functional>\n#include <cstdint>' \
    onnxruntime/core/platform/windows/logging/etw_sink.h

  # path_lib.cc uses PathCchRemoveBackslash/PathCchRemoveFileSpec from
  # pathcch.dll.  MSVC picks up the library via #pragma comment(lib),
  # which GCC ignores.  Add it to onnxruntime_common's link libraries.
  sed -i '/target_link_libraries(onnxruntime_common PUBLIC safeint_interface/a\
if(MINGW)\
  target_link_libraries(onnxruntime_common PRIVATE pathcch)\
endif()' \
    cmake/onnxruntime_common.cmake

  # GNU ld does not handle .def files passed as bare input files: it tries
  # to parse them as linker scripts and chokes on the EXPORTS directive.
  # Remove the .def from the shared library source list (MSVC's link.exe
  # understands .def-as-source, GCC's ld does not).  This means all
  # symbols are exported, which is acceptable for a system package.
  sed -i '/onnxruntime_add_shared_library(onnxruntime/{n;/\${SYMBOL_FILE}/d}' \
    cmake/onnxruntime.cmake

  # The -DEF:<file> link option is MSVC linker syntax.  GCC parses it as
  # -D EF:<file> (a harmless preprocessor define) but the .def file is
  # not actually consumed.  Guard with if(MSVC).
  sed -i 's|target_link_options(onnxruntime PRIVATE  "-DEF:\${SYMBOL_FILE}")|if(MSVC)\n    target_link_options(onnxruntime PRIVATE  "-DEF:${SYMBOL_FILE}")\n    endif()|' \
    cmake/onnxruntime.cmake

  # The DELAYLOAD and /ignore:4199 flags at the bottom of onnxruntime.cmake
  # are MSVC-specific linker options.  The guard "WIN32 AND NOT ...kernel32.lib"
  # fires on MinGW (whose standard libs use -lkernel32, not kernel32.lib).
  # Narrow to MSVC.
  sed -i 's|if (WIN32 AND NOT CMAKE_CXX_STANDARD_LIBRARIES MATCHES kernel32.lib)|if (MSVC AND NOT CMAKE_CXX_STANDARD_LIBRARIES MATCHES kernel32.lib)|' \
    cmake/onnxruntime.cmake
}

build() {
  mkdir -p "${srcdir}/build-${MSYSTEM}" && cd "${srcdir}/build-${MSYSTEM}"

  declare -a _extra_config
  if check_option "debug" "n"; then
    _extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    _extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  # The real CMakeLists.txt is in the cmake/ subdirectory.
  #
  # ONNX Runtime pins protobuf v21.12, which is ABI-incompatible with
  # the system protobuf (v33.x).  Let FetchContent build it from source
  # together with its tightly-coupled deps (abseil, re2).
  #
  # Delay-loaded DLLs use MSVC's delayimp.lib; must be disabled for MinGW.
  # GCC needs -mxsave for the _xgetbv intrinsic used in MLAS
  # platform detection code; MSVC provides it unconditionally.
  # -Wno-attributes: ELF visibility attributes are meaningless on PE.
  # -Wno-unknown-pragmas: MSVC '#pragma warning(push/pop)' is harmless.
  #
  # --allow-multiple-definition: Without a .def file, MinGW exports ALL
  # symbols from the DLL.  Test executables that link against both the
  # DLL import library and the same static libraries get duplicate
  # symbols.  MSVC avoids this because its .def restricts DLL exports.
  CXXFLAGS+=" -mxsave -Wno-attributes -Wno-unknown-pragmas -Wno-unused-value -Wno-unused-variable -Wno-unused-parameter -Wno-unused-but-set-variable -Wno-switch -Wno-parentheses -Wno-cast-function-type -Wno-sign-compare -Wno-deprecated-declarations -DPLATFORM_WINDOWS -DNOGDI -DNOMINMAX -D_USE_MATH_DEFINES -D_WIN32_WINNT=0x0A00 -D_NO_W32_PSEUDO_MODIFIERS" \
  LDFLAGS+=" -Wl,--allow-multiple-definition" \
  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
  ${MINGW_PREFIX}/bin/cmake.exe -Wno-dev \
    -G"Ninja" \
    -DCMAKE_INSTALL_PREFIX=${MINGW_PREFIX} \
    -DCMAKE_DLL_NAME_WITH_SOVERSION=ON \
    -DCMAKE_CXX_SCAN_FOR_MODULES=OFF \
    -Donnxruntime_BUILD_SHARED_LIB=ON \
    -Donnxruntime_BUILD_UNIT_TESTS=ON \
    -Donnxruntime_BUILD_BENCHMARKS=OFF \
    -Donnxruntime_ENABLE_PYTHON=OFF \
    -Donnxruntime_USE_CUDA=OFF \
    -Donnxruntime_USE_TENSORRT=OFF \
    -Donnxruntime_USE_OPENVINO=OFF \
    -Donnxruntime_USE_COREML=OFF \
    -Donnxruntime_USE_DML=OFF \
    -Donnxruntime_USE_WINML=OFF \
    -Donnxruntime_USE_XNNPACK=OFF \
    -Donnxruntime_USE_WEBNN=OFF \
    -Donnxruntime_USE_WEBGPU=OFF \
    -Donnxruntime_USE_JSEP=OFF \
    -Donnxruntime_USE_QNN=OFF \
    -Donnxruntime_USE_SNPE=OFF \
    -Donnxruntime_USE_RKNPU=OFF \
    -Donnxruntime_USE_DNNL=OFF \
    -Donnxruntime_USE_MIGRAPHX=OFF \
    -Donnxruntime_USE_ACL=OFF \
    -Donnxruntime_USE_ARMNN=OFF \
    -Donnxruntime_USE_CANN=OFF \
    -Donnxruntime_USE_VITISAI=OFF \
    -DCMAKE_DISABLE_FIND_PACKAGE_flatbuffers=ON \
    -Donnxruntime_ENABLE_DELAY_LOADING_WIN_DLLS=OFF \
    -Donnxruntime_ENABLE_TRAINING=OFF \
    -Donnxruntime_ENABLE_TRAINING_APIS=OFF \
    -Donnxruntime_USE_MIMALLOC=OFF \
    "${_extra_config[@]}" \
    ../${_realname}-${pkgver}/cmake

  ${MINGW_PREFIX}/bin/cmake --build .
}

check() {
  cd "${srcdir}/build-${MSYSTEM}"
  ${MINGW_PREFIX}/bin/ctest --output-on-failure
}

package() {
  cd "${srcdir}/build-${MSYSTEM}"
  DESTDIR="${pkgdir}" ${MINGW_PREFIX}/bin/cmake --install .

  install -Dm644 "${srcdir}/${_realname}-${pkgver}/LICENSE" \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
