apply_patch_with_msg() {
  for _patch in "$@"
  do
    msg2 "Applying ${_patch}"
    patch -Nbp1 -i "${srcdir}/${_patch}"
  done
}

prepare() {
  cd ${_realname}-${pkgver}

  # ONNX Runtime assumes Windows = MSVC throughout its cmake and C++ code.
  # These patches fix the ~80 files that need adjustments for MinGW/GCC
  # and MinGW/Clang:
  #
  # 0001: cmake guard fixes (WIN32->MSVC for compiler flags, MSVC->WIN32
  #       for platform selection, linker flag guards, DLL PREFIX removal,
  #       -municode for wmain executables, COMPILE_WARNING_AS_ERROR off)
  # 0002: compiler/platform compatibility (SAL annotations, HRESULT typedef,
  #       __cpuid wrapper, FARPROC casts, i64->LL suffix, _tpause guard,
  #       _aligned_free/free mismatch, MLAS_FORCEINLINE guard, vsnprintf_s
  #       precedence fix, [[nodiscard]] Clang conflict)
  # 0003: ETW/telemetry stubs + WIL shim (MinGW lacks TraceLoggingProvider.h
  #       and WIL has no GCC support; provide stub headers and shims)
  # 0004: fstream(wstring) + logging sinks (libstdc++ fstream does not accept
  #       std::wstring; wrap with std::filesystem::path. Restructure logging
  #       sinks so MinGW uses narrow OStreamSink for console, wide for files)
  # 0005: MLAS assembly macros (macamd64.inc SEH shim for UASM, option evex:1
  #       in mlasi.inc for AVX-512 EVEX encoding)
  # 0006: test code fixes (fstream wstring in ~40 test files, locale stubs,
  #       RNG guard, noexcept math functions, missing headers, wide stream
  #       guards, device metadata guard)
  apply_patch_with_msg \
    0001-mingw-cmake-fixes.patch \
    0002-mingw-compiler-compat.patch \
    0003-mingw-etw-telemetry-wil-stubs.patch \
    0004-mingw-fstream-and-logging-sinks-core.patch \
    0005-mingw-mlas-assembly-macros.patch \
    0006-mingw-test-fixes.patch \
    0007-use-system-libraries.patch \
    0008-relax-the-dependency-on-flatbuffers.patch \
    0009-fix-onnx-onnxruntime-register-conflict.patch
}

build() {
  declare -a _extra_config
  if check_option "debug" "n"; then
    _extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    _extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  # The real CMakeLists.txt is in the cmake/ subdirectory.
  #
  # ONNX Runtime pins protobuf v21.12, which is ABI-incompatible with
  # the system protobuf (v33.x).  Let FetchContent build it from source
  # together with its tightly-coupled deps (abseil, re2).
  #
  # GCC needs -mxsave for the _xgetbv intrinsic used in MLAS
  # platform detection code; MSVC provides it unconditionally.
  # -Wno-attributes: ELF visibility attributes are meaningless on PE.
  # -Wno-unknown-pragmas: MSVC '#pragma warning(push/pop)' is harmless.
  #
  # --allow-multiple-definition: without a .def file MinGW exports ALL
  # symbols from DLLs, so test executables linking both DLL import
  # libraries and static archives get duplicates.  GNU ld resolves this.
  # LLD (CLANG64) has a stricter "was replaced" check that this flag
  # cannot suppress, so unit tests are disabled on Clang (the library
  # itself builds fine; tests are fully covered by UCRT64).
  if [[ ${CARCH} == x86_64 ]]; then
    CXXFLAGS+=" -mxsave"
  fi
  CXXFLAGS+=" -w -DPLATFORM_WINDOWS -DNOGDI -DNOMINMAX -D_USE_MATH_DEFINES -D_WIN32_WINNT=0x0A00 -D_NO_W32_PSEUDO_MODIFIERS" \
  LDFLAGS+=" -Wl,--allow-multiple-definition" \
  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
  ${MINGW_PREFIX}/bin/cmake.exe -Wno-dev \
    -G"Ninja" \
    -DCMAKE_INSTALL_PREFIX=${MINGW_PREFIX} \
    -DCMAKE_EXE_LINKER_FLAGS=-Wl,--allow-multiple-definition \
    -DCMAKE_SHARED_LINKER_FLAGS=-Wl,--allow-multiple-definition \
    -DCMAKE_DLL_NAME_WITH_SOVERSION=ON \
    -DCMAKE_CXX_SCAN_FOR_MODULES=OFF \
    -DCMAKE_ASM_MASM_COMPILER=${MINGW_PREFIX}/bin/uasm.exe \
    -DCMAKE_ASM_MASM_FLAGS=-win64 \
    -DBUILD_PKGCONFIG_FILES=ON \
    -Donnxruntime_BUILD_SHARED_LIB=ON \
    -Donnxruntime_BUILD_UNIT_TESTS=OFF \
    -Donnxruntime_BUILD_BENCHMARKS=OFF \
    -Donnxruntime_ENABLE_PYTHON=ON \
    -Donnxruntime_USE_CUDA=OFF \
    -Donnxruntime_USE_TENSORRT=OFF \
    -Donnxruntime_USE_OPENVINO=OFF \
    -Donnxruntime_USE_COREML=OFF \
    -Donnxruntime_USE_DML=OFF \
    -Donnxruntime_USE_WINML=OFF \
    -Donnxruntime_USE_XNNPACK=OFF \
    -Donnxruntime_USE_WEBNN=OFF \
    -Donnxruntime_USE_WEBGPU=OFF \
    -Donnxruntime_USE_JSEP=OFF \
    -Donnxruntime_USE_QNN=OFF \
    -Donnxruntime_USE_SNPE=OFF \
    -Donnxruntime_USE_RKNPU=OFF \
    -Donnxruntime_USE_DNNL=OFF \
    -Donnxruntime_USE_MIGRAPHX=OFF \
    -Donnxruntime_USE_ACL=OFF \
    -Donnxruntime_USE_CANN=OFF \
    -Donnxruntime_USE_VITISAI=OFF \
    -Donnxruntime_USE_FULL_PROTOBUF=OFF \
    -Donnxruntime_ENABLE_DELAY_LOADING_WIN_DLLS=OFF \
    -Donnxruntime_ENABLE_TRAINING=OFF \
    -Donnxruntime_ENABLE_TRAINING_APIS=OFF \
    -Donnxruntime_USE_MIMALLOC=OFF \
    -Donnxruntime_USE_PREINSTALLED_EIGEN=ON \
    -DPython_EXECUTABLE=${MINGW_PREFIX}/bin/python.exe \
    "${_extra_config[@]}" \
    -S ${_realname}-${pkgver}/cmake \
    -B build-${MSYSTEM}

  ${MINGW_PREFIX}/bin/cmake --build build-${MSYSTEM}

  rm -rf "python-build-${MSYSTEM}"
  cp -r "${_realname}-${pkgver}" "python-build-${MSYSTEM}" && cd "python-build-${MSYSTEM}"
  cp -r "${srcdir}"/build-${MSYSTEM}/onnxruntime/* onnxruntime
  cp -r "${srcdir}"/build-${MSYSTEM}/requirements.txt .
  python -m build --wheel --skip-dependency-check --no-isolation
}

check() {
  ${MINGW_PREFIX}/bin/cmake \
    -Donnxruntime_BUILD_UNIT_TESTS=ON \
    -DCMAKE_INCLUDE_PATH=$(python -c "import sysconfig; print(sysconfig.get_path('platlib'))") \
    -S${_realname}-${pkgver}/cmake -Bbuild-${MSYSTEM}
  ${MINGW_PREFIX}/bin/cmake --build build-${MSYSTEM}
  ${MINGW_PREFIX}/bin/ctest --test-dir build-${MSYSTEM} --output-on-failure || true
}

package_onnxruntime() {
  pkgdesc+=" (mingw-w64)"
  DESTDIR="${pkgdir}" ${MINGW_PREFIX}/bin/cmake --install build-${MSYSTEM}

  install -Dm644 "${srcdir}/${_realname}-${pkgver}/LICENSE" \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/ThirdPartyNotices.txt \
    "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/ThirdPartyNotices.txt
}

package_python-onnxruntime() {
  pkgdesc+=" (Python bindings) (mingw-w64)"
  depends=("${MINGW_PACKAGE_PREFIX}-python"
           "${MINGW_PACKAGE_PREFIX}-python-flatbuffers"
           "${MINGW_PACKAGE_PREFIX}-python-numpy"
           "${MINGW_PACKAGE_PREFIX}-python-packaging"
           "${MINGW_PACKAGE_PREFIX}-python-protobuf"
           "${MINGW_PACKAGE_PREFIX}-cc-libs"
           "${MINGW_PACKAGE_PREFIX}-abseil-cpp"
           "${MINGW_PACKAGE_PREFIX}-onnx"
           #"${MINGW_PACKAGE_PREFIX}-onnxruntime"
           "${MINGW_PACKAGE_PREFIX}-protobuf"
           "${MINGW_PACKAGE_PREFIX}-re2")
  options=(!strip)

  cd "${srcdir}"/python-build-${MSYSTEM}

  MSYS2_ARG_CONV_EXCL="--prefix=" \
    ${MINGW_PREFIX}/bin/python -m installer --prefix=${MINGW_PREFIX} \
    --destdir="${pkgdir}" dist/*.whl

  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/python-${_realname}/LICENSE
  install -Dm644 ThirdPartyNotices.txt "${pkgdir}"${MINGW_PREFIX}/share/licenses/python-${_realname}/ThirdPartyNotices.txt
}

# template start; name=mingw-w64-splitpkg-wrappers; version=1.0;
# vim: set ft=bash :

# generate wrappers
for _name in "${pkgname[@]}"; do
  _short="package_${_name#${MINGW_PACKAGE_PREFIX}-}"
  _func="$(declare -f "${_short}")"
  eval "${_func/#${_short}/package_${_name}}"
done
# template end;
