# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Data-Compare
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=1.29
pkgrel=1
pkgdesc="Compare perl data structures. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Data-Compare"
msys2_repository_url="https://github.com/DrHyde/perl-modules-Data-Compare"
msys2_references=(
  'purl: pkg:cpan/DCANTRELL/Data-Compare'
)
license=('spdx:Artistic-1.0-Perl OR GPL-2.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-clone"
         "${MINGW_PACKAGE_PREFIX}-perl-file-find-rule")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/D/DC/DCANTRELL/${_perlname}-${pkgver}.tar.gz")
sha256sums=('53c9db3b93263c88aaa3c4072d819eaded024d7a36b38c0c37737d288d5afa8c')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" install
  install -Dm644 ARTISTIC.txt "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/ARTISTIC.txt
  install -Dm644 GPL2.txt "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/GPL2.txt
}
