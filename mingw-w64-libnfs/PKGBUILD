# Maintainer: Alexey Pavlov <alexpux@gmail.com>

_realname=libnfs
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=6.0.2
pkgrel=1
pkgdesc="Client library for accessing NFS shares over a network (mingw-w64)"
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url="https://github.com/sahlberg/libnfs/"
msys2_repository_url='https://github.com/sahlberg/libnfs'
license=('spdx:BSD-2-Clause AND LGPL-2.1-or-later AND GPL-3.0-or-later')
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc" "${MINGW_PACKAGE_PREFIX}-autotools")
source=("${msys2_repository_url}/archive/${_realname}-${pkgver}.tar.gz"
        0001-fix-header.patch
        2.0.0-win32.patch)
sha256sums=('4e5459cc3e0242447879004e9ad28286d4d27daa42cbdcde423248fad911e747'
            'bc4a2c26d73e019a3bfd46e2a7d9d134de044ff4b8cf32e968bc4f36cd3e0c0d'
            '42431022a0dac3384501c0e1f84490df93e6d4e7870dc87c00371b93222f6992')

prepare() {
  mv "${_realname}-${_realname}-${pkgver}" "${_realname}-${pkgver}" # Canonicalize source directory name

  cd ${_realname}-${pkgver}

  patch -Nbp1 -i "${srcdir}"/0001-fix-header.patch
  patch -Nbp1 -i "${srcdir}"/2.0.0-win32.patch

  autoreconf -fiv
}

build() {
  mkdir "build-${MSYSTEM}" && cd "build-${MSYSTEM}"

  if [[ ${MSYSTEM} == CLANG* ]]; then
    CFLAGS+=" -Wno-cast-align"
  fi

  ../${_realname}-${pkgver}/configure \
    --prefix=${MINGW_PREFIX} \
    --build=${MINGW_CHOST} \
    --host=${MINGW_CHOST} \
    --target=${MINGW_CHOST} \
    --enable-shared \
    --enable-static \
    --enable-utils \
    --without-libkrb5

  make
}

package() {
  cd build-${MSYSTEM}

  make DESTDIR="${pkgdir}" install

  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/COPYING "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/COPYING
  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/LICENCE-BSD.txt "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/LICENCE-BSD.txt
  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/LICENCE-GPL-3.txt "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/LICENCE-GPL-3.txt
  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/LICENCE-LGPL-2.1.txt "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/LICENCE-LGPL-2.1.txt
}
