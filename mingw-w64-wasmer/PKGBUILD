# Maintainer: Maksim Bondarenkov <maksapple2306@gmail.com>

_realname=wasmer
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}"
         "${MINGW_PACKAGE_PREFIX}-lib${_realname}")
pkgver=7.1.0
pkgrel=2
pkgdesc="The leading Wasm Runtime supporting WASIX, WASI and Emscripten (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64')
url="https://github.com/wasmerio/wasmer"
msys2_repository_url='https://github.com/wasmerio/wasmer'
msys2_references=(
  "cpe: cpe:/a:wasmer:wasmer"
  'purl: pkg:cargo/wasmer'
)
license=('spdx:MIT')
makedepends=("${MINGW_PACKAGE_PREFIX}-rust"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-pkgconf"
             "${MINGW_PACKAGE_PREFIX}-llvm"
             "${MINGW_PACKAGE_PREFIX}-openssl"
             "${MINGW_PACKAGE_PREFIX}-nodejs"
             "${MINGW_PACKAGE_PREFIX}-zstd")
checkdepends=("${MINGW_PACKAGE_PREFIX}-rustup")
source=("${_realname}-${pkgver}.tar.xz::${url}/releases/download/v${pkgver}/${_realname}-full-source.tar.xz"
        "llvm-sys.tar.gz::https://crates.io/api/v1/crates/llvm-sys/211.0.0/download"
        "llvm-sys-mingw-fixes.patch")
sha256sums=('4a4374e84f55758de2f8b57b3f5a88015d5f9341b6417601c372138ab90f9fa4'
            '108b3ad2b2eaf2a561fc74196273b20e3436e4a688b8b44e250d83974dc1b2e2'
            '4dc73948f833aa672620ce5fd93d398303902db5bc631fcfb10cb8a6ebff7c62')
noextract=("${_realname}-${pkgver}.tar.xz")

prepare() {
  tar -xf "${_realname}-${pkgver}.tar.xz" || true
  cd "${_realname}-${pkgver}"
  rm rust-toolchain.toml

  patch -d ../llvm-sys-211.0.0 -p1 -i ../llvm-sys-mingw-fixes.patch

  cat >> Cargo.toml <<END

[patch.crates-io]
llvm-sys.path = "../llvm-sys-211.0.0"
END

  cargo update -p llvm-sys
  cargo fetch --locked --target "${RUST_CHOST}"
}

build() {
  cd "${_realname}-${pkgver}"

  export OPENSSL_NO_VENDOR=1
  export WINAPI_NO_BUNDLED_LIBRARIES=1
  export WASMER_INSTALL_PREFIX=${MINGW_PREFIX}
  export WASMER_REPRODUCIBLE_BUILD=1
  export LLVM_SYS_211_FFI_WORKAROUND=1
  export RUSTFLAGS="${RUSTFLAGS/+crt-static/-crt-static}"
  if [[ ${CC} == gcc ]]; then
    # pthread symbols are somehow defined more than once...
    export RUSTFLAGS+=" -Clink-arg=-Wl,--allow-multiple-definition"
  fi
  make -O ENABLE_SINGLEPASS=1 ENABLE_CRANELIFT=1 ENABLE_LLVM=1
}

check() {
  cd "${_realname}-${pkgver}"

  export RUSTUP_TOOLCHAIN="stable-${RUST_CHOST}"
  make test-examples
}

package_wasmer() {
  depends=("${MINGW_PACKAGE_PREFIX}-cc-libs"
           "${MINGW_PACKAGE_PREFIX}-libffi"
           "${MINGW_PACKAGE_PREFIX}-zlib"
           "${MINGW_PACKAGE_PREFIX}-zstd")

  install -Dm755 "${_realname}-${pkgver}"/target/release/wasmer "${pkgdir}${MINGW_PREFIX}/bin/wasmer"
  install -Dm644 "${_realname}-${pkgver}"/LICENSE "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}

package_libwasmer() {
  pkgdesc+=' (C-API)'
  conflicts=("${MINGW_PACKAGE_PREFIX}-libwasmtime")
  depends=("${MINGW_PACKAGE_PREFIX}-cc-libs")

  install -Dm755 "${_realname}-${pkgver}"/target/release/wasmer.dll "${pkgdir}${MINGW_PREFIX}/bin/wasmer.dll"
  install -Dm755 "${_realname}-${pkgver}"/target/release/wasmer.dll.a "${pkgdir}${MINGW_PREFIX}/lib/wasmer.dll.a"
  install -vDm644 "${_realname}-${pkgver}"/lib/c-api/*.h -t "${pkgdir}${MINGW_PREFIX}/include/"
  "${_realname}-${pkgver}"/target/release/wasmer config --pkg-config | install -Dm644 /dev/stdin \
    "${pkgdir}${MINGW_PREFIX}/lib/pkgconfig/wasmer.pc"
  install -Dm644 "${_realname}-${pkgver}"/LICENSE "${pkgdir}${MINGW_PREFIX}/share/licenses/lib${_realname}/LICENSE"
}

# vim: set ft=bash :

# generate wrappers
for _name in "${pkgname[@]}"; do
  _short="package_${_name#${MINGW_PACKAGE_PREFIX}-}"
  _func="$(declare -f "${_short}")"
  eval "${_func/#${_short}/package_${_name}}"
done
