# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Readonly
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=2.05
pkgrel=1
pkgdesc="Facility for creating read-only scalars, arrays, hashes. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Readonly"
msys2_repository_url="https://github.com/sanko/readonly"
msys2_references=(
  'purl: pkg:cpan/SANKO/Readonly'
)
license=('spdx:Artistic-2.0')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl")
makedepends=("${MINGW_PACKAGE_PREFIX}-make"
             "${MINGW_PACKAGE_PREFIX}-perl-module-build-tiny")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/S/SA/SANKO/${_perlname}-${pkgver}.tar.gz")
sha256sums=('4b23542491af010d44a5c7c861244738acc74ababae6b8838d354dfb19462b5e')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  PERL_MM_USE_DEFAULT=1 perl Build.PL
  ./Build
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="--prefix=" \
  ./Build install --destdir="${pkgdir}" --prefix=${MINGW_PREFIX}
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
