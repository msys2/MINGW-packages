# Contributor: Kreijstal <kreijstal@hotmail.com>

_realname=retroarch-assets
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=r1.cd17f64
pkgrel=1
pkgdesc='Menu assets (XMB, Ozone, GLUI, MaterialUI, RGUI, OSK) for RetroArch (mingw-w64)'
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://www.libretro.com/'
msys2_repository_url='https://github.com/libretro/retroarch-assets'
license=('spdx:CC-BY-4.0 AND GPL-3.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-libretro")
depends=()
makedepends=("git")
optdepends=("${MINGW_PACKAGE_PREFIX}-retroarch: frontend that consumes these assets")
_commit=cd17f64cff4eaff187a0702d17520ccb9a760fe3
source=("git+https://github.com/libretro/retroarch-assets.git#commit=${_commit}")
sha256sums=('713e88bf089b36e24e9650e0349f38a96d74cd313f101162493565d5914a20e7')

pkgver() {
  cd retroarch-assets
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
  install -d "${pkgdir}${MINGW_PREFIX}/share/retroarch"
  cp -r retroarch-assets "${pkgdir}${MINGW_PREFIX}/share/retroarch/assets"

  rm -rf "${pkgdir}${MINGW_PREFIX}/share/retroarch/assets/.git" \
         "${pkgdir}${MINGW_PREFIX}/share/retroarch/assets/.gitlab-ci.yml"
}
