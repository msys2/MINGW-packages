 # Generate library list.
 if (CXX_SUPPORTS_NOSTDLIBXX_FLAG)
   add_link_flags_if_supported(-nostdlib++)
-else()
+endif()
+if (C_SUPPORTS_NODEFAULTLIBS_FLAG)
