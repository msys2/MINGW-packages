# Maintainer: Mike Ruprecht <cmaiku@gmail.com>

_realname='gumbo-parser'
pkgbase="mingw-w64-${_realname}"
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=0.13.2
pkgrel=1
pkgdesc='HTML5 parsing library in pure C99 (mingw-w64)'
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url='https://codeberg.org/gumbo-parser/gumbo-parser/'
msys2_repository_url='https://codeberg.org/gumbo-parser/gumbo-parser'
license=('spdx:Apache-2.0')
checkdepends=("${MINGW_PACKAGE_PREFIX}-gtest")
makedepends=("${MINGW_PACKAGE_PREFIX}-autotools" "${MINGW_PACKAGE_PREFIX}-cc")
source=("${url}archive/${pkgver}.tar.gz")
sha256sums=('dbdc159dc8e5c6f3f254e50bce689dd9e439064ff06c165d5653410a5714ab66')

prepare() {
  cd "${_realname}"
  ./autogen.sh
}

build() {
  cd "${_realname}"

  ./configure \
    --prefix=${MINGW_PREFIX} \
    --build=${MINGW_CHOST} \
    --host=${MINGW_CHOST}

  make
}

check() {
  cd "${_realname}"
  make -k check
}

package() {
  cd "${_realname}"
  make install DESTDIR="${pkgdir}"

  install -Dm644 "${srcdir}/${_realname}/doc/COPYING" \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/COPYING"
}
