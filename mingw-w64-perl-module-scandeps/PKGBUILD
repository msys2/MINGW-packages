# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Module-ScanDeps
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=1.37
pkgrel=1
pkgdesc="	Recursively scan Perl code for dependencies. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Module-ScanDeps"
msys2_repository_url="https://github.com/rschupp/Module-ScanDeps"
msys2_references=(
  'purl: pkg:cpan/RSCHUPP/Module-ScanDeps'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl")
makedepends=("${MINGW_PACKAGE_PREFIX}-make"
             "${MINGW_PACKAGE_PREFIX}-perl-ipc-run3"
             "${MINGW_PACKAGE_PREFIX}-perl-test-requires")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/R/RS/RSCHUPP/${_perlname}-${pkgver}.tar.gz")
sha256sums=('1f5e119cade1466c39c71e5bc35a8d4f4e672635db03d79a5a0dcf08c4e2b5a3')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" PREFIX=${MINGW_PREFIX} install
}
