# Contributor (MSYS2): Oleg A. Khlybov <fougas@mail.ru>

_realname=dino
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=0.5.1
pkgrel=1
pkgdesc='XMPP GUI client (mingw-w64)'
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url='https://github.com/dino/libomemo-c'
msys2_repository_url="https://github.com/dino/libomemo-c"
msys2_references=(
  'archlinux: dino'
)
license=('spdx:GPL-3.0')
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs"
         "${MINGW_PACKAGE_PREFIX}-libgee"
         "${MINGW_PACKAGE_PREFIX}-gtk4"
         "${MINGW_PACKAGE_PREFIX}-glib2"
         "${MINGW_PACKAGE_PREFIX}-libadwaita"
         "${MINGW_PACKAGE_PREFIX}-icu"
         "${MINGW_PACKAGE_PREFIX}-sqlite3"
         #"${MINGW_PACKAGE_PREFIX}-qrencode"
         #"${MINGW_PACKAGE_PREFIX}-libcanberra"
         "${MINGW_PACKAGE_PREFIX}-gstreamer"
         "${MINGW_PACKAGE_PREFIX}-webrtc-audio-processing"
         "${MINGW_PACKAGE_PREFIX}-webrtc-audio-processing-1"
         "${MINGW_PACKAGE_PREFIX}-libomemo-c"
         "${MINGW_PACKAGE_PREFIX}-abseil-cpp"
         "${MINGW_PACKAGE_PREFIX}-libnice"
         "${MINGW_PACKAGE_PREFIX}-gnutls"
         "${MINGW_PACKAGE_PREFIX}-libgcrypt"
         "${MINGW_PACKAGE_PREFIX}-libsrtp"
         "${MINGW_PACKAGE_PREFIX}-libsoup3"
         "${MINGW_PACKAGE_PREFIX}-gpgme")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-pkgconf"
             "${MINGW_PACKAGE_PREFIX}-git"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-vala"
             "${MINGW_PACKAGE_PREFIX}-meson")
source=("https://github.com/dino/dino/releases/download/v${pkgver}/${_realname}-${pkgver}.tar.gz"
        "0001-version.patch"
        "0002-langinfo.patch")
sha256sums=('0b265ee3551dcddad5b62e188bdcab2cbb61a0d6a7e72107b2518a156b3ed665'
            '5dcf214d164f38875417b7f3472781cd3854c05c61a5090dc79835cec580b0c7'
            '7916ca1a625613a160f09e6c6f3331fac21b63758e736839b25afc4aa9ce912a')

apply_patch_with_msg() {
  for _patch in "$@"
  do
    msg2 "Applying ${_patch}"
    patch -Nbp1 -i "${srcdir}/${_patch}"
  done
}

prepare() {
  cd "${srcdir}/${_realname}-${pkgver}"
  apply_patch_with_msg \
    "0001-version.patch" \
    "0002-langinfo.patch"
}

build() {
  mkdir -p "build-${MSYSTEM}"
  cd "build-${MSYSTEM}"

  LDFLAGS="-Wl,--export-all-symbols" \
  MSYS2_ARG_CONV_EXCL="--prefix=" \
  meson setup \
    --prefix="${MINGW_PREFIX}" \
    --buildtype=plain \
    ../${_realname}-${pkgver}

  meson compile
}

package() {
  cd "${srcdir}/build-${MSYSTEM}"

  DESTDIR="${pkgdir}" meson install

  cd "${pkgdir}${MINGW_PREFIX}"
  find . -name "*.a" -exec rm {} +
  rm -rf include
  rm -rf share/vala
}
