# Contributor: Kreijstal <kreijstal@hotmail.com>

_realname=libretro-overlays
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=r1.c6ba6c4
pkgrel=1
pkgdesc='Collection of on-screen controller overlays for RetroArch (mingw-w64)'
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://www.libretro.com/'
msys2_repository_url='https://github.com/libretro/common-overlays'
license=('spdx:CC-BY-4.0')
groups=("${MINGW_PACKAGE_PREFIX}-libretro")
depends=()
makedepends=("git")
optdepends=("${MINGW_PACKAGE_PREFIX}-retroarch: frontend that consumes these overlays")
_commit=c6ba6c4b52d03ea3eded3c6f4d530574d6dfe0fa
source=("common-overlays::git+https://github.com/libretro/common-overlays.git#commit=${_commit}")
sha256sums=('e49a1e1c5b4a82f3d41db0fbb518d6f569e4991b521b6d38ee9a94c22eed9355')

pkgver() {
  cd common-overlays
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
  install -d "${pkgdir}${MINGW_PREFIX}/share/libretro"
  cp -r common-overlays "${pkgdir}${MINGW_PREFIX}/share/libretro/overlays"

  rm -rf "${pkgdir}${MINGW_PREFIX}/share/libretro/overlays/.git" \
         "${pkgdir}${MINGW_PREFIX}/share/libretro/overlays/.gitlab-ci.yml"
}
