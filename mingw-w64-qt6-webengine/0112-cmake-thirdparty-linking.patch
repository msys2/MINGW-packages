diff --git a/src/core/CMakeLists.txt b/src/core/CMakeLists.txt
index eb83a82..4b3103e 100644
--- a/src/core/CMakeLists.txt
+++ b/src/core/CMakeLists.txt
@@ -657,6 +657,36 @@ add_gn_build_artifacts_to_target(
     NINJA_STAMP QtWebEngineCore.stamp
     ${dataStampOption}
 )
+if (DEFINED QTWEBENGINE_THIRDPARTY_ARCHIVE_LIST_FILE AND EXISTS "${QTWEBENGINE_THIRDPARTY_ARCHIVE_LIST_FILE}")
+    set(_qtwebengineThirdPartyArchiveList
+        "${CMAKE_CURRENT_BINARY_DIR}/qtwebengine-thirdparty-archives-native.rsp")
+    file(STRINGS "${QTWEBENGINE_THIRDPARTY_ARCHIVE_LIST_FILE}" _qtwebengineThirdPartyArchives)
+    file(WRITE "${_qtwebengineThirdPartyArchiveList}" "")
+    foreach(_qtwebengineThirdPartyArchive IN LISTS _qtwebengineThirdPartyArchives)
+        if(MINGW AND _qtwebengineThirdPartyArchive MATCHES "^/")
+            execute_process(
+                COMMAND cygpath -m "${_qtwebengineThirdPartyArchive}"
+                OUTPUT_VARIABLE _qtwebengineThirdPartyArchiveNative
+                OUTPUT_STRIP_TRAILING_WHITESPACE)
+            file(APPEND "${_qtwebengineThirdPartyArchiveList}" "${_qtwebengineThirdPartyArchiveNative}\n")
+        else()
+            file(APPEND "${_qtwebengineThirdPartyArchiveList}" "${_qtwebengineThirdPartyArchive}\n")
+        endif()
+    endforeach()
+    if(MINGW)
+        target_link_options(WebEngineCore PRIVATE
+            "@${_qtwebengineThirdPartyArchiveList}" "-Wl,--end-group")
+    else()
+        target_link_options(WebEngineCore PRIVATE "@${_qtwebengineThirdPartyArchiveList}")
+    endif()
+endif()
+
+if (DEFINED QTWEBENGINE_THIRDPARTY_OBJECT_LIBRARY AND EXISTS "${QTWEBENGINE_THIRDPARTY_OBJECT_LIBRARY}")
+    target_link_libraries(WebEngineCore PRIVATE "${QTWEBENGINE_THIRDPARTY_OBJECT_LIBRARY}")
+endif()
+if (MINGW)
+    target_link_options(WebEngineCore PRIVATE "-Wl,--strip-debug" "-Wl,--no-keep-memory")
+endif()
 add_dependencies(WebEngineCore run_core_NinjaDone)
 if(COIN_BUG_699)
    set_property(TARGET WebEngineCore PROPERTY CXX_LINKER_LAUNCHER ${PROJECT_BINARY_DIR}/linker_ulimit.sh)
endif()
