apply_patch_with_msg() {
  for _patch in "$@"
  do
    msg2 "Applying ${_patch}"
    patch -Np1 -i "${srcdir}/${_patch}"
  done
}

prepare() {
  cd ${_pkgfn}

  apply_patch_with_msg \
    0001-cmake-configure-fixes.patch \
    0002-chromium-add-mingw-toolchain.patch \
    0003-chromium-base.patch \
    0004-chromium-chrome.patch \
    0005-chromium-components.patch \
    0006-chromium-content.patch \
    0007-chromium-device.patch \
    0008-chromium-gpu.patch \
    0009-chromium-media.patch \
    0010-chromium-net.patch \
    0011-chromium-sandbox.patch \
    0012-chromium-services.patch \
    0013-chromium-tools.patch \
    0014-chromium-ui.patch \
    0015-chromium-v8.patch \
    0016-chromium-others.patch

  sed -i 's@} else if (is_win) {@} else if (is_msvc) {@' \
    src/3rdparty/chromium/chrome/browser/updater/BUILD.gn
  grep -q '} else if (is_msvc) {' \
    src/3rdparty/chromium/chrome/browser/updater/BUILD.gn

  perl -0pi -e '
    s@#if BUILDFLAG\(IS_WIN\)\n(#include "content/browser/installedapp/fetch_related_win_apps_task\.h"\n#include "content/browser/installedapp/native_win_app_fetcher\.h"\n#include "content/browser/installedapp/native_win_app_fetcher_impl\.h"\n)#endif@#if BUILDFLAG(IS_MSVC)\n$1#endif  // BUILDFLAG(IS_MSVC)@;
    s@#if BUILDFLAG\(IS_WIN\)\n(std::unique_ptr<NativeWinAppFetcher> CreateNativeWinAppFetcher\(\) \{\n  return std::make_unique<NativeWinAppFetcherImpl>\(\);\n\})\n#endif  // BUILDFLAG\(IS_WIN\)@#if BUILDFLAG(IS_MSVC)\n$1\n#endif  // BUILDFLAG(IS_MSVC)@;
  ' src/3rdparty/chromium/content/browser/installedapp/installed_app_provider_impl.cc
  grep -q '#if BUILDFLAG(IS_MSVC)' \
    src/3rdparty/chromium/content/browser/installedapp/installed_app_provider_impl.cc

  perl -0pi -e '
    s@(\n  // Do not initialize DWriteFactory if the feature flag is enabled\n  // since this will conflict with the experimental font manager\.\n  // Fallback to only DWrite if running in single process mode, since there can\n  // only be a single font manager and the browser process always has a DWrite\n  // one\.\n  if \(!base::FeatureList::IsEnabled\(features::kFontDataServiceAllWebContents\) \|\|\n      command_line\.HasSwitch\(switches::kSingleProcess\)\) \{\n    InitializeDWriteFontProxy\(\);\n  \}\n)@\n#if defined(COMPILER_MSVC)$1#endif\n@;
    s@void RendererMainPlatformDelegate::PlatformUninitialize\(\) \{\n  UninitializeDWriteFontProxy\(\);\n\}@void RendererMainPlatformDelegate::PlatformUninitialize() {\n#if defined(COMPILER_MSVC)\n  UninitializeDWriteFontProxy();\n#endif\n}@;
  ' src/3rdparty/chromium/content/renderer/renderer_main_platform_delegate_win.cc
  grep -q 'COMPILER_MSVC' \
    src/3rdparty/chromium/content/renderer/renderer_main_platform_delegate_win.cc

  sed -i 's@#if BUILDFLAG(IS_WIN)$@#if BUILDFLAG(IS_MSVC)@' \
    src/3rdparty/chromium/content/utility/services.cc
  grep -q 'RunMediaFoundationServiceBroker' \
    src/3rdparty/chromium/content/utility/services.cc

  sed -i \
    -e 's@#if BUILDFLAG(IS_WIN)$@#if BUILDFLAG(IS_MSVC)@' \
    -e 's@#endif  // BUILDFLAG(IS_WIN)$@#endif  // BUILDFLAG(IS_MSVC)@' \
    src/3rdparty/chromium/gpu/command_buffer/service/shared_image/shared_image_factory.cc
  sed -i \
    -e 's@#elif BUILDFLAG(IS_WIN)$@#elif BUILDFLAG(IS_MSVC)@' \
    src/3rdparty/chromium/gpu/command_buffer/service/shared_image/shared_image_manager.cc
  grep -q 'BUILDFLAG(IS_MSVC)' \
    src/3rdparty/chromium/gpu/command_buffer/service/shared_image/shared_image_factory.cc

  perl -0pi -e '
    s@(\n    deps \+= \[ "//media/base/win:media_foundation_util" \]\n\n)    libs \+= \[\n      "dxguid\.lib",\n      "setupapi\.lib",\n      "winmm\.lib",\n      "mmdevapi\.lib",\n    \]@$1    if (is_mingw) {\n      sources -= [\n        "win/audio_low_latency_input_win.cc",\n        "win/audio_low_latency_input_win.h",\n        "win/audio_low_latency_output_win.cc",\n        "win/audio_low_latency_output_win.h",\n        "win/audio_manager_win.cc",\n        "win/audio_manager_win.h",\n        "win/audio_session_event_listener_win.cc",\n        "win/audio_session_event_listener_win.h",\n      ]\n      libs += [\n        "dxguid",\n        "ksuser",\n        "setupapi",\n        "winmm",\n        "mmdevapi",\n      ]\n    } else {\n      libs += [\n        "dxguid.lib",\n        "setupapi.lib",\n        "winmm.lib",\n        "mmdevapi.lib",\n      ]\n    }@;
  ' src/3rdparty/chromium/media/audio/BUILD.gn
  grep -q 'ksuser' \
    src/3rdparty/chromium/media/audio/BUILD.gn

  sed -i \
    -e 's@#elif BUILDFLAG(IS_WIN)$@#elif BUILDFLAG(IS_MSVC)@' \
    src/3rdparty/chromium/media/capture/video/video_capture_buffer_tracker_factory_impl.cc

  sed -i \
    -e 's@#if BUILDFLAG(IS_WIN)$@#if BUILDFLAG(IS_MSVC)@' \
    src/3rdparty/chromium/media/gpu/gpu_video_encode_accelerator_factory.cc

  perl -0pi -e '
    s@(  hr = SetDebugName\(texture\.Get\(\), "D3D11Decoder_ConfiguratorOutput"\);\n  if \(FAILED\(hr\)\)\n    return D3D11Status\(D3D11Status::Codes::kCreateDecoderOutputTextureFailed, hr\);\n)@#if defined(COMPILER_MSVC)\n$1#endif\n@;
  ' src/3rdparty/chromium/media/gpu/windows/d3d11_decoder_configurator.cc
  grep -q 'D3D11Decoder_ConfiguratorOutput' \
    src/3rdparty/chromium/media/gpu/windows/d3d11_decoder_configurator.cc

  sed -i \
    -e 's@#if BUILDFLAG(IS_WIN)$@#if BUILDFLAG(IS_MSVC)@' \
    -e 's@#endif  // BUILDFLAG(IS_WIN)$@#endif  // BUILDFLAG(IS_MSVC)@' \
    src/3rdparty/chromium/services/webnn/webnn_context_provider_impl.cc
  grep -q 'BUILDFLAG(IS_MSVC)' \
    src/3rdparty/chromium/services/webnn/webnn_context_provider_impl.cc
  perl -0pi -e '
    s@(\n    deps \+= \[ "//third_party/onnxruntime_headers" \]\n)\n    libs \+= \[ "runtimeobject\.lib" \]@$1\n    if (is_mingw) {\n      libs = [ "runtimeobject" ]\n    } else {\n      libs = [ "runtimeobject.lib" ]\n    }@
  ' src/3rdparty/chromium/services/webnn/BUILD.gn

  perl -0pi -e '
    s@(\n    deps \+= \[\n      "//components/headless/screen_info",\n      "//ui/gfx/mojom:dxgi_info",\n    \]\n)    libs = \[ "shcore\.lib" \]\n    ldflags = \[ "/DELAYLOAD:shcore\.dll" \]@$1    if (is_mingw) {\n      libs = [ "shcore" ]\n    } else {\n      libs = [ "shcore.lib" ]\n      ldflags = [ "/DELAYLOAD:shcore.dll" ]\n    }@;
  ' src/3rdparty/chromium/ui/display/BUILD.gn
  grep -q 'libs = \[ "shcore" \]' \
    src/3rdparty/chromium/ui/display/BUILD.gn

  perl -0pi -e '
    s@    libs = \[\n      "setupapi\.lib",\n      "dwmapi\.lib",\n      "dwrite\.lib",\n      "onecore\.lib",\n    \]@    if (is_mingw) {\n      libs = [\n        "setupapi",\n        "dwmapi",\n        "dwrite",\n        "onecore",\n      ]\n    } else {\n      libs = [\n        "setupapi.lib",\n        "dwmapi.lib",\n        "dwrite.lib",\n        "onecore.lib",\n      ]\n    }@;
  ' src/3rdparty/chromium/ui/gfx/BUILD.gn
  grep -q '"onecore"' \
    src/3rdparty/chromium/ui/gfx/BUILD.gn

  perl -0pi -e '
    s@(base::expected<void, CommitError> DCLayerTree::CommitAndClearPendingOverlays\(\n    std::vector<std::unique_ptr<DCLayerOverlayParams>> overlays\) \{\n)@$1#if !defined(COMPILER_GCC)\n@;
  ' src/3rdparty/chromium/ui/gl/dc_layer_tree.cc
  grep -q 'missing Microsoft::WRL::ComPtr<IDXGISwapChain1>\|#if !defined(COMPILER_GCC)' \
    src/3rdparty/chromium/ui/gl/dc_layer_tree.cc

  perl -0pi -e '
    s@(  ink_layer\.overlay_image = DCLayerOverlayImage\(presentation_area_enclosed_size,\n                                           delegated_ink_trail_\);\n)@#if !defined(COMPILER_GCC)\n$1#endif\n@;
  ' src/3rdparty/chromium/ui/gl/delegated_ink_point_renderer_gpu.cc

  perl -0pi -e '
    s@(\n  TRACE_EVENT0\("gpu", "VSyncProviderWinDComp::GetVSyncParametersIfAvailable"\);)@\n#if !defined(COMPILER_GCC)$1@;
    s@(  return true;\n\}\n\nbool VSyncProviderWinDComp::SupportGetVSyncParametersIfAvailable\(\) const \{)@  return true;\n#else\n  return false;\n#endif\n}\n\nbool VSyncProviderWinDComp::SupportGetVSyncParametersIfAvailable() const {@;
  ' src/3rdparty/chromium/ui/gl/vsync_provider_win_dcomp.cc
  grep -q 'COMPILER_GCC' \
    src/3rdparty/chromium/ui/gl/vsync_provider_win_dcomp.cc

  sed -i \
    -e 's@is_linux || is_chromeos || is_android || current_os == "aix"@is_linux || is_mingw || is_chromeos || is_android || current_os == "aix"@' \
    -e 's@if (is_clang && show_includes) {@if (is_clang \&\& !is_mingw \&\& show_includes) {@' \
    -e 's@if (current_os != "aix" && current_os != "zos") {@if (!is_mingw \&\& current_os != "aix" \&\& current_os != "zos") {@' \
    src/3rdparty/chromium/build/config/compiler/BUILD.gn
  perl -0pi -e 's@config\("symbol_visibility_hidden"\) \{\n  cflags = \[ "-fvisibility=hidden" \]@config("symbol_visibility_hidden") {\n  if (!is_mingw) {\n    cflags = [ "-fvisibility=hidden" ]\n  }@' \
    src/3rdparty/chromium/build/config/gcc/BUILD.gn
  perl -0pi -e 's@(all_dependent_configs \+= \[ "//third_party/perfetto/gn:public_config" \]\n\n)    if \(is_win\) \{@$1    if (is_msvc) {@' \
    src/3rdparty/chromium/base/BUILD.gn
  perl -0pi -e '
    s@    jumbo_excluded_sources = \[\n      "platform_sensor_provider_winrt\.cc",\n      "platform_sensor_reader_winrt\.cc",\n    \]@    if (!is_mingw) {\n      jumbo_excluded_sources = [\n        "platform_sensor_provider_winrt.cc",\n        "platform_sensor_reader_winrt.cc",\n      ]\n    }@;
    s@(\n    if \(!is_mingw\) \{\n      jumbo_excluded_sources = \[\n        "platform_sensor_provider_winrt\.cc",\n        "platform_sensor_reader_winrt\.cc",\n      \]\n    \})@$1\n\n    if (is_mingw) {\n      mingw_sources = sources\n      sources = []\n      sources += filter_exclude(mingw_sources, [\n        "platform_sensor_provider_winrt.cc",\n        "platform_sensor_provider_winrt.h",\n        "platform_sensor_reader_winrt.cc",\n        "platform_sensor_reader_winrt.h",\n      ])\n    }@;
    s@    libs = \[\n      "portabledeviceguids\.lib",\n      "sensorsapi\.lib",\n    \]@    if (is_mingw) {\n      libs = [\n        "portabledeviceguids",\n        "sensorsapi",\n      ]\n    } else {\n      libs = [\n        "portabledeviceguids.lib",\n        "sensorsapi.lib",\n      ]\n    }@;
  ' src/3rdparty/chromium/services/device/generic_sensor/BUILD.gn
  grep -q 'filter_exclude(mingw_sources' \
    src/3rdparty/chromium/services/device/generic_sensor/BUILD.gn

  perl -0pi -e '
    s@#if QT_VERSION < QT_VERSION_CHECK\(6, 11, 0\)\n(?=#if defined\(Q_STATIC_LOGGING_CATEGORY\))@@;
    s@(#define Q_WEBENGINE_LOGGING_CATEGORY\(name, \.\.\.\) Q_LOGGING_CATEGORY\(name, __VA_ARGS__\)\n#endif\n)#endif\n@$1@;
  ' src/core/api/qtwebenginecoreglobal_p.h

  sed -i 's@#include <dxcore.h>@#include <directx/dxcore.h>@g; s@_uuidof(ID3D12Device)@__uuidof(ID3D12Device)@g' \
    src/3rdparty/chromium/gpu/config/gpu_info_collector_win.cc

  grep -rlZ --include='*.cc' --include='*.cpp' --include='*.h' --include='*.hpp' 'v8/include/' \
    src/3rdparty/chromium \
    | xargs -0 -r sed -i 's@#include "\([^"]*\)v8/include/@#include "\1@g; s@#include <\([^>]*\)v8/include/@#include <\1@g'

  apply_patch_with_msg \
    0101-chromium-third-party-angle.patch \
    0102-chromium-third-party-blink.patch \
    0103-chromium-third-party-breakpad.patch \
    0104-chromium-third-party-crashpad.patch \
    0105-chromium-third-party-ffmpeg.patch \
    0106-chromium-third-party-pdfium.patch \
    0107-chromium-third-party-perfetto.patch \
    0108-chromium-third-party-skia.patch \
    0109-chromium-third-party-vulkan.patch \
    0110-chromium-third-party-webrtc.patch \
    0111-chromium-third-party-others.patch

  perl -0pi -e 's@import optparse\nimport shlex@import os\nimport optparse\nimport shlex@' \
    src/3rdparty/chromium/third_party/blink/renderer/bindings/scripts/collect_idl_files.py
  perl -0pi -e 's@    for filepath in filepaths:\n        ast_group.add_ast_node\(idl_parser.ParseFile\(parser, filepath\)\)@    private_chromium_dir = os.environ.get("QTWEBENGINE_PRIVATE_CHROMIUM_DIR")\n    if not private_chromium_dir:\n        private_chromium_dir = os.path.abspath(os.path.join(\n            os.path.dirname(__file__), "..", "..", "..", "..", ".."))\n\n    def _use_private_chromium_path(filepath):\n        if os.path.exists(filepath):\n            return filepath\n        normalized_path = filepath.replace("\\\\", "/")\n        third_party_marker = "/third_party/"\n        marker_index = normalized_path.find(third_party_marker)\n        if marker_index < 0:\n            return filepath\n        private_path = os.path.join(\n            private_chromium_dir,\n            normalized_path[marker_index + 1:].replace("/", os.sep))\n        if os.path.exists(private_path):\n            return private_path\n        return filepath\n\n    for filepath in filepaths:\n        ast_group.add_ast_node(idl_parser.ParseFile(\n            parser, _use_private_chromium_path(filepath)))@' \
    src/3rdparty/chromium/third_party/blink/renderer/bindings/scripts/collect_idl_files.py
  grep -q '_use_private_chromium_path' \
    src/3rdparty/chromium/third_party/blink/renderer/bindings/scripts/collect_idl_files.py

  apply_patch_with_msg \
    0201-gn-mingw-fixes.patch

  apply_patch_with_msg \
    0112-cmake-thirdparty-linking.patch

  rm -rf src/3rdparty/chromium/third_party
  rsync -a \
    "${MINGW_PREFIX}/share/qt6-webengine-private/chromium/third_party" \
    src/3rdparty/chromium/
  find src/3rdparty/chromium/third_party -type f \
    \( -name '*.c' -o -name '*.cc' -o -name '*.cpp' -o -name '*.cxx' \) \
    -delete

  rm -rf src/3rdparty/chromium/v8/include
  rsync -a \
    "${MINGW_PREFIX}/share/qt6-webengine-private/chromium/v8/include" \
    src/3rdparty/chromium/v8/

  find src/3rdparty/chromium -type f \( -name '*.gn' -o -name '*.gni' \) -print0 \
    | xargs -0 sed -i \
      -e 's@"pdh\.lib"@"pdh"@g' \
      -e 's@"crypt32\.lib"@"crypt32"@g' \
      -e 's@"d3d11\.lib"@"d3d11"@g' \
      -e 's@"dxgi\.lib"@"dxgi"@g' \
      -e 's@"dcomp\.lib"@"dcomp"@g'

  cat > src/3rdparty/chromium/build/config/qtwebengine_private_paths.gni <<'EOF'
declare_args() {
  qtwebengine_private_chromium_include_dir = ""
  qtwebengine_private_tool_dir = ""
}
EOF
  local _private_chromium_dir="$(cygpath -m "${MINGW_PREFIX}/share/qt6-webengine-private/chromium")"
  local _private_tool_dir="$(cygpath -m "${MINGW_PREFIX}/lib/qt6-webengine-private/bin")"
  sed -i \
    -e "s@qtwebengine_private_chromium_include_dir = \"\"@qtwebengine_private_chromium_include_dir = \"${_private_chromium_dir}\"@" \
    -e "s@qtwebengine_private_tool_dir = \"\"@qtwebengine_private_tool_dir = \"${_private_tool_dir}\"@" \
    src/3rdparty/chromium/build/config/qtwebengine_private_paths.gni

  sed -i \
    -e '/deps = \[ qtwebengine_target \]/c\    deps = [\n      qtwebengine_target,\n      "//third_party/perfetto/src/protozero/protoc_plugin:cppgen_plugin",\n      "//third_party/perfetto/src/protozero/protoc_plugin:protozero_plugin",\n    ]' \
    src/3rdparty/chromium/BUILD.gn
  sed -i '/import("\/\/build\/config\/qtwebengine_private_paths.gni")/d' \
    src/3rdparty/chromium/third_party/protobuf/proto_library.gni
  sed -i '/import("\/\/build\/config\/sanitizers\/sanitizers.gni")/a import("//build/config/qtwebengine_private_paths.gni")' \
    src/3rdparty/chromium/third_party/protobuf/proto_library.gni
  perl -0pi -e 's@(    if \(defined\(invoker\.import_dirs\)\) \{\n      foreach\(path, invoker\.import_dirs\) \{\n        args \+= \[ "--import-dir=" \+ rebase_path\(path, root_build_dir\) \]\n      \}\n    \}\n)@$1\n    if (defined(invoker.import_dirs) && qtwebengine_private_chromium_include_dir != "") {\n      args += [ "--import-dir=" + rebase_path(qtwebengine_private_chromium_include_dir, root_build_dir) ]\n    }\n@s' \
    src/3rdparty/chromium/third_party/protobuf/proto_library.gni
  perl -0pi -e 's@static const PolicyFunctions& GetPolicyFunctions\\(\\) \\{@static PolicyFunctions GetPolicyFunctions() {@; s@\\n    static const PolicyFunctions value = \\{@\n    return {@; s@\\};\\n    return value;@};@' \
    src/3rdparty/chromium/third_party/abseil-cpp/absl/container/internal/raw_hash_set.h
  grep -rl '/wd4201' src/3rdparty/chromium/third_party/crashpad/crashpad --include=BUILD.gn | \
    xargs -r sed -i '/\/wd4201/d'
  perl -0pi -e 's@\n\s*if \(crashpad_is_win\) \{\n\s*cflags =\s*\n\s*\}@@g' \
    src/3rdparty/chromium/third_party/crashpad/crashpad/tools/BUILD.gn
  if [ -f src/3rdparty/chromium/content/browser/renderer_host/input/BUILD.gn ]; then
    sed -i '/stylus_handwriting_controller_win\.\(cc\|h\)/d' \
      src/3rdparty/chromium/content/browser/renderer_host/input/BUILD.gn
  fi
  if [ -f src/3rdparty/chromium/content/browser/renderer_host/input/stylus_handwriting_controller_win.h ]; then
    perl -0pi -e 's@#include <ShellHandwriting\.h>@#if defined(COMPILER_MSVC)\n#include <ShellHandwriting.h>\n#endif@' \
      src/3rdparty/chromium/content/browser/renderer_host/input/stylus_handwriting_controller_win.h
  fi
  sed -i \
    -e 's@enable_js_protobuf = !is_cronet_build@enable_js_protobuf = false@' \
    -e 's@generate_javascript = invoker.generate_javascript@generate_javascript = invoker.generate_javascript \&\& enable_js_protobuf@' \
    -e 's@invoker.generate_typescript \&\& enable_js_protobuf@invoker.generate_typescript@' \
    src/3rdparty/chromium/third_party/protobuf/proto_library.gni
  sed -i '/import("\/\/build\/config\/qtwebengine_private_paths.gni")/d' \
    src/3rdparty/chromium/third_party/blink/public/devtools_protocol/BUILD.gn
  sed -i '1a import("//build/config/qtwebengine_private_paths.gni")' \
    src/3rdparty/chromium/third_party/blink/public/devtools_protocol/BUILD.gn
  perl -0pi -e 's@_inspector_protocol_dir = "//third_party/inspector_protocol"\n_protocol_out_dir@if (qtwebengine_private_chromium_include_dir != "") {\n  _inspector_protocol_dir = qtwebengine_private_chromium_include_dir + "/third_party/inspector_protocol"\n  _browser_protocol_pdl = qtwebengine_private_chromium_include_dir + "/third_party/blink/public/devtools_protocol/browser_protocol.pdl"\n  _browser_protocol_compat_json = qtwebengine_private_chromium_include_dir + "/third_party/blink/public/devtools_protocol/browser_protocol-1.3.json"\n} else {\n  _inspector_protocol_dir = "//third_party/inspector_protocol"\n  _browser_protocol_pdl = "browser_protocol.pdl"\n  _browser_protocol_compat_json = "browser_protocol-1.3.json"\n}\n_protocol_out_dir@' \
    src/3rdparty/chromium/third_party/blink/public/devtools_protocol/BUILD.gn
  sed -i \
    -e 's@"browser_protocol.pdl"@_browser_protocol_pdl@g' \
    -e 's@"browser_protocol-1.3.json"@_browser_protocol_compat_json@g' \
    src/3rdparty/chromium/third_party/blink/public/devtools_protocol/BUILD.gn
  sed -i \
    -e 's@_browser_protocol_pdl = _browser_protocol_pdl@_browser_protocol_pdl = "browser_protocol.pdl"@' \
    -e 's@_browser_protocol_compat_json = _browser_protocol_compat_json@_browser_protocol_compat_json = "browser_protocol-1.3.json"@' \
    src/3rdparty/chromium/third_party/blink/public/devtools_protocol/BUILD.gn

  sed -i \
    -e 's@enable_widevine=true@enable_widevine=false@g' \
    -e 's@devtools_dcheck_always_on=true@devtools_dcheck_always_on=false@g' \
    src/core/CMakeLists.txt

  perl -0pi -e 's@const srcPath = path\.join\(process\.cwd\(\), src\);\nconst destPath = path\.join\(process\.cwd\(\), dest\);@const srcPath = path.isAbsolute(src) ? src : path.join(process.cwd(), src);\nconst destPath = path.isAbsolute(dest) ? dest : path.join(process.cwd(), dest);@' \
    src/3rdparty/chromium/third_party/devtools-frontend/src/scripts/build/ninja/copy-file.js
  grep -q 'path.isAbsolute(src)' \
    src/3rdparty/chromium/third_party/devtools-frontend/src/scripts/build/ninja/copy-file.js
  perl -0pi -e 's@const originalFrontendMappedLocation =\n    path\.relative\(path\.dirname\(tsconfigLocation\), path\.join\(process\.cwd\(\), originalFileLocation\)\);@const originalPath = path.isAbsolute(originalFileLocation) || /^[A-Za-z]:[\\\\/]/.test(originalFileLocation) ?\n    originalFileLocation :\n    path.join(process.cwd(), originalFileLocation);\nconst originalFrontendMappedLocation =\n    path.relative(path.dirname(tsconfigLocation), originalPath);@' \
    src/3rdparty/chromium/third_party/devtools-frontend/src/scripts/build/ninja/generate-tsconfig.js
  grep -q 'path.isAbsolute(originalFileLocation)' \
    src/3rdparty/chromium/third_party/devtools-frontend/src/scripts/build/ninja/generate-tsconfig.js
}
build() {
  local _build_tmp="${srcdir}/build-tmp-${MSYSTEM}"
  rm -rf "${_build_tmp}"
  install -d "${_build_tmp}"
  export TMPDIR="${_build_tmp}"
  export TMP="${_build_tmp}"
  export TEMP="${_build_tmp}"
  export NODEJS_EXECUTABLE="${MINGW_PREFIX}/bin/node.exe"

  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
  cmake -Wno-dev \
    -GNinja \
    -DCMAKE_BUILD_TYPE=RelWithDebInfo \
    -DCMAKE_INSTALL_PREFIX=${MINGW_PREFIX} \
    -DPython3_EXECUTABLE=${MINGW_PREFIX}/bin/python \
    -DQT_FEATURE_qtpdf_build=OFF \
    -DQT_FEATURE_webengine_webrtc=OFF \
    -DQT_FEATURE_webenginedriver=OFF \
    -DQT_FEATURE_webengine_system_ffmpeg=ON \
    -DQT_FEATURE_webengine_system_freetype=ON \
    -DQT_FEATURE_webengine_system_harfbuzz=ON \
    -DQT_FEATURE_webengine_system_icu=ON \
    -DQT_FEATURE_webengine_system_lcms2=ON \
    -DQT_FEATURE_webengine_system_libjpeg=ON \
    -DQT_FEATURE_webengine_system_libopenjpeg2=ON \
    -DQT_FEATURE_webengine_system_libpng=ON \
    -DQT_FEATURE_webengine_system_libtiff=ON \
    -DQT_FEATURE_webengine_system_libvpx=ON \
    -DQT_FEATURE_webengine_system_libwebp=ON \
    -DQT_FEATURE_webengine_system_libxml=ON \
    -DQT_FEATURE_webengine_system_minizip=ON \
    -DQT_FEATURE_webengine_system_openh264=ON \
    -DQT_FEATURE_webengine_system_opus=ON \
    -DQT_FEATURE_webengine_system_re2=ON \
    -DQT_FEATURE_webengine_system_snappy=ON \
    -DQT_FEATURE_webengine_system_zlib=ON \
    -DQTWEBENGINE_THIRDPARTY_ARCHIVE_LIST_FILE="${MINGW_PREFIX}/lib/qt6-webengine-private/qtwebengine-thirdparty-archives.rsp" \
    -DQTWEBENGINE_THIRDPARTY_OBJECT_LIBRARY="${MINGW_PREFIX}/lib/qt6-webengine-private/libQt6WebEngineThirdPartyObjects.a" \
    -DQT_SHOW_EXTRA_IDE_SOURCES=OFF \
    -S ${_pkgfn} \
    -B build-${MSYSTEM}

  cmake --build build-${MSYSTEM}
}

package_qt6-webengine() {
  depends+=("${MINGW_PACKAGE_PREFIX}-qt6-base"
            "${MINGW_PACKAGE_PREFIX}-qt6-declarative"
            "${MINGW_PACKAGE_PREFIX}-qt6-httpserver"
            "${MINGW_PACKAGE_PREFIX}-qt6-positioning"
            "${MINGW_PACKAGE_PREFIX}-qt6-webchannel")
  groups=("${MINGW_PACKAGE_PREFIX}-qt6")

  DESTDIR="${pkgdir}" cmake --install build-${MSYSTEM}

  install -d "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}"
  install -Dm644 ${_pkgfn}/LICENSES/* -t "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}"

  local PKGDIR_PREFIX_WIN=$(cygpath -m "${pkgdir}"${MINGW_PREFIX})
  local FAKE_PREFIX_FOR_REPLACE="@@QT_REAL_PREFIX/dir@@"

  find "${pkgdir}${MINGW_PREFIX}/lib" -type f \( -name '*.pri' -o -name '*.prl' \) \
      -exec sed -i -e "s|${PREFIX_WIN}|${FAKE_PREFIX_FOR_REPLACE}|g" {} \;

  find "${pkgdir}${MINGW_PREFIX}/lib/pkgconfig" -type f -name '*.pc' \
      -exec sed -i -e "s|${PREFIX_WIN}|${MINGW_PREFIX}|g" {} \;

  find "${pkgdir}${MINGW_PREFIX}/lib/pkgconfig" -type f -name '*.pc' \
      -exec sed -i -e "s|${PKGDIR_PREFIX_WIN}|${MINGW_PREFIX}|g" {} \;
}

# template start; name=mingw-w64-splitpkg-wrappers; version=1.0;
# vim: set ft=bash :

# generate wrappers
for _name in "${pkgname[@]}"; do
  _short="package_${_name#${MINGW_PACKAGE_PREFIX}-}"
  _func="$(declare -f "${_short}")"
  eval "${_func/#${_short}/package_${_name}}"
done
# template end;
