apply_patch_with_msg() {
  for _patch in "$@"
  do
    msg2 "Applying ${_patch}"
    patch -Np1 -i "${srcdir}/${_patch}"
  done
}

prepare() {
  cd ${_pkgfn}

  apply_patch_with_msg \
    0001-cmake-configure-fixes.patch \
    0002-chromium-add-mingw-toolchain.patch \
    0003-chromium-base.patch \
    0004-chromium-chrome.patch \
    0005-chromium-components.patch \
    0006-chromium-content.patch \
    0007-chromium-device.patch \
    0008-chromium-gpu.patch \
    0009-chromium-media.patch \
    0010-chromium-net.patch \
    0011-chromium-sandbox.patch \
    0012-chromium-services.patch \
    0013-chromium-tools.patch \
    0014-chromium-ui.patch \
    0015-chromium-v8.patch \
    0016-chromium-others.patch \
    0101-chromium-third-party-angle.patch \
    0102-chromium-third-party-blink.patch \
    0103-chromium-third-party-breakpad.patch \
    0104-chromium-third-party-crashpad.patch \
    0105-chromium-third-party-ffmpeg.patch \
    0106-chromium-third-party-pdfium.patch \
    0107-chromium-third-party-perfetto.patch \
    0108-chromium-third-party-skia.patch \
    0109-chromium-third-party-vulkan.patch \
    0110-chromium-third-party-webrtc.patch \
    0111-chromium-third-party-others.patch \
    0201-gn-mingw-fixes.patch \
    0112-cmake-thirdparty-linking.patch \
    0113-chromium-mingw-followup.patch

  local _private_third_party_source_dirs=(
    abseil-cpp agg23 angle bigint blink boringssl brotli ced cld_3 cpuinfo
    crashpad crc32c dav1d dawn emoji-segmenter expat fastfeat fdlibm fft flac
    g711 g722 getopt highway hunspell iaccessible2 ink ink_stroke_modeler inspector_protocol ipcz
    isimpledom leveldatabase libaddressinput libaom libavif libgav1 libsrtp
    libtess2 liburlpattern libwebm libxml libyuv lzma_sdk
    material_color_utilities metrics_proto modp_b64 nasm node one_euro_filter ooura
    ots pdfium perfetto pffft private-join-and-compute protobuf quiche rnnoise
    search_engines_data sigslot simdutf skia spl_sqrt_floor sqlite v8 vector
    vulkan_memory_allocator webrtc webrtc_overrides woff2 wuffs xxhash zlib zstd
  )

  rm -rf "${srcdir}/qtwebengine-private-third-party-keep"
  mkdir -p "${srcdir}/qtwebengine-private-third-party-keep"
  for _dir in "${_private_third_party_source_dirs[@]}"
  do
    if [[ -d "src/3rdparty/chromium/third_party/${_dir}" ]]; then
      mv "src/3rdparty/chromium/third_party/${_dir}" \
        "${srcdir}/qtwebengine-private-third-party-keep/"
    fi
  done

  rm -rf src/3rdparty/chromium/third_party
  rsync -a \
    "${MINGW_PREFIX}/share/qt6-webengine-private/chromium/third_party" \
    src/3rdparty/chromium/
  find src/3rdparty/chromium/third_party -type f \
    \( -name '*.c' -o -name '*.cc' -o -name '*.cpp' -o -name '*.cxx' \) \
    -delete
  for _dir in "${_private_third_party_source_dirs[@]}"
  do
    if [[ -d "${srcdir}/qtwebengine-private-third-party-keep/${_dir}" ]]; then
      rm -rf "src/3rdparty/chromium/third_party/${_dir}"
      mv "${srcdir}/qtwebengine-private-third-party-keep/${_dir}" \
        src/3rdparty/chromium/third_party/
    fi
  done

  rm -rf src/3rdparty/chromium/v8/include
  rsync -a \
    "${MINGW_PREFIX}/share/qt6-webengine-private/chromium/v8/include" \
    src/3rdparty/chromium/v8/

  msg2 "Applying 0114-chromium-private-protoc-tools.patch"
  patch -Np1 -i "${srcdir}/0114-chromium-private-protoc-tools.patch"

  msg2 "Applying 0115-chromium-private-brotli-tool.patch"
  patch -Np1 -i "${srcdir}/0115-chromium-private-brotli-tool.patch"

  msg2 "Applying 0116-chromium-system-flatc-tool.patch"
  patch -Np1 -i "${srcdir}/0116-chromium-system-flatc-tool.patch"

  msg2 "Applying 0118-chromium-system-jsoncpp-lib.patch"
  patch -Np1 -i "${srcdir}/0118-chromium-system-jsoncpp-lib.patch"

  msg2 "Applying 0119-chromium-histogram-script-path.patch"
  patch -Np1 -i "${srcdir}/0119-chromium-histogram-script-path.patch"

  msg2 "Applying 0120-chromium-crashpad-mingw-arm64-object.patch"
  patch -Np1 -i "${srcdir}/0120-chromium-crashpad-mingw-arm64-object.patch"

  msg2 "Applying 0121-chromium-nasm-native-paths.patch"
  patch -Np1 -i "${srcdir}/0121-chromium-nasm-native-paths.patch"

  msg2 "Applying 0122-chromium-delegated-ink-mingw.patch"
  patch -Np1 -i "${srcdir}/0122-chromium-delegated-ink-mingw.patch"

  msg2 "Applying 0123-chromium-dawn-tint-msvc-flags.patch"
  patch -Np1 -i "${srcdir}/0123-chromium-dawn-tint-msvc-flags.patch"

  msg2 "Applying 0124-chromium-abseil-policy-functions-mingw.patch"
  patch -Np1 -i "${srcdir}/0124-chromium-abseil-policy-functions-mingw.patch"

  msg2 "Applying 0125-chromium-d3d12-video-device-mingw.patch"
  patch -Np1 -i "${srcdir}/0125-chromium-d3d12-video-device-mingw.patch"

  msg2 "Applying 0126-chromium-mingw-link-followup.patch"
  patch -Np1 -i "${srcdir}/0126-chromium-mingw-link-followup.patch"
}

build() {
  local _build_tmp="${srcdir}/build-tmp-${MSYSTEM}"
  rm -rf "${_build_tmp}"
  install -d "${_build_tmp}"
  export TMPDIR="${_build_tmp}"
  export TMP="${_build_tmp}"
  export TEMP="${_build_tmp}"
  export NODEJS_EXECUTABLE="${MINGW_PREFIX}/bin/node.exe"
  local _debug_prefix="/usr/src/debug/${_realname}-${pkgver}"
  local _srcdir_win="$(cygpath -m "${srcdir}")"
  local _prefix_map_flags="-ffile-prefix-map=${srcdir}=${_debug_prefix} -ffile-prefix-map=${_srcdir_win}=${_debug_prefix}"
  export CFLAGS+=" ${_prefix_map_flags}"
  export CXXFLAGS+=" ${_prefix_map_flags}"
  export CPPFLAGS+=" ${_prefix_map_flags}"

  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
  cmake -Wno-dev \
    -GNinja \
    -DCMAKE_BUILD_TYPE=RelWithDebInfo \
    -DCMAKE_INSTALL_PREFIX=${MINGW_PREFIX} \
    -DPython3_EXECUTABLE=${MINGW_PREFIX}/bin/python \
    -DQT_FEATURE_qtpdf_build=OFF \
    -DQT_FEATURE_webengine_webrtc=OFF \
    -DQT_FEATURE_webenginedriver=OFF \
    -DQT_FEATURE_webengine_system_ffmpeg=ON \
    -DQT_FEATURE_webengine_system_freetype=ON \
    -DQT_FEATURE_webengine_system_harfbuzz=ON \
    -DQT_FEATURE_webengine_system_icu=ON \
    -DQT_FEATURE_webengine_system_lcms2=ON \
    -DQT_FEATURE_webengine_system_libjpeg=ON \
    -DQT_FEATURE_webengine_system_libopenjpeg2=ON \
    -DQT_FEATURE_webengine_system_libpng=ON \
    -DQT_FEATURE_webengine_system_libtiff=ON \
    -DQT_FEATURE_webengine_system_libvpx=ON \
    -DQT_FEATURE_webengine_system_libwebp=ON \
    -DQT_FEATURE_webengine_system_libxml=ON \
    -DQT_FEATURE_webengine_system_minizip=ON \
    -DQT_FEATURE_webengine_system_openh264=ON \
    -DQT_FEATURE_webengine_system_opus=ON \
    -DQT_FEATURE_webengine_system_re2=ON \
    -DQT_FEATURE_webengine_system_snappy=ON \
    -DQT_FEATURE_webengine_system_zlib=ON \
    -DQTWEBENGINE_THIRDPARTY_ARCHIVE_LIST_FILE="${MINGW_PREFIX}/lib/qt6-webengine-private/qtwebengine-thirdparty-archives.rsp" \
    -DQTWEBENGINE_THIRDPARTY_OBJECT_LIBRARY="${MINGW_PREFIX}/lib/qt6-webengine-private/libQt6WebEngineThirdPartyObjects.a" \
    -DQTWEBENGINE_PRIVATE_CHROMIUM_INCLUDE_DIR="$(cygpath -m "${MINGW_PREFIX}/share/qt6-webengine-private/chromium")" \
    -DQTWEBENGINE_PRIVATE_TOOL_DIR="$(cygpath -m "${MINGW_PREFIX}/lib/qt6-webengine-private/bin")" \
    -DQT_SHOW_EXTRA_IDE_SOURCES=OFF \
    -S ${_pkgfn} \
    -B build-${MSYSTEM}

  cmake --build build-${MSYSTEM}
}

package_qt6-webengine() {
  depends+=("${MINGW_PACKAGE_PREFIX}-qt6-base"
            "${MINGW_PACKAGE_PREFIX}-qt6-declarative"
            "${MINGW_PACKAGE_PREFIX}-qt6-httpserver"
            "${MINGW_PACKAGE_PREFIX}-qt6-positioning"
            "${MINGW_PACKAGE_PREFIX}-qt6-webchannel")
  groups=("${MINGW_PACKAGE_PREFIX}-qt6")

  DESTDIR="${pkgdir}" cmake --install build-${MSYSTEM}

  install -d "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}"
  install -Dm644 ${_pkgfn}/LICENSES/* -t "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}"

  rm -rf "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}"
  rm -f "${pkgdir}${MINGW_PREFIX}/lib/cmake/Qt6BuildInternals/StandaloneTests/QtWebEngineTestsConfig.cmake"

  local _replace_build_ref
  _replace_build_ref() {
    local _ref="$1"
    local _replacement="/usr/src/debug/${_realname}-${pkgver}"
    while ((${#_replacement} < ${#_ref})); do
      _replacement+="_"
    done
    if ((${#_replacement} == ${#_ref})); then
      python - "${_ref}" "${_replacement}" "${pkgdir}" <<'PY'
import os
import sys

needle = sys.argv[1].encode()
replacement = sys.argv[2].encode()
root = sys.argv[3]

for dirpath, _, filenames in os.walk(root):
    for filename in filenames:
        path = os.path.join(dirpath, filename)
        with open(path, "rb") as file:
            data = file.read()
        if needle in data:
            with open(path, "wb") as file:
                file.write(data.replace(needle, replacement))
PY
    fi
  }
  _replace_build_ref "${srcdir}"
  _replace_build_ref "$(cygpath -m "${srcdir}")"

  local PREFIX_WIN=$(cygpath -m "${MINGW_PREFIX}")
  local PKGDIR_PREFIX_WIN=$(cygpath -m "${pkgdir}"${MINGW_PREFIX})
  local FAKE_PREFIX_FOR_REPLACE="@@QT_REAL_PREFIX/dir@@"

  find "${pkgdir}${MINGW_PREFIX}/lib" -type f \( -name '*.pri' -o -name '*.prl' \) \
      -exec sed -i -e "s|${PREFIX_WIN}|${FAKE_PREFIX_FOR_REPLACE}|g" {} \;

  find "${pkgdir}${MINGW_PREFIX}/lib/pkgconfig" -type f -name '*.pc' \
      -exec sed -i -e "s|${PREFIX_WIN}|${MINGW_PREFIX}|g" {} \;

  find "${pkgdir}${MINGW_PREFIX}/lib/pkgconfig" -type f -name '*.pc' \
      -exec sed -i -e "s|${PKGDIR_PREFIX_WIN}|${MINGW_PREFIX}|g" {} \;
}

# template start; name=mingw-w64-splitpkg-wrappers; version=1.0;
# vim: set ft=bash :

# generate wrappers
for _name in "${pkgname[@]}"; do
  _short="package_${_name#${MINGW_PACKAGE_PREFIX}-}"
  _func="$(declare -f "${_short}")"
  eval "${_func/#${_short}/package_${_name}}"
done
# template end;
