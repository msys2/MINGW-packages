# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Specio
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=0.53
pkgrel=1
pkgdesc="Type constraints and coercions for Perl. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Specio"
msys2_repository_url="https://github.com/houseabsolute/Specio"
msys2_references=(
  'purl: pkg:cpan/DROLSKY/Specio'
)
license=('spdx:Artistic-2.0')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-clone"
         "${MINGW_PACKAGE_PREFIX}-perl-clone-choose"
         "${MINGW_PACKAGE_PREFIX}-perl-devel-stacktrace"
         "${MINGW_PACKAGE_PREFIX}-perl-eval-closure"
         "${MINGW_PACKAGE_PREFIX}-perl-mro-compat"
         "${MINGW_PACKAGE_PREFIX}-perl-role-tiny"
         "${MINGW_PACKAGE_PREFIX}-perl-test-fatal")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/D/DR/DROLSKY/${_perlname}-${pkgver}.tar.gz")
sha256sums=('0d0eecfb9e89bd0f5f710fac42e1200a882d513a862f98497eaef5927ac6c183')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" install
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
