# Contributor: Beat Bolli <dev@drbeat.li>

_realname=fmt
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=12.2.0
pkgrel=1
pkgdesc="A modern formatting library for C++ (mingw-w64)"
arch=('any')
mingw_arch=('mingw64' 'mingw32' 'ucrt64' 'clang64' 'clangarm64')
url="https://fmt.dev"
msys2_repository_url="https://github.com/fmtlib/fmt"
msys2_references=(
  'archlinux: fmt'
  "cpe: cpe:/a:fmt:fmt"
)
license=('spdx:MIT')
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-ninja")
source=("https://github.com/fmtlib/fmt/archive/${pkgver}/${_realname}-${pkgver}.tar.gz"
        cmake-dual-lib.patch
        fix-i686-builds.patch::https://github.com/fmtlib/fmt/commit/588b3a0f8f6a8bcf2a959cae882d5b2703e86737.patch)
sha256sums=('8b852bb5aa6e7d8564f9e81394055395dd1d1936d38dfd3a17792a02bebd7af0'
            '4bb54b9c1ae8b5c3bc336f859da6eb199f4f01bf0dd76d84840845da37e8656c'
            '174298371219375c3ff6932fabaac9d82b21fd9c0eedd10d1aaea578ee314f90')

prepare() {
  cd "${_realname}-${pkgver}"
  patch -Nbp1 -i "${srcdir}"/cmake-dual-lib.patch
  patch -Nbp1 -i "${srcdir}"/fix-i686-builds.patch
}

build() {
  declare -a _extra_config
  if check_option "debug" "n"; then
    _extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    _extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  # Shared Build
  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    cmake \
      -GNinja \
      -DCMAKE_INSTALL_PREFIX=${MINGW_PREFIX} \
      "${_extra_config[@]}" \
      -DBUILD_SHARED_LIBS=ON \
      -DCMAKE_DLL_NAME_WITH_SOVERSION=ON \
      -DFMT_TEST=OFF \
      -S ${_realname}-${pkgver} \
      -B build-${MSYSTEM}-shared

  cmake --build build-${MSYSTEM}-shared

  # Static Build
  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    cmake \
      -GNinja \
      -DCMAKE_INSTALL_PREFIX=${MINGW_PREFIX} \
      "${_extra_config[@]}" \
      -DBUILD_SHARED_LIBS=OFF \
      -DFMT_TEST=OFF \
      -S ${_realname}-${pkgver} \
      -B build-${MSYSTEM}-static

  cmake --build build-${MSYSTEM}-static
}

check() {
  cmake -DFMT_TEST=ON -S ${_realname}-${pkgver} -B build-${MSYSTEM}-shared
  cmake --build build-${MSYSTEM}-shared
  ctest --test-dir build-${MSYSTEM}-shared --output-on-failure
}

package() {
  # Static Install
  DESTDIR="${pkgdir}" cmake --install build-${MSYSTEM}-static

  # Shared Install
  DESTDIR="${pkgdir}" cmake --install build-${MSYSTEM}-shared

  # License
  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE
}
