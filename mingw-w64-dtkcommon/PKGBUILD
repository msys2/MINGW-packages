# Maintainer: Cloud <kt286@qq.com>

_realname=dtkcommon
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=6.7.46
pkgrel=1
pkgdesc='DTK common modules'
arch=('any')
mingw_arch=('ucrt64')
url="https://github.com/linuxdeepin/dtkcommon"
license=('LGPL3')
#depends=("${MINGW_PACKAGE_PREFIX}-dconf")
makedepends=("${MINGW_PACKAGE_PREFIX}-cmake" "${MINGW_PACKAGE_PREFIX}-ninja" "${MINGW_PACKAGE_PREFIX}-gcc")
provides=('dtkcommon')

source=("${_realname}-${pkgver}.tar.gz::https://github.com/linuxdeepin/dtkcommon/archive/refs/tags/${pkgver}.tar.gz")
sha512sums=('ee8c6d955bd5bf4335e41c66c53930621caeaff72137fd2a12eb4396bce093ff90296d45efdb7759ec914e25dd9c93843c1782694c9f2bd8765e77903873d154')

build() {
  mkdir -p "${srcdir}"/${_realname}-${pkgver}/build-${MSYSTEM} && cd "${srcdir}"/${_realname}-${pkgver}/build-${MSYSTEM}
  
  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    ${MINGW_PREFIX}/bin/cmake .. -GNinja \
      -DCMAKE_INSTALL_PREFIX=${MINGW_PREFIX} \
      -DCMAKE_PREFIX_PATH=${MINGW_PREFIX} \
      -DDTK_VERSION=${pkgver}
  ${MINGW_PREFIX}/bin/ninja
}

package() {
  cd "${srcdir}"/${_realname}-${pkgver}/build-${MSYSTEM}
  DESTDIR="${pkgdir}" ${MINGW_PREFIX}/bin/ninja install
}
