# Contributor: Kreijstal <kreijstal@hotmail.com>

_realname=libretro-shaders-glsl
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=r1.3f86ce7
pkgrel=1
pkgdesc='GLSL shaders for RetroArch (legacy GL2/GLES drivers) (mingw-w64)'
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://www.libretro.com/'
msys2_repository_url='https://github.com/libretro/glsl-shaders'
license=('spdx:GPL-3.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-libretro")
depends=()
makedepends=("git")
optdepends=("${MINGW_PACKAGE_PREFIX}-retroarch: frontend that consumes these shaders")
_commit=3f86ce75e7244aa9b3384e6f045fa2b74b97a7f5
source=("glsl-shaders::git+https://github.com/libretro/glsl-shaders.git#commit=${_commit}")
sha256sums=('1dcf3407533265caacd255cf30f43808fd9bf85798de96e109b7ad386cd3d709')

pkgver() {
  cd glsl-shaders
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
  install -d "${pkgdir}${MINGW_PREFIX}/share/libretro/shaders"
  cp -r glsl-shaders "${pkgdir}${MINGW_PREFIX}/share/libretro/shaders/shaders_glsl"

  rm -rf "${pkgdir}${MINGW_PREFIX}/share/libretro/shaders/shaders_glsl/.git" \
         "${pkgdir}${MINGW_PREFIX}/share/libretro/shaders/shaders_glsl/.gitlab-ci.yml"
}
