+struct SystemV8Config {
+  bin_dir: PathBuf,
+  lib_dir: PathBuf,
+  src_binding_path: PathBuf,
+}
+
+fn system_v8_config() -> Option<SystemV8Config> {
+  let target = env::var("TARGET").unwrap();
+  if !target.contains("windows-gnu") {
+    return None;
+  }
+
+  let root = env::var_os("MSYSTEM_PREFIX").map(PathBuf::from).unwrap();
+  let bin_dir = root.join("bin");
+  let lib_dir = root.join("lib");
+
+  // Hacky, but it works
+  let binding_name = match env::var("CARGO_CFG_TARGET_ARCH").unwrap().as_str() {
+    "aarch64" => "src_binding_release_aarch64-unknown-linux-gnu.rs",
+    "x86_64" => "src_binding_release_x86_64-unknown-linux-gnu.rs",
+    _ => panic!(),
+  };
+  let src_binding_path = get_dirs().root.join("gen").join(binding_name);
+  assert!(
+    src_binding_path.exists(),
+    "expected binding file at {}",
+    src_binding_path.display()
+  );
+
+  Some(SystemV8Config {
+    bin_dir,
+    lib_dir,
+    src_binding_path,
+  })
+}
+
+fn patched_system_binding_source() -> String {
+  fs::read_to_string("src/binding.cc").unwrap()
+}
+
+fn build_system_binding() {
+  let dir = static_lib_dir();
+  fs::create_dir_all(&dir).unwrap();
+  println!("cargo:rustc-link-search={}", dir.display());
+
+  let patched_binding = dir.join("binding_system.cc");
+  fs::write(&patched_binding, patched_system_binding_source()).unwrap();
+
+  let object = dir.join("binding_system.o");
+  let status = Command::new("c++")
+    .current_dir(get_dirs().root)
+    .arg("-std=c++20")
+    .arg("-I.")
+    .arg("-Isrc")
+    .arg("-Iv8")
+    .arg("-Iv8/include")
+    .arg("-c")
+    .arg(&patched_binding)
+    .arg("-o")
+    .arg(&object)
+    .status()
+    .unwrap();
+  assert!(status.success(), "failed to compile {patched_binding:?}");
+
+  let static_lib = static_lib_path();
+  if static_lib.exists() {
+    fs::remove_file(&static_lib).unwrap();
+  }
+
+  let status = Command::new("ar")
+    .arg("crs")
+    .arg(&static_lib)
+    .arg(&object)
+    .status()
+    .unwrap();
+  assert!(status.success(), "failed to archive {static_lib:?}");
+}
+
+fn print_system_src_binding_path(system_v8: &SystemV8Config) {
+  println!(
+    "cargo:rustc-env=RUSTY_V8_SRC_BINDING_PATH={}",
+    system_v8.src_binding_path.display()
+  );
+}
+
+fn print_system_link_flags(system_v8: &SystemV8Config) {
+  println!("cargo:rustc-link-lib=static=rusty_v8");
+  println!(
+    "cargo:rustc-link-search=native={}",
+    system_v8.lib_dir.display()
+  );
+  println!(
+    "cargo:rustc-env=CODEX_SYSTEM_V8_BIN_DIR={}",
+    system_v8.bin_dir.display()
+  );
+  println!("cargo:rustc-link-lib=dylib=v8");
+  println!("cargo:rustc-link-lib=dylib=v8_libbase");
+  println!("cargo:rustc-link-lib=dylib=v8_libplatform");
+  println!("cargo:rustc-link-lib=dylib=icuuc");
+  println!("cargo:rustc-link-lib=dylib=icuin");
+
+  // It's duplicated, but if removed, it errors on linking
+  if let Ok(stdlib) = env::var("CXXSTDLIB") {
+    if !stdlib.is_empty() {
+      println!("cargo:rustc-link-lib=dylib={stdlib}");
+    }
+  } else {
+    println!("cargo:rustc-link-lib=dylib=c++");
+  }
+}
+
