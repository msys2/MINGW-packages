# Contributor: Kreijstal <kreijstal@hotmail.com>

_realname=solvespace
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=3.2
pkgrel=1
pkgdesc='Parametric 2d/3d CAD (mingw-w64)'
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url='https://solvespace.com'
msys2_repository_url='https://github.com/solvespace/solvespace'
msys2_changelog_url='https://github.com/solvespace/solvespace/blob/master/CHANGELOG.md'
msys2_references=(
  'archlinux: solvespace'
  'cpe: cpe:/a:solvespace:solvespace'
)
license=('spdx:GPL-3.0-or-later')
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-ninja")
source=("https://github.com/solvespace/solvespace/releases/download/v${pkgver}/${_realname}-${pkgver}.tar.xz")
sha256sums=('d93e816667b6c6f05fabc3f3cb6d783fad2a3805c46d24e28f2ebd91bc36de76')
# extlib/pixman/.gitlab-ci.d contains symlinks that bsdtar can't create on
# Windows; extract by hand and discard those errors. The dir is dev-only.
noextract=("${_realname}-${pkgver}.tar.xz")

prepare() {
  cd "${srcdir}"
  bsdtar -xf "${_realname}-${pkgver}.tar.xz" \
    --exclude="${_realname}-${pkgver}/extlib/pixman/.gitlab-ci.d"
}

build() {
  declare -a _extra_config
  if check_option "debug" "n"; then
    _extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    _extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  # On clangarm64, the in-tree ANGLE (OpenGL ES → DirectX translation layer)
  # does not compile. Use system OpenGL (provided by Windows on ARM) instead.
  if [[ "${MSYSTEM}" == "CLANGARM64" ]]; then
    _extra_config+=("-DOPENGL=1")
  fi

  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    "${MINGW_PREFIX}/bin/cmake.exe" \
      -GNinja \
      -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
      "${_extra_config[@]}" \
      -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
      -DENABLE_TESTS=OFF \
      -DENABLE_COVERAGE=OFF \
      -S "${_realname}-${pkgver}" \
      -B "build-${MSYSTEM}"

  "${MINGW_PREFIX}/bin/cmake.exe" --build "build-${MSYSTEM}"
}

package() {
  # cmake --install picks up the libslvs install rule (import lib +
  # header) but its install(TARGETS slvs ...) lacks a RUNTIME line, so
  # the DLL itself is dropped on Windows. install(TARGETS solvespace ...)
  # is also gated on NOT (WIN32 OR APPLE OR EMSCRIPTEN). Both need a
  # manual hand-off.
  DESTDIR="${pkgdir}" "${MINGW_PREFIX}/bin/cmake.exe" --install "build-${MSYSTEM}"

  install -Dm755 "${srcdir}/build-${MSYSTEM}/bin/solvespace.exe" \
    "${pkgdir}${MINGW_PREFIX}/bin/solvespace.exe"
  install -Dm755 "${srcdir}/build-${MSYSTEM}/bin/solvespace-cli.exe" \
    "${pkgdir}${MINGW_PREFIX}/bin/solvespace-cli.exe"
  install -Dm755 "${srcdir}/build-${MSYSTEM}/bin/libslvs.dll" \
    "${pkgdir}${MINGW_PREFIX}/bin/libslvs.dll"

  install -Dm644 "${srcdir}/${_realname}-${pkgver}/COPYING.txt" \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/COPYING.txt"
}
