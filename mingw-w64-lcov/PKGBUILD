_realname=lcov
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=2.5
pkgrel=1
pkgdesc="front-end for GCC's coverage testing tool gcov"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://github.com/linux-test-project/lcov"
msys2_repository_url='https://github.com/linux-test-project/lcov'
license=('spdx:GPL-2.0-or-later')
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-capture-tiny"
         "${MINGW_PACKAGE_PREFIX}-perl-datetime"
         "${MINGW_PACKAGE_PREFIX}-perl-devel-cover")
         #"${MINGW_PACKAGE_PREFIX}-perl-memory-process")
makedepends=("${MINGW_PACKAGE_PREFIX}-clang"
             "${MINGW_PACKAGE_PREFIX}-python-sphinx"
             "${MINGW_PACKAGE_PREFIX}-python-sphinx_rtd_theme")
optdepends=("${MINGW_PACKAGE_PREFIX}-python: enable extra support scripts"
            "${MINGW_PACKAGE_PREFIX}-python-coverage: enable python coverage reporting"
            "${MINGW_PACKAGE_PREFIX}-python-xslxwriter: generate shpreadsheet reports")
source=("https://github.com/linux-test-project/lcov/releases/download/v${pkgver}/${_realname}-${pkgver}.tar.gz")
sha256sums=('7e5e5a154bd5f3557659c328cab376764e7abd238bb403c424472c296b175126')

package() {
  cd "${srcdir}/${_realname}-${pkgver}"

  make LCOV_PERL_PATH="${MINGW_PREFIX}/bin/perl" PREFIX="${MINGW_PREFIX}" DESTDIR="${pkgdir}" install

  mkdir -p "${pkgdir}"${MINGW_PREFIX}/lib/perl5/site_perl
  cp "${pkgdir}"${MINGW_PREFIX}/lib/lcov/lcovutil.pm "${pkgdir}"${MINGW_PREFIX}/lib/perl5/site_perl/

  install -Dm644 COPYING "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE
}
