+  raw_hash_set& operator=(raw_hash_set&& that) noexcept(
+      AllocTraits::is_always_equal::value &&
+      std::is_nothrow_move_assignable<hasher>::value &&
+      std::is_nothrow_move_assignable<key_equal>::value) {
