-#if DCHECK_IS_ON()
-  VisualTreeValid(subtree_index_to_overlay, prev_subtree_is_attached_to_root);
-#endif  // DCHECK_IS_ON()
-
-  IDCompositionVisual2* left_sibling_visual = nullptr;
