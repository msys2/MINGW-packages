+IDXGISwapChain1* DCLayerTree::GetLayerSwapChainForTesting(
+    const gfx::OverlayLayerId& layer_id) const {
+  CHECK_IS_TEST();
+  if (video_swap_chains_.contains(layer_id)) {
+    return video_swap_chains_.at(layer_id)->swap_chain().Get();
+  }
+  return nullptr;
+}
