+  // a better match if non-const iterator is passed as an argument.
+  void erase(iterator it) {
+    ABSL_SWISSTABLE_ASSERT(capacity() > 0);
+    AssertNotDebugCapacity();
+    it.assert_is_full("erase()");
+    destroy(it.slot());
+    erase_meta_only(it);
