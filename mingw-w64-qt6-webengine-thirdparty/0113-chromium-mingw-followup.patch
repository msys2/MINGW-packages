-    hr = clip_visual_->AddVisual(rounded_corners_visual_.Get(), FALSE, nullptr);
-    CHECK_EQ(hr, S_OK);
-    hr = rounded_corners_visual_->AddVisual(transform_visual_.Get(), FALSE,
-                                            nullptr);
-    CHECK_EQ(hr, S_OK);
-    hr = transform_visual_->AddVisual(background_color_visual_.Get(), FALSE,
