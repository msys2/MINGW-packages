+
+namespace {
+constexpr int kMaxNumberOfQueriedApps = 10;
+
+#if BUILDFLAG(IS_MSVC)
+std::unique_ptr<NativeWinAppFetcher> CreateNativeWinAppFetcher() {
+  return std::make_unique<NativeWinAppFetcherImpl>();
+}
