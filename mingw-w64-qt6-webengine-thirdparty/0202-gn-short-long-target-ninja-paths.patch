+std::string ShortenNinjaFileNameIfNeeded(const std::string& name) {
+  constexpr size_t kMaxNinjaFileNameLength = 80;
+  if (name.size() <= kMaxNinjaFileNameLength)
+    return name;
+
+  uint64_t hash = 14695981039346656037ull;
+  for (unsigned char c : name) {
+    hash ^= c;
+    hash *= 1099511628211ull;
+  }
+
+  static constexpr char kHex[] = "0123456789abcdef";
+  std::string result = name.substr(0, 48);
+  result.push_back('_');
+  for (int shift = 60; shift >= 0; shift -= 4)
+    result.push_back(kHex[(hash >> shift) & 0xf]);
+  return result;
+}
+
+}  // namespace
