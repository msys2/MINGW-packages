# Maintainer: Maksim Bondarenkov <maksapple2306@gmail.com>

_realname=trippy
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=0.13.0
pkgrel=1
pkgdesc="A network diagnostic tool (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://trippy.rs'
msys2_repository_url='https://github.com/fujiapple852/trippy'
license=('spdx:Apache-2.0')
makedepends=("${MINGW_PACKAGE_PREFIX}-rust")
source=("${msys2_repository_url}/archive/${pkgver}/${_realname}-${pkgver}.tar.gz")
sha256sums=('72e598d2e0b947e8bc46706021c511f169b7e7634a734c326e492e0f30725c35')
noextract=("${_realname}-${pkgver}.tar.gz")

prepare() {
  tar -xf "${_realname}-${pkgver}.tar.gz" || true
  cd "${_realname}-${pkgver}"

  cargo fetch --locked --target "${RUST_CHOST}"
}

build() {
  cd "${_realname}-${pkgver}"

  cargo build --release --frozen --all-features -p trippy
}

check() {
  cd "${_realname}-${pkgver}"

  cargo test --release --frozen --all-features -p trippy
}

package() {
  cd "${_realname}-${pkgver}"

  local _target='target/release/trip'
  install -Dm755 $_target "${pkgdir}${MINGW_PREFIX}/bin/trip"
  install -Dm644 <($_target --generate bash) "${pkgdir}${MINGW_PREFIX}/share/bash-completion/completions/${_realname}"
  install -Dm644 <($_target --generate fish) "${pkgdir}${MINGW_PREFIX}/share/fish/vendor_completions.d/${_realname}.fish"
  install -Dm644 <($_target --generate zsh) "${pkgdir}${MINGW_PREFIX}/share/zsh/site-functions/_${_realname}"
  install -Dm644 <($_target --generate-man) "${pkgdir}${MINGW_PREFIX}/share/man/man1/trip.1"
  install -Dm644 LICENSE "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
