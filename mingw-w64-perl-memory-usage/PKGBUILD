# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Memory-Usage
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=0.201
pkgrel=1
pkgdesc="Tools to determine actual memory usage. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Memory-Usage"
msys2_references=(
  'purl: pkg:cpan/DONEILL/Memory-Usage'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl")
makedepends=("${MINGW_PACKAGE_PREFIX}-make"
             "${MINGW_PACKAGE_PREFIX}-perl-module-install")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/D/DO/DONEILL/${_perlname}-${pkgver}.tar.gz")
sha256sums=('8f2afad21e40a748e81c8c0f3e40ca718c14ddb9fb2d880bfbd28ae913ce5349')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" install
}
