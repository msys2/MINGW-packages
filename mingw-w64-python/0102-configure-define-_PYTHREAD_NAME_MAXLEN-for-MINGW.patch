From f4ad9cdee3fc9de80c90e6594be2e50b3076d2fa Mon Sep 17 00:00:00 2001
From: Christoph Reiter <reiter.christoph@gmail.com>
Date: Sat, 24 Jan 2026 11:33:27 +0100
Subject: [PATCH 102/N] configure: define _PYTHREAD_NAME_MAXLEN for MINGW

value copied from the MSVC build config
---
 configure.ac | 1 +
 1 file changed, 1 insertion(+)

diff --git a/configure.ac b/configure.ac
index 9aadaa5..597f722 100644
--- a/configure.ac
+++ b/configure.ac
@@ -8223,6 +8223,7 @@ case "$ac_sys_system" in
   iOS) _PYTHREAD_NAME_MAXLEN=63;;
   FreeBSD*) _PYTHREAD_NAME_MAXLEN=19;; # gh-131268
   OpenBSD*) _PYTHREAD_NAME_MAXLEN=23;; # gh-131268
+  MINGW*) _PYTHREAD_NAME_MAXLEN=32766;;
   *) _PYTHREAD_NAME_MAXLEN=;;
 esac
 if test -n "$_PYTHREAD_NAME_MAXLEN"; then
