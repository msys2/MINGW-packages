
_realname=pygobject-stubs
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-python-gobject-stubs")
pkgver=2.17.0
pkgrel=1
pkgdesc="PEP 561 Typing Stubs for PyGObject"
arch=(any)
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url="https://pygobject.gnome.org"
msys2_repository_url="https://github.com/pygobject/pygobject-stubs"
msys2_references=(
  'purl: pkg:pypi/pygobject-stubs'
)
license=('spdx:LGPL-2.1-or-later')
depends=("${MINGW_PACKAGE_PREFIX}-python-gobject")
makedepends=("${MINGW_PACKAGE_PREFIX}-python-build"
             "${MINGW_PACKAGE_PREFIX}-python-installer"
             "${MINGW_PACKAGE_PREFIX}-python-wheel"
             "${MINGW_PACKAGE_PREFIX}-python-setuptools"
)
source=(https://github.com/pygobject/pygobject-stubs/archive/refs/tags/v${pkgver}.tar.gz)
sha256sums=('25150fdac46210ee84632e9e3731f27e74aaca0ebce279c370898ab851b56373')

build() {
  cp -r "${_realname}-${pkgver}" "python-build-${MSYSTEM}" && cd "python-build-${MSYSTEM}"
  ${MINGW_PREFIX}/bin/python -m build --wheel --skip-dependency-check --no-isolation
}

package() {
  cd "${srcdir}/python-build-${MSYSTEM}"
  MSYS2_ARG_CONV_EXCL="--prefix" \
    ${MINGW_PREFIX}/bin/python -m installer --prefix=${MINGW_PREFIX} \
    --destdir="${pkgdir}" dist/*.whl

}
