# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Scalar-List-Utils
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=1.70
pkgrel=1
pkgdesc="Scalar::Util, List::Util and Sub::Util perl modules. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Scalar-List-Utils"
msys2_repository_url="https://github.com/Dual-Life/Scalar-List-Utils"
msys2_references=(
  'purl: pkg:cpan/PEVANS/Scalar-List-Utils'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-python"
             "${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/P/PE/PEVANS/${_perlname}-${pkgver}.tar.gz"
        "patchmakefile.py")
sha256sums=('e0cc03f9fe3565cdf4d6102654f87bba3bca2d8ff989da38307e857d0ae3c886'
            'a17a0febbf36be98b01d3fc9e7f22e5450adbf09cb5dc74c9690c8517464b2b3')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  PERL_MM_USE_DEFAULT=1 perl Makefile.PL
  export pkgdir=${pkgdir}
  python ${srcdir}/patchmakefile.py
  mingw32-make CC=${CC} CXX=${CXX} LD=${CXX}
}

package() {
  cd build-${MSYSTEM}
  mingw32-make DESTDIR="${pkgdir}/" install
}
