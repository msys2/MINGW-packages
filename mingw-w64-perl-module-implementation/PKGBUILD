# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Module-Implementation
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=0.09
pkgrel=1
pkgdesc="Loads one of several alternate underlying implementations for a module. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Module-Implementation"
msys2_repository_url="https://github.com/houseabsolute/Module-Implementation"
msys2_references=(
  'purl: pkg:cpan/DROLSKY/Module-Implementation'
)
license=('spdx:Artistic-2.0')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-module-runtime"
         "${MINGW_PACKAGE_PREFIX}-perl-try-tiny")
makedepends=("${MINGW_PACKAGE_PREFIX}-python"
             "${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/D/DR/DROLSKY/${_perlname}-${pkgver}.tar.gz"
        "patchmakefile.py")
sha256sums=('c15f1a12f0c2130c9efff3c2e1afe5887b08ccd033bd132186d1e7d5087fd66d'
            'a17a0febbf36be98b01d3fc9e7f22e5450adbf09cb5dc74c9690c8517464b2b3')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  PERL_MM_USE_DEFAULT=1 perl Makefile.PL
  export pkgdir=${pkgdir}
  python ${srcdir}/patchmakefile.py
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" PREFIX=${MINGW_PREFIX} install
  install -Dm644 LICENSE "${pkgdir}${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE"
}
