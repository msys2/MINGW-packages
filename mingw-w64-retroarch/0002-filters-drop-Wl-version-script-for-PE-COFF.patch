From: Kreijstal <kreijstal@hotmail.com>
Subject: filters: drop -Wl,--version-script for PE/COFF

-Wl,--version-script=link.T is an ELF-only feature; binutils silently
ignores it on PE/COFF, but lld (used by CLANG{64,ARM64}) errors out.
Symbol export on Windows DLLs is governed by __declspec, so the flag
is meaningless here regardless of the linker.

diff --git a/gfx/video_filters/Makefile b/gfx/video_filters/Makefile
index 6ca8585..fb99b78 100644
--- a/gfx/video_filters/Makefile
+++ b/gfx/video_filters/Makefile
@@ -42,7 +42,7 @@ ifeq (debug,$(build))
 extra_flags += -O0 -g
 endif
 
-ldflags := $(LDFLAGS) -shared -Wl,--version-script=link.T
+ldflags := $(LDFLAGS) -shared 
 
 ifeq ($(platform), unix)
 DYLIB = so
diff --git a/libretro-common/audio/dsp_filters/Makefile b/libretro-common/audio/dsp_filters/Makefile
index 34392e1..2ed6f2e 100644
--- a/libretro-common/audio/dsp_filters/Makefile
+++ b/libretro-common/audio/dsp_filters/Makefile
@@ -42,7 +42,7 @@ ifeq (debug,$(build))
    extra_flags += -O0 -g
 endif
 
-ldflags := $(LDFLAGS) -shared -lm -Wl,--version-script=link.T
+ldflags := $(LDFLAGS) -shared -lm 
 
 ifeq ($(platform), unix)
    DYLIB = so
