_realname=retroarch
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=1.22.2
pkgrel=1
pkgdesc='Reference frontend for the libretro API (mingw-w64)'
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://www.libretro.com/'
msys2_repository_url='https://github.com/libretro/RetroArch'
license=('spdx:GPL-3.0-only')
groups=("${MINGW_PACKAGE_PREFIX}-libretro")
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs"
         "${MINGW_PACKAGE_PREFIX}-ffmpeg"
         "${MINGW_PACKAGE_PREFIX}-fontconfig"
         "${MINGW_PACKAGE_PREFIX}-freetype"
         "${MINGW_PACKAGE_PREFIX}-fribidi"
         "${MINGW_PACKAGE_PREFIX}-libass"
         "${MINGW_PACKAGE_PREFIX}-libusb"
         "${MINGW_PACKAGE_PREFIX}-mbedtls"
         "${MINGW_PACKAGE_PREFIX}-openssl"
         "${MINGW_PACKAGE_PREFIX}-SDL2"
         "${MINGW_PACKAGE_PREFIX}-vulkan-loader"
         "${MINGW_PACKAGE_PREFIX}-zlib"
         "${MINGW_PACKAGE_PREFIX}-zstd")
depends+=("${MINGW_PACKAGE_PREFIX}-qt6-base")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-pkgconf"
             "${MINGW_PACKAGE_PREFIX}-vulkan-headers"
             "git")
optdepends=("${MINGW_PACKAGE_PREFIX}-retroarch-assets: menu UI assets (XMB, Ozone, GLUI, RGUI)"
            "${MINGW_PACKAGE_PREFIX}-libretro-core-info: core info files (required for the menu to list cores)"
            "${MINGW_PACKAGE_PREFIX}-libretro-database: content database / playlist scanning"
            "${MINGW_PACKAGE_PREFIX}-libretro-overlays: on-screen controller overlays"
            "${MINGW_PACKAGE_PREFIX}-libretro-shaders-slang: slang/SPIRV shaders for vulkan/d3d/glcore"
            "${MINGW_PACKAGE_PREFIX}-libretro-shaders-glsl: GLSL shaders for legacy GL drivers")
# Hook writes retroarch.cfg with cygpath-resolved absolute paths.
install=retroarch-${MSYSTEM}.install
backup=("${MINGW_PREFIX#/}/bin/retroarch.cfg")
_tag=69a4f0ea1e8aaf442ae4858f2e7f2b31a1776576
source=("git+https://github.com/libretro/RetroArch.git#tag=${_tag}"
        "0001-ui_qt-move-QStringList-declaration-outside-extern-C.patch"
        "0002-filters-drop-Wl-version-script-for-PE-COFF.patch"
        "0003-encoding_crc32-only-include-arm64_neon-h-on-MSVC.patch"
        "0004-config-def-buildbot-url-fallback-for-non-MSVC-ARM64.patch")
sha256sums=('298e210a1ec83b3d0fb46223dcbde1818a985e793f45f04ae62b66388325f7f3'
            '78912a0ceb62ef8c2df89523c262334dd921cb75c1763ea1d45041b1794309a6'
            '4fb3ec0a02d404232f8fcf8a725410829015ef83c64a9743c20c204d334ced69'
            'c04b654e68ea2c49b2762fe2281c1d119fb9846244967971d1e3dc635351f66b'
            '67362c0291916ca1f0a64ca4cc9a3a23cd3216f667115318deadd9159f502609')

pkgver() {
  cd RetroArch
  git describe --tags | sed 's/^v//'
}

prepare() {
  cd RetroArch
  patch -Np1 -i "${srcdir}/0001-ui_qt-move-QStringList-declaration-outside-extern-C.patch"
  patch -Np1 -i "${srcdir}/0002-filters-drop-Wl-version-script-for-PE-COFF.patch"
  patch -Np1 -i "${srcdir}/0003-encoding_crc32-only-include-arm64_neon-h-on-MSVC.patch"
  patch -Np1 -i "${srcdir}/0004-config-def-buildbot-url-fallback-for-non-MSVC-ARM64.patch"
}

build() {
  cd "${srcdir}/RetroArch"

  # Use distro libraries instead of vendored copies wherever the
  # configure script supports it. d3d11/d3d12, cheevos, discord, and
  # fontconfig are auto-detected by qb (no explicit --enable flag).
  # glslang and flac stay at qb's defaults: MSYS2's glslang split out
  # OGLCompiler/HLSL so qb's detector misses it (falls back to builtin),
  # and --disable-builtinflac breaks libretro-common/formats/libchdr
  # which expects the bundled dr_flac single-header to be on the include
  # path even when system libFLAC is available.
  ./configure \
    --prefix="${MINGW_PREFIX}" \
    --disable-builtinmbedtls \
    --disable-builtinbearssl \
    --disable-builtinzlib \
    --enable-zlib \
    --enable-ssl \
    --enable-vulkan \
    --enable-opengl \
    --enable-sdl2 \
    --disable-sdl \
    --enable-ffmpeg \
    --enable-hid \
    --enable-libusb \
    --enable-networkgamepad \
    --enable-qt \
    --enable-freetype \
    --enable-ssa \
    --disable-jack \
    --disable-oss \
    --disable-pulse \
    --disable-pipewire \
    --disable-alsa \
    --disable-x11 \
    --disable-wayland

  make
  # The filter Makefiles hardcode CC=gcc, which doesn't exist on CLANG64;
  # override with `cc`, which is the env-default symlink in every MSYS2
  # mingw environment (clang on CLANG{64,ARM64}, gcc on UCRT64).
  make CC=cc -C libretro-common/audio/dsp_filters
  make CC=cc -C gfx/video_filters
}

package() {
  cd "${srcdir}/RetroArch"

  make DESTDIR="${pkgdir}" install

  install -d "${pkgdir}${MINGW_PREFIX}/lib/retroarch/filters/audio"
  install -d "${pkgdir}${MINGW_PREFIX}/lib/retroarch/filters/video"
  install -Dm644 libretro-common/audio/dsp_filters/*.{dsp,dll} -t "${pkgdir}${MINGW_PREFIX}/lib/retroarch/filters/audio/"
  install -Dm644 gfx/video_filters/*.{filt,dll} -t "${pkgdir}${MINGW_PREFIX}/lib/retroarch/filters/video/"

  install -Dm644 COPYING "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
