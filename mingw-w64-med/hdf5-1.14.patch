Adapt MED to HDF5 2.x (ALT ships hdf5 2.1.1).

1. The version gate hardcodes major==1 && minor==14, rejecting HDF5 2.x.
   Relax it to ">= 1.14.0" so newer HDF5 is accepted.
2. The H5public.h/H5Ipublic.h lookup used HDF5_INCLUDE_DIRS with
   NO_DEFAULT_PATH; modern CMake FindHDF5 leaves HDF5_INCLUDE_DIRS empty for
   system HDF5, so the headers were not found. Also search HDF5_C_INCLUDE_DIRS
   and the default system paths.

--- a/config/cmake_files/medMacros.cmake
+++ b/config/cmake_files/medMacros.cmake
@@ -447,7 +447,7 @@ MACRO(MED_FIND_HDF5)
     ##
     ## Requires 1.14.0 version
     ##
-    IF (NOT HDF_VERSION_MAJOR_REF EQUAL 1 OR NOT HDF_VERSION_MINOR_REF EQUAL 14 OR NOT HDF_VERSION_RELEASE_REF GREATER_EQUAL 0)
+    IF (HDF5_VERSION VERSION_LESS 1.14.0)
         MESSAGE(FATAL_ERROR "HDF5 version is ${HDF_VERSION_REF}. Only versions >= 1.14.0 are supported.")
     ENDIF()
     ##
@@ -469,5 +469,5 @@ MACRO(MED_FIND_HDF5)
     # Extract some stuff from headers
-    FIND_FILE(_H5PUB_ABS_PATH H5public.h PATHS ${HDF5_INCLUDE_DIRS} NO_DEFAULT_PATH)
-    FIND_FILE(_H5_I_PUB_ABS_PATH H5Ipublic.h PATHS ${HDF5_INCLUDE_DIRS} NO_DEFAULT_PATH)
+    FIND_FILE(_H5PUB_ABS_PATH H5public.h PATHS ${HDF5_INCLUDE_DIRS} ${HDF5_C_INCLUDE_DIRS})
+    FIND_FILE(_H5_I_PUB_ABS_PATH H5Ipublic.h PATHS ${HDF5_INCLUDE_DIRS} ${HDF5_C_INCLUDE_DIRS})
     IF(NOT _H5PUB_ABS_PATH OR NOT _H5_I_PUB_ABS_PATH)
        MESSAGE(FATAL_ERROR "Could not find H5public.h or H5Ipublic.h!")
