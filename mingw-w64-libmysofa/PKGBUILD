_realname=libmysofa
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=1.3.4
pkgrel=1
pkgdesc="Reader for AES SOFA files to get better HRTFs (mingw-w64)"
arch=('any')
mingw_arch=('mingw32' 'mingw64' 'ucrt64' 'clang64' 'clangarm64')
url="https://github.com/hoene/libmysofa/"
msys2_repository_url='https://github.com/hoene/libmysofa'
msys2_references=(
  "cpe: cpe:/a:symonics:libmysofa"
)
license=('spdx:BSD-3-Clause')
depends=(
  "${MINGW_PACKAGE_PREFIX}-cc-libs"
  "${MINGW_PACKAGE_PREFIX}-zlib"
)
makedepends=(
  "${MINGW_PACKAGE_PREFIX}-cc"
  "${MINGW_PACKAGE_PREFIX}-cmake"
  "${MINGW_PACKAGE_PREFIX}-ninja"
  "${MINGW_PACKAGE_PREFIX}-pkgconf"
  "${MINGW_PACKAGE_PREFIX}-cunit"
)
source=("https://github.com/hoene/libmysofa/archive/v${pkgver}/${_realname}-${pkgver}.tar.gz"
        '001-mingw-dont-use-nuget.patch'
        '002-fix-exports.patch'
        '005-add-cflag-private-for-staticlib.patch'
        '006-fix-tests.patch'
        '007-fix-dllname.patch')
sha256sums=('64c661f75ef39edf68bfc3a28403d2b5a0bd251d0b9f5d021ed6f7917867fb37'
            'f7c1f72dac366fd11502cf7176aa5133075f39b0e375522d00fc1cb827189378'
            'eee2ea1c7bc233a40be8608881cf05dd623a61b1daa6365a1db47ac316bf42e4'
            '7c88bad3aac44c96d8ef1dd001f9677b46613774e9f2e2780692f3af995cc609'
            'ad260750552ffbdefc9f45e3683f29a29a59afbeabb21bbb632a9328347da9e6'
            '34926f9df08443fb0c7661c925a132c14685c72a83415e505f9c370132d40902')

apply_patch_with_msg() {
  for _patch in "$@"
  do
    msg2 "Applying $_patch"
    patch -Nbp1 -i "${srcdir}/$_patch"
  done
}

prepare() {
  cd "${srcdir}"/${_realname}-${pkgver}

  apply_patch_with_msg \
    001-mingw-dont-use-nuget.patch \
    002-fix-exports.patch \
    005-add-cflag-private-for-staticlib.patch \
    007-fix-dllname.patch

  # https://github.com/hoene/libmysofa/pull/247
  apply_patch_with_msg \
    006-fix-tests.patch
}

build() {
  declare -a _extra_config
  if check_option "debug" "n"; then
    _extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    _extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    cmake \
      -GNinja \
      -DCMAKE_INSTALL_PREFIX=${MINGW_PREFIX} \
      -DBUILD_SHARED_LIBS=ON \
      -DBUILD_TESTS=OFF \
      "${_extra_config[@]}" \
      -S ${_realname}-${pkgver} \
      -B build-${MSYSTEM}

  cmake --build build-${MSYSTEM}
}

check() {
  cmake -DBUILD_TESTS=ON -S ${_realname}-${pkgver} -B build-${MSYSTEM}
  cmake --build build-${MSYSTEM}

  # Shell script tests are not supported on Windows.
  ctest --test-dir build-${MSYSTEM} --output-on-failure || true
}

package() {
  DESTDIR="${pkgdir}" cmake --install build-${MSYSTEM}

  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/LICENSE \
    "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE
}
