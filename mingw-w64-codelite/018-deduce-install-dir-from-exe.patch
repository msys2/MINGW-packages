--- ./CodeLite/Platform/MSYS2.cpp	2026-03-04 14:26:37.072627200 +0800
+++ ./CodeLite/Platform/MSYS2.cpp	2026-03-04 14:50:26.971308300 +0800
@@ -19,6 +19,28 @@
 
     m_checked_for_install_dir = true;
 
+    // Infer MSYS2 installation directory from the current executable's location.
+    // CodeLite is installed inside an MSYS2 environment, typically at:
+    //   <MSYS2_ROOT>/<env>/bin/codelite.exe
+    // By stripping two directory levels we obtain the root where 'msys2.exe' resides.
+
+    // get the executable path
+	wxString exePath = clStandardPaths::Get().GetExecutablePath();
+	wxFileName fn(exePath);
+
+    // Strip the `bin` directory
+    fn.RemoveLastDir();
+    // Strip the environment directory (e.g., ucrt64, clang64, mingw64)
+    fn.RemoveLastDir();
+
+    // Search for `msys2.exe` located in the root directory of `msys64`
+    wxString dir = fn.GetPath();
+    if (wxFileName::FileExists(dir + "\\msys2.exe")) {
+		m_install_dir = dir;
+		return m_install_dir;
+	}
+
+    // Keep the original method
     wxString reg_install_path;
 #ifdef __WXMSW__
     wxRegKey uninstall(wxRegKey::HKCU, R"(SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall)");
