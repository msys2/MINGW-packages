From 8461f990040d8e6cbc63993504a1a7390da20b15 Mon Sep 17 00:00:00 2001
From: Joel Holdsworth <jholdsworth@nvidia.com>
Date: Thu, 30 Oct 2025 20:58:16 -0700
Subject: [PATCH 1/4] Rename B #define to SPR_B

regs51.h has pre-processor defines for special purpose registers (SPRs)
of the s51 architecture which include a "B" SPR.

As a result, regs51.h contains the line:

    #define B (0xf0)

Unfortunaly, the GCC headers contain function definitions such as this:

    __m256bh _mm256_roundscale_pbh (__m256bh __A, int B);

To prevent collision between the "B" define and usage of "B" in GCC's
headers, this patch renames "B" to "SPR_B".
---
 sim/ucsim/src/sims/s51.src/arith.cc | 10 +++++-----
 sim/ucsim/src/sims/s51.src/regs51.h |  2 +-
 sim/ucsim/src/sims/s51.src/uc390.cc |  2 +-
 sim/ucsim/src/sims/s51.src/uc51.cc  |  4 ++--
 4 files changed, 9 insertions(+), 9 deletions(-)

diff --git a/sim/ucsim/src/sims/s51.src/arith.cc b/sim/ucsim/src/sims/s51.src/arith.cc
index 3e2908666..e879c8471 100644
--- a/sim/ucsim/src/sims/s51.src/arith.cc
+++ b/sim/ucsim/src/sims/s51.src/arith.cc
@@ -367,13 +367,13 @@ cl_51core::instruction_84/*inst_div_ab*/(t_mem/*uchar*/ code)
   pw= psw->get();
   pw&= ~bmCY;
   ac= acc->get();
-  if (!(b= sfr->get(B)))
+  if (!(b= sfr->get(SFR_B)))
     pw|= bmOV;
   else
     {
       pw&= ~bmOV;
       temp= (ac) / b;
-      sfr->write(B, ac % b);
+      sfr->write(SFR_B, ac % b);
       ac= temp;
     }
   psw->write(pw);
@@ -522,10 +522,10 @@ cl_51core::instruction_a4/*inst_mul_ab*/(t_mem/*uchar*/ code)
 
   pw= psw->get();
   pw&= ~bmCY;
-  temp= (ac= acc->read()) * (b= sfr->get(B));
+  temp= (ac= acc->read()) * (b= sfr->get(SFR_B));
   acc->write(temp & 0xff);
-  x= sfr->write(B, (temp >> 8) & 0xff);
-  SFR_SET_BIT(x/*sfr->get(B)*/, PSW, bmOV);
+  x= sfr->write(SFR_B, (temp >> 8) & 0xff);
+  SFR_SET_BIT(x/*sfr->get(SFR_B)*/, PSW, bmOV);
   SFR_SET_BIT(0, PSW, bmCY);
   tick(3);
   vc.rd++;//= 2;
diff --git a/sim/ucsim/src/sims/s51.src/regs51.h b/sim/ucsim/src/sims/s51.src/regs51.h
index c339a0d1f..30fe1da74 100644
--- a/sim/ucsim/src/sims/s51.src/regs51.h
+++ b/sim/ucsim/src/sims/s51.src/regs51.h
@@ -32,7 +32,7 @@ Software Foundation, 59 Temple Place - Suite 330, Boston, MA
 /* Address of SFR registers */
 
 #define ACC	0xe0 /* Accumulator */
-#define B	0xf0 /* B register (secondary accumulator) */
+#define SFR_B	0xf0 /* B register (secondary accumulator) */
 #define PSW	0xd0 /* Program Status Word */
 #define SP	0x81 /* Stack Pointer */
 #define DPL	0x82 /* Data Pointer Low byte */
diff --git a/sim/ucsim/src/sims/s51.src/uc390.cc b/sim/ucsim/src/sims/s51.src/uc390.cc
index 4adb32e93..da6427de5 100644
--- a/sim/ucsim/src/sims/s51.src/uc390.cc
+++ b/sim/ucsim/src/sims/s51.src/uc390.cc
@@ -1279,7 +1279,7 @@ cl_uc390::print_regs (class cl_console_base *con)
   con->dd_printf ("  ACC= 0x%02x %3d %c  B= 0x%02x",
                   sfr->get (ACC), sfr->get (ACC),
                   isprint (sfr->get (ACC)) ?
-                  (sfr->get (ACC)) : '.', sfr->get (B));
+                  (sfr->get (ACC)) : '.', sfr->get (SFR_B));
   con->dd_printf("\n");
   
   eram2xram ();
diff --git a/sim/ucsim/src/sims/s51.src/uc51.cc b/sim/ucsim/src/sims/s51.src/uc51.cc
index e07326c6e..8db61e812 100644
--- a/sim/ucsim/src/sims/s51.src/uc51.cc
+++ b/sim/ucsim/src/sims/s51.src/uc51.cc
@@ -1423,7 +1423,7 @@ cl_51core::print_regs(class cl_console_base *con)
   con->dd_printf("@R0 %02x %c", data, isprint(data) ? data : '.');
 
   con->dd_printf("  ACC= 0x%02x %3d %c  B= 0x%02x\n", sfr->get(ACC), sfr->get(ACC),
-              isprint(sfr->get(ACC))?(sfr->get(ACC)):'.', sfr->get(B));
+              isprint(sfr->get(ACC))?(sfr->get(ACC)):'.', sfr->get(SFR_B));
   data= iram->get(iram->get(start+1));
   con->dd_printf("@R1 %02x %c", data, isprint(data) ? data : '.');
   data= psw->get();
@@ -1711,7 +1711,7 @@ cl_51core::clear_sfr(void)
   prev_p1= /*port_pins[1] &*/ sfr->/*get*/read(P1);
   prev_p3= /*port_pins[3] &*/ sfr->/*get*/read(P3);
   sfr->write(ACC, 0);
-  sfr->write(B, 0);
+  sfr->write(SFR_B, 0);
   sfr->write(PSW, 0);
   sfr->write(SP, 7);
   sfr->write(DPL, 0);
-- 
