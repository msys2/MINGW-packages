# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=JSON
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=4.11
pkgrel=1
pkgdesc="Perl implementation of JSON encoder/decoder. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/JSON"
msys2_repository_url="https://github.com/makamaka/JSON"
msys2_references=(
  'purl: pkg:cpan/ISHIGAKI/JSON'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/I/IS/ISHIGAKI/${_perlname}-${pkgver}.tar.gz")
sha256sums=('713bdbe724dbb915ed50265ffe47e079a511980cb2427aa19076788bb64c3182')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  mingw32-make DESTDIR="${pkgdir}/" install
}
