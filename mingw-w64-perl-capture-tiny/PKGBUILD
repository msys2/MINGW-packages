# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Capture-Tiny
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=0.50
pkgrel=3
pkgdesc="Capture STDOUT and STDERR from Perl, XS or external programs. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Capture-Tiny"
msys2_repository_url="https://github.com/dagolden/Capture-Tiny"
msys2_references=(
  'purl: pkg:cpan/DAGOLDEN/Capture-Tiny'
)
license=('spdx:Apache-2.0')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/D/DA/DAGOLDEN/${_perlname}-${pkgver}.tar.gz")
sha256sums=('ca6e8d7ce7471c2be54e1009f64c367d7ee233a2894cacf52ebe6f53b04e81e5')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  mingw32-make DESTDIR="${pkgdir}/" install
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
