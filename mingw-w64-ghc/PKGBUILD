prepare() {
  cd "${srcdir}"

  mkdir -p prebuilt

  msg "Extracting binaries: ${_realname}-${pkgver}-${_hsarch}-unknown-mingw32.tar.xz..."
  bsdtar -xf ${_realname}-${pkgver}-${_hsarch}-unknown-mingw32.tar.xz -C prebuilt --strip-components 1

  cp -a ${_realname}-${pkgver} build-${MSYSTEM} || true

  for _hook in "${_hooks[@]}"; do
    echo $_hook
    sed -e "s|MINGW_PREFIX|$(basename ${MINGW_PREFIX})|" \
      ${_hook} > build-${MSYSTEM}/${_hook}
  done

  cp -av "${srcdir}/build.mk" "${srcdir}/build-${MSYSTEM}/mk/build.mk"

  cd "${srcdir}/build-${MSYSTEM}"
  patch -Nbp1 -i "${srcdir}/0001-use-system-gmp.patch"
  patch -Nbp1 -i "${srcdir}/0002-Switch-LLVM-version.patch"
  patch -Nbp1 -i "${srcdir}/0003-fix-build-with-ucrt.patch"
  patch -Nbp1 -i "${srcdir}/0004-fix-windres.patch"
  patch -Nbp1 -i "${srcdir}/0005-fix-install.patch"
}

build() {
  cd "${srcdir}/build-${MSYSTEM}"

  export PATH="${srcdir}/prebuilt/bin:$PATH"

  ln -sfn ${MINGW_PREFIX} mingw
  mkdir -p inplace
  (cd inplace && ln -sfn ${MINGW_PREFIX} mingw)

  ./boot
  ./configure \
    --prefix=${MINGW_PREFIX} \
    --build=${MINGW_CHOST} \
    --host=${MINGW_CHOST} \
    --with-system-libffi \
    --enable-distro-toolchain

  # Force static linking to libffi, otherwise ghc-stage2.exe failed with
  # Mingw-w64 runtime failure: 32 bit pseudo relocation at XXX out of range
  install -Dm644 "${MINGW_PREFIX}/lib/libffi.a" rts/dist/build/libffi.a

  make -j
}

# check() {
#   cd "${srcdir}/build-${MSYSTEM}"

#   make test -j || true
# }

package() {
  cd "${srcdir}/build-${MSYSTEM}"

  make prefix="${pkgdir}${MINGW_PREFIX}" \
    docdir="${pkgdir}${MINGW_PREFIX}/share/docs/ghc" \
    install

  for _hook in "${_hooks[@]}"; do
    install -Dm644 "${srcdir}/build-${MSYSTEM}/${_hook}" \
      "${pkgdir}/usr/share/libalpm/hooks/${MINGW_PACKAGE_PREFIX}-${_hook}"
  done

  mkdir -vp "${pkgdir}${MINGW_PREFIX}/share/haskell/"{register,unregister}

  install -Dm644 LICENSE "${pkgdir}${MINGW_PREFIX}/share/licenses/ghc/LICENSE"
}
