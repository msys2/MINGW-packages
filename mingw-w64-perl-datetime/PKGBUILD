# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=DateTime
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=1.66
pkgrel=1
pkgdesc="A date and time object for Perl. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/DateTime"
msys2_repository_url="https://github.com/houseabsolute/DateTime.pm"
msys2_references=(
  'purl: pkg:cpan/DROLSKY/DateTime'
)
license=('spdx:Artistic-2.0')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-datetime-locale"
         "${MINGW_PACKAGE_PREFIX}-perl-datetime-timezone"
         "${MINGW_PACKAGE_PREFIX}-perl-eval-closure"
         "${MINGW_PACKAGE_PREFIX}-perl-math-round"
         "${MINGW_PACKAGE_PREFIX}-perl-namespace-autoclean"
         "${MINGW_PACKAGE_PREFIX}-perl-params-validate"
         "${MINGW_PACKAGE_PREFIX}-perl-params-validationcompiler"
         "${MINGW_PACKAGE_PREFIX}-perl-specio")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-make"
             "${MINGW_PACKAGE_PREFIX}-perl-module-build")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/D/DR/DROLSKY/${_perlname}-${pkgver}.tar.gz")
sha256sums=('afabd686fb83d3ebf49ee453974f9122f3eec9b25ff8d2ddf4f12de92af1e5e2')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" install
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
