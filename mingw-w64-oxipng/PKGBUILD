# Maintainer: Christoph Reiter <reiter.christoph@gmail.com>

_realname=oxipng
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=10.1.1
pkgrel=1
pkgdesc="A lossless PNG compression optimiser (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://github.com/oxipng/oxipng"
msys2_repository_url="${url}"
msys2_references=(
  'purl: pkg:cargo/oxipng'
)
license=('spdx:MIT')
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs")
makedepends=("${MINGW_PACKAGE_PREFIX}-rust"
             "${MINGW_PACKAGE_PREFIX}-cc")
source=("${_realname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('ce19b1f060d586ceb3ea682f27d00e41675ec4093d8ac200a61ccd9d967d0999')

build() {
  cd "${_realname}-${pkgver}"

  # Generate man page
  cargo xtask mangen

  cargo build --release --locked
}

package() {
  cd "${_realname}-${pkgver}"

  install -Dm755 "target/release/${_realname}.exe" "${pkgdir}${MINGW_PREFIX}/bin/${_realname}.exe"
  install -Dm644 "target/xtask/mangen/manpages/${_realname}.1" "${pkgdir}${MINGW_PREFIX}/share/man/man1/${_realname}.1"
  install -Dm644 LICENSE "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
