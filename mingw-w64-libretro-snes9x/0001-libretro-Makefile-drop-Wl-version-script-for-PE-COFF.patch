From: Kreijstal <kreijstal@hotmail.com>
Subject: libretro Makefile: drop -Wl,--version-script for PE/COFF

-Wl,--version-script=link.T is an ELF-only feature; binutils silently
ignores it on PE/COFF, but lld (used by CLANG{64,ARM64}) errors out.
Symbol export on Windows DLLs is governed by __declspec, so the flag
is meaningless here regardless of the linker.

diff --git a/libretro/Makefile b/libretro/Makefile
index 466fa6b0..ca1625bf 100644
--- a/libretro/Makefile
+++ b/libretro/Makefile
@@ -62,7 +62,7 @@ ifneq (,$(findstring unix,$(platform)))
    SHARED := -shared -z defs
    else
    LIBS += -lz
-   SHARED := -shared -Wl,--version-script=link.T -Wl,-z,defs
+   SHARED := -shared  -Wl,-z,defs
    endif
 
    # ARM
@@ -86,7 +86,7 @@ endif
 else ifneq (,$(findstring CortexA73_G12B,$(platform)))
 	TARGET := $(TARGET_NAME)_libretro.so
 	fpic := -fPIC
-	SHARED := -shared -Wl,-version-script=link.T
+	SHARED := -shared 
 	ARCH = arm64
 	HAVE_NEON = 1
 	BUILTIN_GPU = neon
@@ -166,7 +166,7 @@ else ifeq ($(platform), libnx)
 else ifeq ($(platform), classic_armv7_a7)
 	TARGET := $(TARGET_NAME)_libretro.so
 	fpic := -fPIC
-	SHARED := -shared -Wl,--version-script=link.T -Wl,--no-undefined
+	SHARED := -shared  -Wl,--no-undefined
 	CXXFLAGS += -Ofast \
 	-flto=4 -fwhole-program -fuse-linker-plugin \
 	-fdata-sections -ffunction-sections -Wl,--gc-sections \
@@ -195,7 +195,7 @@ else ifeq ($(platform), classic_armv7_a7)
 else ifeq ($(platform), classic_armv8_a35)
 	TARGET := $(TARGET_NAME)_libretro.so
 	fpic := -fPIC
-	SHARED := -shared -Wl,--version-script=link.T -Wl,--no-undefined
+	SHARED := -shared  -Wl,--no-undefined
 	CXXFLAGS += -Ofast \
 	-flto=4 -fwhole-program -fuse-linker-plugin \
 	-fdata-sections -ffunction-sections -Wl,--gc-sections \
@@ -287,7 +287,7 @@ else ifeq ($(platform), theos_ios)
 else ifeq ($(platform), qnx)
    TARGET := $(TARGET_NAME)_libretro_$(platform).so
    fpic := -fPIC
-   SHARED := -shared -Wl,--version-script=link.T
+   SHARED := -shared 
    CC = qcc -Vgcc_notarmv7le
    CXX = QCC -Vgcc_notarmv7le
    AR = QCC -Vgcc_ntoarmv7le
@@ -602,7 +602,7 @@ else
    TARGET := $(TARGET_NAME)_libretro.dll
    CC ?= gcc
    CXX ?= g++
-   SHARED := -shared -static-libgcc -static-libstdc++ -s -Wl,--version-script=link.T
+   SHARED := -shared -static-libgcc -static-libstdc++ -s 
    CXXFLAGS += -D__WIN32__
    LIBS += -lz -lcrypt32
 endif
