# Contributor: Kreijstal <kreijstal@hotmail.com>

_realname=libretro-snes9x
_corename=snes9x
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=r1.185488c
pkgrel=1
pkgdesc='Super Nintendo / Super Famicom libretro core (snes9x) (mingw-w64)'
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://www.libretro.com/'
msys2_repository_url='https://github.com/libretro/snes9x'
license=('custom:snes9x')
groups=("${MINGW_PACKAGE_PREFIX}-libretro")
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "git" "make")
optdepends=("${MINGW_PACKAGE_PREFIX}-retroarch: frontend that loads this core"
            "${MINGW_PACKAGE_PREFIX}-libretro-core-info: required for the core to show up in the menu")
_commit=185488cd83aaf274752a742c94d45561cbecb7af
source=("snes9x::git+https://github.com/libretro/snes9x.git#commit=${_commit}"
        "0001-libretro-Makefile-drop-Wl-version-script-for-PE-COFF.patch")
sha256sums=('a1360ae3fd1dbe6f4527388b3e3842b532e434a28605f2b3afbf303b9f896528'
            '1ec5bd8a5783068958c308db2661aa78088ef4220fc5a4f32988f60dfbe7e95f')

pkgver() {
  cd snes9x
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd snes9x
  patch -Np1 -i "${srcdir}/0001-libretro-Makefile-drop-Wl-version-script-for-PE-COFF.patch"
}

build() {
  cd snes9x/libretro
  make platform=win
}

package() {
  install -Dm755 "snes9x/libretro/${_corename}_libretro.dll" \
    "${pkgdir}${MINGW_PREFIX}/lib/libretro/${_corename}_libretro.dll"
  install -Dm644 snes9x/LICENSE \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
