# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=File-Find-Rule
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=0.35
pkgrel=1
pkgdesc="	Alternative interface to File::Find. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/File-Find-Rule"
msys2_references=(
  'purl: pkg:cpan/RCLAMP/File-Find-Rule'
)
license=('unknown')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-number-compare"
         "${MINGW_PACKAGE_PREFIX}-perl-text-glob")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/R/RC/RCLAMP/${_perlname}-${pkgver}.tar.gz")
sha256sums=('2bd556289a6d44ad2ee74803258bb0b0050d246f1e81caab0b263c303acf0c82')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" install
}
