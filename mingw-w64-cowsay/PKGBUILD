# Maintainer: Dirk Stolle

_realname=cowsay
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=3.8.4
pkgrel=1
pkgdesc="Configurable takling cow (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://cowsay.diamonds/'
msys2_repository_url='https://github.com/cowsay-org/cowsay'
msys2_references=(
  'archlinux: cowsay'
  'gentoo: games-misc/cowsay'
)
license=('spdx:GPL-3.0-only')
depends=('perl')
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
source=("https://github.com/cowsay-org/cowsay/archive/v${pkgver}/${_realname}-${pkgver}.tar.gz")
sha256sums=('c15bc10712835d3a9bcda780dc9453362567bf48d1185905dc7ef2334d79aadd')

package() {
  cd "${_realname}-${pkgver}"

  DESTDIR="${pkgdir}" make install prefix=${MINGW_PREFIX}

  install -Dm644 LICENSE.txt "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
