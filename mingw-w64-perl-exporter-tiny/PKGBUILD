# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Exporter-Tiny
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=1.006003
pkgrel=3
pkgdesc="An exporter with the features of Sub::Exporter but only core dependencies. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Exporter-Tiny"
msys2_repository_url="https://github.com/tobyink/p5-exporter-tiny"
msys2_references=(
  'purl: pkg:cpan/TOBYINK/Exporter-Tiny'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/T/TO/TOBYINK/${_perlname}-${pkgver}.tar.gz")
sha256sums=('6499f09a6432cf87b133fb9580a8a9a9a6c566821346b1fdee95f7b64c0317b1')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  mingw32-make DESTDIR="${pkgdir}/" install
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
