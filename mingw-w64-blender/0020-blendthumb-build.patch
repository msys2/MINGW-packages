     char system_dir[FILE_MAXDIR];
     BLI_windows_get_executable_dir(install_dir);
     GetSystemDirectory(system_dir, sizeof(system_dir));
+#ifdef __MINGW32__
+    const char *thumbnail_handler = "libBlendThumb.dll";
