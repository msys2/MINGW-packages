 source/lib/win.cpp           | 2 +-
 source/script.cpp            | 6 +++---
 source/script2.cpp           | 6 +++---
 source/script_expression.cpp | 6 +++---
 source/script_object.cpp     | 2 +-
 source/script_registry.cpp   | 2 +-
 7 files changed, 13 insertions(+), 13 deletions(-)

