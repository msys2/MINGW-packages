# Contributor: Kreijstal <kreijstal@hotmail.com>

_realname=libretro-core-info
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=r1.bd81a0b
pkgrel=1
pkgdesc='Core info files describing each libretro core for the RetroArch frontend (mingw-w64)'
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://www.libretro.com/'
msys2_repository_url='https://github.com/libretro/libretro-core-info'
license=('spdx:MIT')
groups=("${MINGW_PACKAGE_PREFIX}-libretro")
depends=()
makedepends=("git")
optdepends=("${MINGW_PACKAGE_PREFIX}-retroarch: frontend that consumes these info files")
_commit=bd81a0b73b50449c0862b65bd755d87860925f65
source=("libretro-core-info::git+https://github.com/libretro/libretro-core-info.git#commit=${_commit}")
sha256sums=('9a3a23f23db01cb204a41ffd62c2e68b0fff88514ab40e3f0653ddf3ef10d7cd')

pkgver() {
  cd libretro-core-info
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
  install -d "${pkgdir}${MINGW_PREFIX}/share/libretro/info"
  install -m644 libretro-core-info/*.info "${pkgdir}${MINGW_PREFIX}/share/libretro/info/"
}
