# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Params-Validate
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=1.31
pkgrel=1
pkgdesc="Validate method/function parameters. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Params-Validate"
msys2_repository_url="https://github.com/houseabsolute/Params-Validate"
msys2_references=(
  'purl: pkg:cpan/DROLSKY/Params-Validate'
)
license=('spdx:Artistic-2.0')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-module-implementation")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-perl-module-build")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/D/DR/DROLSKY/${_perlname}-${pkgver}.tar.gz")
sha256sums=('1bf2518ef2c4869f91590e219f545c8ef12ed53cf313e0eb5704adf7f1b2961e')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  PERL_MM_USE_DEFAULT=1 perl Build.PL
  ./Build
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="--prefix=" \
  ./Build install --destdir="${pkgdir}" --prefix=${MINGW_PREFIX}
  install -Dm644 LICENSE "${pkgdir}${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE"
}
