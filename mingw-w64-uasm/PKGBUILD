# Maintainer: Adrian Pop <adrian.pop@liu.se>

_realname=uasm
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=2.58
pkgrel=1
pkgdesc="UASM is a free MASM-compatible assembler based on JWasm (mingw-w64)"
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64')
license=('spdx:Watcom-1.0')
url="https://github.com/Terraspace/UASM"
msys2_repository_url='https://github.com/Terraspace/UASM'
depends=("${MINGW_PACKAGE_PREFIX}-cc")
source=("https://github.com/Terraspace/UASM/archive/v${pkgver}/${_realname}-${pkgver}.tar.gz"
        "0001-fix-AVX-512BW-instruction-support-for-VPBROADCASTW-a.patch"
        "avx512-regtest.BIN"
        "avx512bw-regtest.BIN")
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP')

prepare() {
  cd "UASM-${pkgver}"
  patch -p1 -i "${srcdir}/0001-fix-AVX-512BW-instruction-support-for-VPBROADCASTW-a.patch"
  # Regenerated expected output for the avx512.asm regression test.
  # The vcvtps2ph SIB fix in v2.58 (commit 8222333) changed the EVEX
  # encoding of vcvtps2ph but did not update the expected binary.
  # Shipped as a verbatim file rather than a patch because patch(1)
  # cannot apply git binary diffs.
  cp "${srcdir}/avx512-regtest.BIN" regress/exp/plain_bin/avx512.bin
  # Expected output for the new avx512bw.asm regression test added by
  # the AVX-512BW patch; same reason for being a separate file.
  cp "${srcdir}/avx512bw-regtest.BIN" regress/exp/plain_bin/avx512bw.BIN
  rm -rf DJGPPr
  sed -i -e 's/^extra_c_flags = .*$/& -std=c11 -D__NT__ -Wno-incompatible-pointer-types -Wno-int-conversion -Wno-implicit-function-declaration -Wno-incompatible-function-pointer-types'"$CFLAGS"'/' Makefile-DOS-GCC.mak
  sed -i -e 's|gcc\.exe|cc.exe|g' Makefile-DOS-GCC.mak
}

build() {
  cd "UASM-${pkgver}"
  make -f Makefile-DOS-GCC.mak
}

package() {
  install -Dm744 "${srcdir}"/UASM-${pkgver}/DJGPPr/hjwasm.exe "${pkgdir}${MINGW_PREFIX}/bin/jwasm.exe"
  install -Dm744 "${srcdir}"/UASM-${pkgver}/DJGPPr/hjwasm.exe "${pkgdir}${MINGW_PREFIX}/bin/${_realname}.exe"
  install -Dm644 "${srcdir}"/UASM-${pkgver}/License.txt "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
