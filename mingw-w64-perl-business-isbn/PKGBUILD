# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Business-ISBN
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=3.014
pkgrel=1
pkgdesc="work with International Standard Book Numbers. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Business-ISBN"
msys2_repository_url="https://github.com/briandfoy/business-isbn"
msys2_references=(
  'purl: pkg:cpan/BRIANDFOY/Business-ISBN'
)
license=('spdx:Artistic-2.0')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-business-isbn-data")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/B/BR/BRIANDFOY/${_perlname}-${pkgver}.tar.gz")
sha256sums=('91135da48dd97fdbb40ea33306a008a2eae35ac5e3fae15fd420beab106b1e7a')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" install
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
