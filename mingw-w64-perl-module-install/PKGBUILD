# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Module-Install
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=1.21
pkgrel=1
pkgdesc="Standalone, extensible Perl module installer. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Module-Install"
msys2_repository_url="https://github.com/Perl-Toolchain-Gang/Module-Install"
msys2_references=(
  'purl: pkg:cpan/ETHER/Module-Install'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-file-remove"
         "${MINGW_PACKAGE_PREFIX}-perl-json"
         "${MINGW_PACKAGE_PREFIX}-perl-module-build"
         "${MINGW_PACKAGE_PREFIX}-perl-module-scandeps"
         "${MINGW_PACKAGE_PREFIX}-perl-par-dist"
         "${MINGW_PACKAGE_PREFIX}-perl-yaml-tiny")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/E/ET/ETHER/${_perlname}-${pkgver}.tar.gz")
sha256sums=('fbf91007f30565f3920e106055fd0d4287981d5e7dad8b35323ce4b733f15a7b')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" PREFIX=${MINGW_PREFIX} install
}
