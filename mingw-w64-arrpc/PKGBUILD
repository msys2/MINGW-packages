# Maintainer: Maksim Bondarenkov <maksapple2306@gmail.com>

_realname=arrpc
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=3.7.0
pkgrel=1
pkgdesc='Open Discord RPC server for atypical setups (mingw-w64)'
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url='https://arrpc.openasar.dev'
msys2_repository_url='https://github.com/OpenAsar/arRPC'
msys2_changelog_url='https://github.com/OpenAsar/arrpc/blob/main/changelog.md'
msys2_references=(
  'aur: arrpc'
  'purl: pkg:npm/arrpc'
)
license=('spdx:MIT')
depends=("${MINGW_PACKAGE_PREFIX}-nodejs")
options=('!strip')
source=("${msys2_repository_url}/archive/${pkgver}/${_realname}-${pkgver}.tar.gz")
sha256sums=('1fe4441800c960cd1d8561805c5cdde52c05875e42721e1dd650379a0ca0e06b')
noextract=("${_realname}-${pkgver}.tar.gz")

package() {
  npm install -g \
    --cache npm-cache \
    --prefix "${pkgdir}${MINGW_PREFIX}" \
    "${_realname}-${pkgver}.tar.gz"
}
