# Contributor/Maintainer: Sarah Ottinger <schalaalexiazeal@gmail.com>

_realname=mypy
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=2.1.0
pkgrel=1
pkgdesc='Optional static typing for Python 3 (PEP484) (mingw-w64)'
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url="https://www.mypy-lang.org/"
msys2_repository_url="https://github.com/python/mypy"
msys2_references=(
  'archlinux: mypy'
  'gentoo: dev-python/mypy'
  'purl: pkg:pypi/mypy'
)
license=('spdx:MIT')
depends=(
  "${MINGW_PACKAGE_PREFIX}-python"
  "${MINGW_PACKAGE_PREFIX}-python-typing_extensions"
  "${MINGW_PACKAGE_PREFIX}-python-mypy_extensions"
  "${MINGW_PACKAGE_PREFIX}-python-pathspec"
  "${MINGW_PACKAGE_PREFIX}-python-librt"
  "${MINGW_PACKAGE_PREFIX}-python-ast-serialize"
)
makedepends=(
  "${MINGW_PACKAGE_PREFIX}-python-build"
  "${MINGW_PACKAGE_PREFIX}-python-installer"
  "${MINGW_PACKAGE_PREFIX}-python-setuptools"
)
options=('!strip')
source=("https://pypi.org/packages/source/${_realname::1}/${_realname}/${_realname}-${pkgver}.tar.gz"
        '001-mingw32-alias-for-unix.patch')
sha256sums=('81e76ad12c2d804512e9b13240d1588316531bfba07558286078bfbce9613633'
            'e55e923f6d71f5db0eaaa1673de5fbbde6ec82d81d80c5a6400c561c6b0dc3cd')

prepare() {
  cd ${_realname}-${pkgver}

  patch -Nbp1 -i "${srcdir}"/001-mingw32-alias-for-unix.patch
}

build() {
  cp -r ${_realname}-${pkgver} python-build-${MSYSTEM} && cd python-build-${MSYSTEM}

  python -m build --wheel --skip-dependency-check --no-isolation
}

package() {
  cd python-build-${MSYSTEM}

  MSYS2_ARG_CONV_EXCL="--prefix=" \
    python -m installer --prefix=${MINGW_PREFIX} --destdir="${pkgdir}" dist/*.whl

  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/LICENSE \
    "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE
}
