# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Clone-Choose
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=0.010
pkgrel=1
pkgdesc="	Choose appropriate clone utility. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Clone-Choose"
msys2_repository_url="https://github.com/perl5-utils/Clone-Choose"
msys2_references=(
  'purl: pkg:cpan/HERMES/Clone-Choose'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
optdepends=("${MINGW_PACKAGE_PREFIX}-perl-clone")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/H/HE/HERMES/${_perlname}-${pkgver}.tar.gz")
sha256sums=('5623481f58cee8edb96cd202aad0df5622d427e5f748b253851dfd62e5123632')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" install
}
