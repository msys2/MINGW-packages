# Maintainer: Jing Yufei <master-hash@outlook.com>

_realname=gitu
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=0.42.0
pkgrel=1
pkgdesc='A TUI Git client inspired by Magit (mingw-w64)'
msys2_references=(
  'anitya: 387618'
  'archlinux: gitu'
  'purl: pkg:cargo/gitu'
)
url='https://github.com/altsem/gitu'
msys2_repository_url='https://github.com/altsem/gitu'
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
license=('spdx:MIT')
depends=("${MINGW_PACKAGE_PREFIX}-libgit2")
makedepends=("${MINGW_PACKAGE_PREFIX}-rust"
             "${MINGW_PACKAGE_PREFIX}-pkgconf"
             'git')
source=("git+https://github.com/altsem/gitu.git#tag=v${pkgver}")
sha256sums=('2b583985d089e82900b1e683bdf18d509add8c1a62c65db0b552d3a8d9f4b202')

prepare() {
  cd "${_realname}"

  cargo fetch --locked --target "${RUST_CHOST}"
}

build() {
  cd "${_realname}"

  cargo build \
    --frozen \
    --release
}

check() {
  cd "${_realname}"

  cargo test \
    --frozen \
    --release
}

package() {
  cd "${_realname}"

  cargo install \
    --frozen \
    --offline \
    --no-track \
    --path . \
    --root "${pkgdir}${MINGW_PREFIX}"

  install -Dm644 LICENSE "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
