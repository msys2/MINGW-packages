# Maintainer: Konstantin Podsvirov <konstantin@podsvirov.su>

_realname=litehtml
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=0.10
pkgrel=1
pkgdesc="Fast and lightweight HTML/CSS rendering engine (mingw-w64)"
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url='http://www.litehtml.com/'
msys2_repository_url='https://github.com/litehtml/litehtml'
license=('spdx:BSD-3-Clause')
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs"
         "${MINGW_PACKAGE_PREFIX}-gumbo-parser")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-ninja")
checkdepends=("${MINGW_PACKAGE_PREFIX}-gtk3")
source=("https://github.com/litehtml/litehtml/archive/v$pkgver/$_realname-$pkgver.tar.gz")
sha256sums=('7700eced92847d34ad9846b138cf195a9c974b519be70de58797880ae9da649e')

build() {
  declare -a extra_config
  if check_option "debug" "n"; then
    extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    cmake \
      -GNinja \
      -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
      "${extra_config[@]}" \
      -DBUILD_SHARED_LIBS=ON \
      -DCMAKE_DLL_NAME_WITH_SOVERSION=ON \
      -DEXTERNAL_GUMBO=ON \
      -DLITEHTML_BUILD_TESTING=OFF \
      -S ${_realname}-${pkgver} \
      -B "build-${MSYSTEM}"

  cmake --build "build-${MSYSTEM}"
}

# Currently tests build failed due to missing `-lstdc++fs`
# check() {
#   cmake -DLITEHTML_BUILD_TESTING=ON -S ${_realname}-${pkgver} -B "build-${MSYSTEM}"
#   cmake --build "build-${MSYSTEM}"
#   ctest --test-dir "build-${MSYSTEM}" --output-on-failure || true
# }

package() {
  DESTDIR="${pkgdir}" cmake --install "build-${MSYSTEM}"

  # Don't search for non-existant gumbo cmake config
  sed -e '/gumbo/d' -i "${pkgdir}${MINGW_PREFIX}"/lib/cmake/litehtml/litehtmlConfig.cmake

  install -Dm644 "${srcdir}/${_realname}-${pkgver}/LICENSE" "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
