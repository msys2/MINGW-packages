Replace MSVC-only %I printf length modifier with portable PRI*/standard ones.

The %I length modifier is an MSVC special. See:
https://learn.microsoft.com/en-us/cpp/c-runtime-library/format-specification-syntax-printf-and-wprintf-functions?view=msvc-170

This results in the method osync_get_mutex in w32os.c writing a string that is
either empty or garbage. And then the follow issue looks like this:
    *** invalid output sync mutex: <garbage>.  Stop.

or, when the string starts with NUL:

    : option '--sync-mutex' requires an argument

--- a/src/w32/w32os.c
+++ b/src/w32/w32os.c
@@ -18,6 +18,7 @@

 #include <stdio.h>
 #include <string.h>
+#include <inttypes.h>

 #include <windows.h>
 #include <process.h>
@@ -433,7 +434,7 @@
       /* Prepare the mutex handle string for our children.
          2 hex digits per byte + 2 characters for "0x" + null.  */
       mutex = xmalloc ((2 * sizeof (osync_handle)) + 2 + 1);
-      sprintf (mutex, "0x%Ix", (unsigned long long)(DWORD_PTR)osync_handle);
+      sprintf (mutex, "0x%" PRIxPTR, (uintptr_t)osync_handle);
     }

   return mutex;
