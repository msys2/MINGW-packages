# Maintainer: Maksim Bondarenkov <maksapple2306@gmail.com>

_realname=rufus
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=4.8BETA
pkgrel=1
pkgdesc="The Reliable USB Formatting Utility (mingw-w64)"
arch=('any')
mingw_arch=('mingw64' 'ucrt64')
url='https://rufus.ie'
msys2_repository_url='https://github.com/pbatard/rufus'
license=('spdx:GPL-3.0-or-later')
makedepends=("${MINGW_PACKAGE_PREFIX}-autotools"
             "${MINGW_PACKAGE_PREFIX}-cc")
source=("${msys2_repository_url}/archive/v${pkgver/BETA/_BETA}/${_realname}-${pkgver}.tar.gz")
sha256sums=('d7f347b853340cdba39a8881a1a8982a1cc78b4dc391b5c3b8efa321e4161fdf')

build() {
  mkdir -p "${_realname}-${pkgver/BETA/_BETA}/build-${MSYSTEM}" && cd "${_realname}-${pkgver/BETA/_BETA}/build-${MSYSTEM}"

  ../configure \
    --prefix="${MINGW_PREFIX}" \
    --enable-silent-rules \
    --disable-debug

  make
}

package() {
  cd "build-${MSYSTEM}"

  install -Dm755 src/rufus.exe "${pkgdir}${MINGW_PREFIX}/bin/rufus.exe"
  install -Dm644 "../${_realname}-${pkgver/BETA/_BETA}/LICENSE.txt" "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE.txt"
}
