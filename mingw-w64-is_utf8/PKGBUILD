# Maintainer: llm96 <llm96@fervidex.net>

_realname=is_utf8
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=1.4.1
pkgrel=1
pkgdesc="Fast C++ function is_utf8 (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://github.com/simdutf/${_realname}"
license=('spdx:Apache-2.0 AND BSL-1.0 AND MIT')
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-ninja")
source=("${url}/archive/refs/tags/v${pkgver}/${_realname}-${pkgver}.tar.gz"
        "0001-disable-benchmarks-option.patch::https://github.com/simdutf/is_utf8/commit/d0680429.patch"
        "0002-fix-missing-targets-install.patch::https://github.com/simdutf/is_utf8/commit/df062405.patch")
sha256sums=('8013eae5c474fe0aa6083118ede0b14d25c57a9cd63b2de8532a2909582b7e25'
            '4c26eb1324070debc2f8064cb69e32344df6a4a2c663647ff151595ba44e87e0'
            '24a1af1aac70d45dfcc3baffeaeb1671b295e02fc3ad7d6ed8e6c2ad8b3d7688')

prepare() {
  cd "${srcdir}/${_realname}-${pkgver}"

  # https://github.com/simdutf/is_utf8/pull/21
  patch -Np1 -i "${srcdir}/0001-disable-benchmarks-option.patch"
  patch -Np1 -i "${srcdir}/0002-fix-missing-targets-install.patch"
}

build() {
  declare -a _extra_config
  if check_option "debug" "n"; then
    _extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    _extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    ${MINGW_PREFIX}/bin/cmake.exe \
      -G"Ninja" \
      -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
      "${_extra_config[@]}" \
      -DBUILD_TESTING=OFF \
      -DIS_UTF8_BENCHMARKS=OFF \
      -S "${_realname}-${pkgver}" \
      -B "build-${MSYSTEM}"

  ${MINGW_PREFIX}/bin/cmake.exe --build "build-${MSYSTEM}"
}

package() {
  DESTDIR="${pkgdir}" ${MINGW_PREFIX}/bin/cmake.exe --install "build-${MSYSTEM}"

  install -Dm644 "${srcdir}/${_realname}-${pkgver}/LICENSE-APACHE" \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE-APACHE"
  install -Dm644 "${srcdir}/${_realname}-${pkgver}/LICENSE-BOOST" \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE-BOOST"
  install -Dm644 "${srcdir}/${_realname}-${pkgver}/LICENSE-MIT" \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE-MIT"
}
