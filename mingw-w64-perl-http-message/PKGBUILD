# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=HTTP-Message
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=7.02
pkgrel=3
pkgdesc="HTTP style message. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/HTTP-Message"
msys2_repository_url="https://github.com/libwww-perl/HTTP-Message"
msys2_references=(
  'purl: pkg:cpan/OALDERS/HTTP-Message'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-clone"
         "${MINGW_PACKAGE_PREFIX}-perl-encode-locale"
         "${MINGW_PACKAGE_PREFIX}-perl-http-date"
         "${MINGW_PACKAGE_PREFIX}-perl-io-html"
         "${MINGW_PACKAGE_PREFIX}-perl-lwp-mediatypes"
         "${MINGW_PACKAGE_PREFIX}-perl-uri")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/O/OA/OALDERS/${_perlname}-${pkgver}.tar.gz")
sha256sums=('78abef1d833146b48d17db219b1b03d53cbbe37a28ccdad0efdcc5833ca5c60c')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  mingw32-make DESTDIR="${pkgdir}/" install
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
