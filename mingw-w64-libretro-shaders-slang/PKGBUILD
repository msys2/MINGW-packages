# Contributor: Kreijstal <kreijstal@hotmail.com>

_realname=libretro-shaders-slang
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=r1.6edb8f0
pkgrel=1
pkgdesc='SPIRV/slang shaders for RetroArch (vulkan, D3D10/11/12, glcore drivers) (mingw-w64)'
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://www.libretro.com/'
msys2_repository_url='https://github.com/libretro/slang-shaders'
license=('spdx:GPL-3.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-libretro")
depends=()
makedepends=("git")
optdepends=("${MINGW_PACKAGE_PREFIX}-retroarch: frontend that consumes these shaders")
_commit=6edb8f0c6c40b334f9098b2bbe94e0c67b18289e
source=("slang-shaders::git+https://github.com/libretro/slang-shaders.git#commit=${_commit}")
sha256sums=('35fc5371fef9276eca1fc3926efd9671d5409263b0bf965298ce686d5e677149')

pkgver() {
  cd slang-shaders
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
  install -d "${pkgdir}${MINGW_PREFIX}/share/libretro/shaders"
  cp -r slang-shaders "${pkgdir}${MINGW_PREFIX}/share/libretro/shaders/shaders_slang"

  rm -rf "${pkgdir}${MINGW_PREFIX}/share/libretro/shaders/shaders_slang/.git" \
         "${pkgdir}${MINGW_PREFIX}/share/libretro/shaders/shaders_slang/.gitlab-ci.yml"
}
