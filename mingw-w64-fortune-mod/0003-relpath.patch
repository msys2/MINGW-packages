 #define NO_PROB (-1)                /* no prob specified for file */

+#ifdef _WIN32
+static const char *win32_fortunes_dir(const bool offensive)
+{
+    static bool initialized = false;
+    static char exe_dir[32768];
+    static char fortunes_dir[32768];
+    static char fortunes_off_dir[32768];
+
+    if (!initialized)
+    {
+        DWORD len = GetModuleFileNameA(NULL, exe_dir, sizeof(exe_dir));
+        if (!len || len >= sizeof(exe_dir))
+        {
+            fprintf(stderr, "%s",
+                "fortune: could not determine executable path.\n");
+            exit(1);
+        }
+        for (char *p = exe_dir; *p; ++p)
+        {
+            if (*p == '\\')
+            {
+                *p = '/';
+            }
+        }
+        while (len && exe_dir[len - 1] != '/')
+        {
+            --len;
+        }
+        if (!len)
+        {
+            fprintf(stderr, "%s",
+                "fortune: could not determine executable directory.\n");
+            exit(1);
+        }
+        exe_dir[len - 1] = '\0';
+        snprintf(
+            fortunes_dir, sizeof(fortunes_dir), "%s/../share/fortune", exe_dir);
+        snprintf(fortunes_off_dir, sizeof(fortunes_off_dir), "%s/off",
+            fortunes_dir);
+        initialized = true;
+    }
+
+    return offensive ? fortunes_off_dir : fortunes_dir;
+}
+
+#undef FORTUNE_LOCAL_OFFENSIVE_FORTUNES_DIR
+#undef FORTUNE_LOCAL_INOFFENSIVE_FORTUNES_DIR
+#undef FORTUNE_SYSTEM_OFFENSIVE_FORTUNES_DIR
+#undef FORTUNE_SYSTEM_INOFFENSIVE_FORTUNES_DIR
+
+#define FORTUNE_LOCAL_OFFENSIVE_FORTUNES_DIR (win32_fortunes_dir(true))
+#define FORTUNE_LOCAL_INOFFENSIVE_FORTUNES_DIR (win32_fortunes_dir(false))
+#define FORTUNE_SYSTEM_OFFENSIVE_FORTUNES_DIR (win32_fortunes_dir(true))
+#define FORTUNE_SYSTEM_INOFFENSIVE_FORTUNES_DIR (win32_fortunes_dir(false))
+#endif
