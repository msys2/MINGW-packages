# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Module-Runtime
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=0.018
pkgrel=2
pkgdesc="Runtime module handling. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Module-Runtime"
msys2_repository_url="https://github.com/haarg/Module-Runtime"
msys2_references=(
  'purl: pkg:cpan/HAARG/Module-Runtime'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl")
makedepends=("${MINGW_PACKAGE_PREFIX}-perl-module-build"
             "${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/H/HA/HAARG/${_perlname}-${pkgver}.tar.gz")
sha256sums=('0bf77ef68e53721914ff554eada20973596310b4e2cf1401fc958601807de577')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" PREFIX=${MINGW_PREFIX} install
  install -Dm644 LICENSE "${pkgdir}${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE"
}
