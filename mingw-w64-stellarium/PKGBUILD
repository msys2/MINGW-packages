_realname=stellarium
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=26.1
pkgrel=2
pkgdesc="Software which renders realistic skies in real time with OpenGL (mingw-w64)"
arch=(any)
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://stellarium.org"
license=(spdx:GPL-2.0-or-later)
depends=(
  ${MINGW_PACKAGE_PREFIX}-calcmysky
  ${MINGW_PACKAGE_PREFIX}-exiv2
  ${MINGW_PACKAGE_PREFIX}-cc-libs
  ${MINGW_PACKAGE_PREFIX}-md4c
  ${MINGW_PACKAGE_PREFIX}-nlopt
  ${MINGW_PACKAGE_PREFIX}-qt6-base
  ${MINGW_PACKAGE_PREFIX}-qt6-charts
  ${MINGW_PACKAGE_PREFIX}-qt6-declarative
  ${MINGW_PACKAGE_PREFIX}-qt6-multimedia
  ${MINGW_PACKAGE_PREFIX}-qt6-positioning
  ${MINGW_PACKAGE_PREFIX}-qt6-serialport
  ${MINGW_PACKAGE_PREFIX}-qt6-svg
  ${MINGW_PACKAGE_PREFIX}-qxlsx
  ${MINGW_PACKAGE_PREFIX}-zlib
)
makedepends=(
  ${MINGW_PACKAGE_PREFIX}-cc
  ${MINGW_PACKAGE_PREFIX}-cmake
  ${MINGW_PACKAGE_PREFIX}-mesa
  ${MINGW_PACKAGE_PREFIX}-qt6-tools
)
source=(https://github.com/Stellarium/stellarium/releases/download/v$pkgver/stellarium-$pkgver.tar.xz
        qt-6.10.patch)
validpgpkeys=('79151C2E6351E7278DA1A730BF38D4D02A328DFF') # Alexander Wolf <alex.v.wolf@gmail.com>
sha256sums=('578bada2531e39146ccefcf6a0d202867e403b559f54239e8db9f9c003e04443'
            'ddef4435490c1aac4de5892386e93967b945c8e88f18fbe465c0c166c8a9d514')

prepare() {
  patch -d "${_realname}-${pkgver}" -p1 < qt-6.10.patch
}

build() {
  declare -a extra_config
  if check_option "debug" "n"; then
    extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    cmake \
      -DCMAKE_INSTALL_PREFIX=${MINGW_PREFIX} \
      -Wno-dev \
      -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
      -DCMAKE_C_EXTENSIONS=Yes \
      -DCMAKE_C_STANDARD=17 \
      -DCMAKE_CXX_EXTENSIONS=Yes \
      -DCPM_LOCAL_PACKAGES_ONLY=ON \
      -DENABLE_QT6=1 \
      -DENABLE_SPOUT=OFF \
      "${extra_config[@]}" \
      -S "${_realname}-${pkgver}" \
      -B "build-${MSYSTEM}"

  cmake --build "build-${MSYSTEM}" --target all
}

package() {
  DESTDIR="$pkgdir" cmake --install "build-${MSYSTEM}"
  rm "${pkgdir}${MINGW_PREFIX}/bin/"*.dll.a
  install -vDm 644 "${srcdir}/${_realname}-${pkgver}/COPYING" -t "${pkgdir}${MINGW_PREFIX}/share/licenses/$_realname"
}
