# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Module-Build-Tiny
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=0.053
pkgrel=1
pkgdesc="A tiny replacement for Module::Build. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Module-Build-Tiny"
msys2_repository_url="https://github.com/Perl-Toolchain-Gang/module-build-tiny"
msys2_references=(
  'purl: pkg:cpan/LEONT/Module-Build-Tiny'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-extutils-config"
         "${MINGW_PACKAGE_PREFIX}-perl-extutils-helpers"
         "${MINGW_PACKAGE_PREFIX}-perl-extutils-installpaths"
         "${MINGW_PACKAGE_PREFIX}-perl-cpan-requirements-dynamic")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/L/LE/LEONT/${_perlname}-${pkgver}.tar.gz")
sha256sums=('3726d622da6f655e88fdf89e4fd597709c44970b47de65082003e8d86b5e193a')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  PERL_MM_USE_DEFAULT=1 perl Build.PL
  ./Build
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="--prefix=" \
  ./Build install --destdir="${pkgdir}" --prefix=${MINGW_PREFIX}
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
