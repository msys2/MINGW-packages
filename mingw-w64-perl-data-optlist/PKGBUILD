# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_perlname=Data-OptList
_realname="${_perlname,,}"
pkgbase=mingw-w64-perl-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-perl-${_realname}")
pkgver=0.114
pkgrel=1
pkgdesc="Parse and validate simple name/value option pairs. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://metacpan.org/dist/Data-OptList"
msys2_repository_url="https://github.com/rjbs/Data-OptList"
msys2_references=(
  'purl: pkg:cpan/RJBS/Data-OptList'
)
license=('spdx:Artistic-1.0-Perl OR GPL-1.0-or-later')
groups=("${MINGW_PACKAGE_PREFIX}-perl-modules")
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-params-util"
         "${MINGW_PACKAGE_PREFIX}-perl-scalar-list-utils"
         "${MINGW_PACKAGE_PREFIX}-perl-sub-install")
makedepends=("${MINGW_PACKAGE_PREFIX}-make")
options=('!emptydirs')
source=("https://cpan.metacpan.org/authors/id/R/RJ/RJBS/${_perlname}-${pkgver}.tar.gz")
sha256sums=('9fd1093b917a21fb79ae1607db53d113b4e0ad8fe0ae776cb077a7e50044fdf3')

build() {
  cp -r ${_perlname}-${pkgver} build-${MSYSTEM} && cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  PERL_MM_USE_DEFAULT=1 \
    perl Makefile.PL \
    PREFIX=${MINGW_PREFIX}
  mingw32-make
}

package() {
  cd build-${MSYSTEM}
  MSYS2_ARG_CONV_EXCL="PREFIX=" \
  mingw32-make DESTDIR="${pkgdir}/" install
  install -Dm644 LICENSE "${pkgdir}"${MINGW_PREFIX}/share/licenses/perl-${_realname}/LICENSE
}
