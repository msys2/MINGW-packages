Relax overly strict dependency version constraints.

The mycli 1.70.0 pyproject.toml uses `~= X.Y.Z` (compatible release with
3 components) for several dependencies, which pins to exact minor versions.
This causes pip check failures when the MSYS2 repos ship slightly newer
versions of cli_helpers, sqlglot, or pygments, or a slightly older version
of keyring.

Changing to `>= X.Y.Z` allows any newer version within the same major
version, which is appropriate for a distribution-packaged environment.

--- a/pyproject.toml
+++ b/pyproject.toml
@@ -11,19 +11,19 @@
     "click ~= 8.3.1",
     "clickdc ~= 0.1.1",
     "cryptography ~= 46.0.5",
-    "Pygments ~= 2.19.2",
+    "Pygments >= 2.19.2",
     "prompt_toolkit>=3.0.6,<4.0.0",
     "PyMySQL ~= 1.1.2",
     "sqlparse>=0.3.0,<0.6.0",
-    "sqlglot[c] ~= 30.4.3",
+    "sqlglot[c] >= 30.4.3",
     "configobj ~= 5.0.9",
-    "cli_helpers[styles] ~= 2.12.0",
+    "cli_helpers[styles] >= 2.12.0",
     "wcwidth ~= 0.6.0",
     "pyperclip ~= 1.11.0",
     "pycryptodomex ~= 3.23.0",
     "pyfzf ~= 0.3.1",
     "rapidfuzz ~= 3.14.3",
-    "keyring ~= 25.7.0",
+    "keyring >= 25.6.0",
 ]
