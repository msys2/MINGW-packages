# Contributor: Kreijstal <kreijstal@hotmail.com>

_realname=mycli
pkgbase=mingw-w64-python-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-python-${_realname}")
pkgver=1.70.0
pkgrel=1
pkgdesc='A Terminal Client for MySQL with AutoCompletion and Syntax Highlighting (mingw-w64)'
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url='https://www.mycli.net/'
msys2_repository_url='https://github.com/dbcli/mycli'
msys2_changelog_url='https://github.com/dbcli/mycli/blob/main/changelog.md'
msys2_references=(
  'purl: pkg:pypi/mycli'
)
license=('spdx:BSD-3-Clause')
depends=("${MINGW_PACKAGE_PREFIX}-python"
         "${MINGW_PACKAGE_PREFIX}-python-cli_helpers"
         "${MINGW_PACKAGE_PREFIX}-python-click"
         "${MINGW_PACKAGE_PREFIX}-python-clickdc"
         "${MINGW_PACKAGE_PREFIX}-python-configobj"
         "${MINGW_PACKAGE_PREFIX}-python-cryptography"
         "${MINGW_PACKAGE_PREFIX}-python-keyring"
         "${MINGW_PACKAGE_PREFIX}-python-prompt_toolkit"
         "${MINGW_PACKAGE_PREFIX}-python-pycryptodomex"
         "${MINGW_PACKAGE_PREFIX}-python-pyfzf"
         "${MINGW_PACKAGE_PREFIX}-python-pygments"
         "${MINGW_PACKAGE_PREFIX}-python-pymysql"
         "${MINGW_PACKAGE_PREFIX}-python-pyperclip"
         "${MINGW_PACKAGE_PREFIX}-python-rapidfuzz"
         "${MINGW_PACKAGE_PREFIX}-python-sqlglot"
         "${MINGW_PACKAGE_PREFIX}-python-sqlparse"
         "${MINGW_PACKAGE_PREFIX}-python-wcwidth")
makedepends=("${MINGW_PACKAGE_PREFIX}-python-build"
             "${MINGW_PACKAGE_PREFIX}-python-installer"
             "${MINGW_PACKAGE_PREFIX}-python-setuptools"
             "${MINGW_PACKAGE_PREFIX}-python-setuptools-scm"
             "${MINGW_PACKAGE_PREFIX}-python-wheel")
optdepends=("${MINGW_PACKAGE_PREFIX}-python-paramiko: SSH support"
            "${MINGW_PACKAGE_PREFIX}-python-sshtunnel: SSH tunnel support")
options=('!strip')
source=("https://pypi.org/packages/source/${_realname::1}/${_realname}/${_realname}-${pkgver}.tar.gz"
        "001-relax-dependency-constraints.patch")
sha256sums=('1f19a69dcd59dae6602cca6d82ac8ad31ec2308321efcf28679f00c3c94028ce'
            'SKIP')

prepare() {
  cd "${srcdir}/${_realname}-${pkgver}"

  # Relax overly strict dependency version constraints so pip check passes
  # with the versions shipped in MSYS2 (see the patch header for details).
  patch -Np1 -i "${srcdir}/001-relax-dependency-constraints.patch"
}

build() {
  cp -r "${_realname}-${pkgver}" "python-build-${MSYSTEM}" && cd "python-build-${MSYSTEM}"
  SETUPTOOLS_SCM_PRETEND_VERSION=${pkgver} \
    ${MINGW_PREFIX}/bin/python -m build --wheel --skip-dependency-check --no-isolation
}

package() {
  cd "${srcdir}/python-build-${MSYSTEM}"
  MSYS2_ARG_CONV_EXCL="--prefix=" \
    ${MINGW_PREFIX}/bin/python -m installer --prefix=${MINGW_PREFIX} \
    --destdir="${pkgdir}" dist/*.whl

  install -Dm644 "${srcdir}/${_realname}-${pkgver}/LICENSE.txt" \
    "${pkgdir}${MINGW_PREFIX}/share/licenses/python-${_realname}/LICENSE"
}
