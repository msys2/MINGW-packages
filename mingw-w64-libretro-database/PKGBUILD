# Contributor: Kreijstal <kreijstal@hotmail.com>

_realname=libretro-database
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=r1.4edb9a6
pkgrel=1
pkgdesc='Content database (RDB), cheats and cursors for RetroArch playlist scanning (mingw-w64)'
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://www.libretro.com/'
msys2_repository_url='https://github.com/libretro/libretro-database'
license=('spdx:MIT')
groups=("${MINGW_PACKAGE_PREFIX}-libretro")
depends=()
makedepends=("git" "make")
optdepends=("${MINGW_PACKAGE_PREFIX}-retroarch: frontend that consumes this database")
_commit=4edb9a6f8f7b1e94be2eafcf3369daa1bc676056
source=("libretro-database::git+https://github.com/libretro/libretro-database.git#commit=${_commit}")
sha256sums=('1d40a77e5df88837516ed60764f05381d3f8bd12dbd42e21b7364577b55b1e98')

pkgver() {
  cd libretro-database
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd libretro-database
  make build
}

package() {
  cd libretro-database
  install -d "${pkgdir}${MINGW_PREFIX}/share/libretro-database"
  for d in rdb cht cursors dat metadat; do
    cp -r "${d}" "${pkgdir}${MINGW_PREFIX}/share/libretro-database/${d}"
  done
}
