# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_realname=rkcommon
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=1.15.2
pkgrel=1
pkgdesc="Intel RenderKit common C++/CMake infrastructure. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://github.com/RenderKit/rkcommon'
msys2_repository_url="https://github.com/RenderKit/rkcommon"
msys2_references=(
  'archlinux: rkcommon'
)
license=('spdx:Apache-2.0')
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs"
         "${MINGW_PACKAGE_PREFIX}-tbb")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-ninja"
             "${MINGW_PACKAGE_PREFIX}-iconv")
source=("https://github.com/RenderKit/rkcommon/archive/v${pkgver}/${_realname}-${pkgver}.tar.gz"
        "001-fix-build-on-mingw.patch")
sha256sums=('9128642e5187b963385dbf1655f3b143d3ef46310cc2e27114d220b347d0e2f2'
            '497708fdadadc64390b3d0f48a68f8d07e2110cdc5c99037b603bf54710246ed')

prepare() {
  cd "${_realname}-${pkgver}"

  patch -Np1 -i ../001-fix-build-on-mingw.patch

  iconv -f UTF-16 -t UTF-8 rkcommon/rkcommon.rc > rkcommon/rkcommon.rc.utf8
  mv rkcommon/rkcommon.rc.utf8 rkcommon/rkcommon.rc
}

build() {
  declare -a extra_config
  if check_option "debug" "n"; then
    extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  if [[ ${CARCH} == aarch64 ]]; then
    CXXFLAGS+=" -D__ARM_NEON"
  fi

  CXXFLAGS+=" -D_USE_MATH_DEFINES" \
  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    cmake \
      -GNinja \
      -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
      "${extra_config[@]}" \
      -DBUILD_SHARED_LIBS=ON \
      -DCMAKE_SKIP_INSTALL_RPATH=ON \
      -DINSTALL_DEPS=OFF \
      -DBUILD_TESTING=OFF \
      -S "${_realname}-${pkgver}" \
      -B "build-${MSYSTEM}"

  cmake --build "build-${MSYSTEM}"
}

check() {
  cmake -DBUILD_TESTING=ON -S"${_realname}-${pkgver}" -B"build-${MSYSTEM}"
  cmake --build "build-${MSYSTEM}"
  ctest --test-dir "build-${MSYSTEM}" --output-on-failure
}

package() {
  DESTDIR="${pkgdir}" cmake --install "build-${MSYSTEM}"

  install -Dm644 "${_realname}-${pkgver}"/LICENSE.txt \
    "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE
}
