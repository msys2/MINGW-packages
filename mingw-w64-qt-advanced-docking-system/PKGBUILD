# Contributor: Mehdi Chinoune <mehdi.chinoune@hotmail.com>

_realname=qt-advanced-docking-system
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=4.5.0
pkgrel=1
pkgdesc="Advanced Docking System for Qt (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://github.com/githubuser0xFFFF/Qt-Advanced-Docking-System'
msys2_repository_url='https://github.com/githubuser0xFFFF/Qt-Advanced-Docking-System'
license=('spdx:LGPL-2.1-or-later')
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs"
         "${MINGW_PACKAGE_PREFIX}-qt6-base")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-ninja")
source=("${url}/archive/${pkgver}/${_realname}-${pkgver}.tar.gz"
        "001-add-cmake-module-path.patch"
        "002-do-not-use-git-version.patch")
sha256sums=('a438810b9749684232fa29721857bb700167006f44407ab4dd51f5c90d171f09'
            'a9985cd8d8bf0934aad5878d9b3543de0ddff6d70624772c0daa99a0a44ac916'
            '52257f69cb32a60bbbb4b7255ae47c4d2e52808deca40d4bffa15bf9e773e8d5')

prepare() {
  cd Qt-Advanced-Docking-System-${pkgver}
  patch -p1 -i "${srcdir}"/001-add-cmake-module-path.patch
  patch -p1 -i "${srcdir}"/002-do-not-use-git-version.patch
}

build() {
  declare -a extra_config
  if check_option "debug" "n"; then
    extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    cmake \
      -GNinja \
      -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
      "${extra_config[@]}" \
      -DBUILD_SHARED_LIBS=ON \
      -DBUILD_EXAMPLES=OFF \
      -DADS_VERSION="${pkgver}" \
      -DQT_VERSION_MAJOR="6" \
      -S "Qt-Advanced-Docking-System-${pkgver}" \
      -B "build-${MSYSTEM}"

  cmake --build "build-${MSYSTEM}"
}

package() {
  DESTDIR="${pkgdir}" cmake --install "build-${MSYSTEM}"

  install -Dm644 "${srcdir}"/Qt-Advanced-Docking-System-${pkgver}/LICENSE \
    "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE
}
